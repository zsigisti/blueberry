# common.list — graphical base shared by every Blueberry Desktop spin.
# Built from packages/<name> the same way as the base image (self-hosted; no
# Arch mirrors). Lines starting with '#' and blank lines are ignored.
#
# This is the dependency closure the build server fills in incrementally; a
# package listed here must have a packages/<name>/bpm.toml before `desktop-iso`
# can bundle it. Order is roughly bottom-up (libs before consumers).

# ── Foundation libraries (layer 0/1 — built & verified from source) ───────────
# Bottom-up order: these underpin the whole graphical stack. zlib/zstd/xz are
# host-provided (etc/bpm/provided), so they are not listed here.
libpng
libjpeg-turbo
pixman
libxml2
libpciaccess
coreutils                   # cat/ls/cp/tail/tty/env/sleep — base CLI tools (no busybox)
grep                        # GNU grep (desktop has no busybox)
sed                         # GNU sed
gawk                        # GNU awk
findutils                   # find/xargs
tar                         # GNU tar
gzip                        # gzip
freetype2
glib2
glibc-locales               # en_US.UTF-8 locale-archive
fontconfig
harfbuzz
xkeyboard-config
libxkbcommon

# ── Display / graphics stack ──────────────────────────────────────────────────
wayland
wayland-protocols
libdrm
libglvnd
mesa                   # needs LLVM (heavy) — build-server layer
vulkan-icd-loader
xorg-xwayland          # X11 app compatibility under Wayland (needs xcb sub-layer)

# ── Session / policy / login ──────────────────────────────────────────────────
pam
polkit
xdg-desktop-portal
xdg-utils
systemd
sddm                   # display manager (default greeter for both spins)

# ── Audio ─────────────────────────────────────────────────────────────────────
pipewire
wireplumber

# ── Networking (desktop) ──────────────────────────────────────────────────────
networkmanager

# ── Bluetooth / printing ──────────────────────────────────────────────────────
bluez
cups

# ── Fonts / theming base ──────────────────────────────────────────────────────
glibc-locales               # en_US.UTF-8 locale-archive
fontconfig
freetype2
harfbuzz
ttf-dejavu                  # DejaVu — actually-built UI font (noto recipe pending)

# ── Installer (live ISO only; not copied to the target) ───────────────────────
calamares

# ── Runtime library closure (ELF-NEEDED by SDDM/KWin/Plasma/Calamares but not
#    always declared as package deps; staged explicitly so the graphical stack
#    links cleanly). See doc / git log "closure libs round 2".
icu                         # libicuuc/libicui18n.78 — Qt6Core
krb5                        # libgssapi_krb5.2 — Qt6Network
keyutils                    # libkeyutils.1 — krb5
lcms2                       # liblcms2.2 — kwin
libinput                    # libinput.10 — kwin
libxcvt                     # libxcvt.0 — kwin
libdisplay-info             # libdisplay-info.3 — kwin
libqaccessibilityclient-qt6 # kwin_wayland a11y
libpulse                    # libpulse.0 — Qt6Multimedia / plasma-pa
libsndfile                  # libsndfile.1 — libpulse
lmdb                        # liblmdb.so — baloo
yaml-cpp                    # libyaml-cpp.0.9 — Calamares
qt6-speech                  # libQt6TextToSpeech.6 — KF6TextEditor
libcanberra                 # libcanberra.0 — notification sounds
libtool                     # libltdl.7 — libcanberra
libogg                      # libogg.0 — libvorbis
libvorbis                   # libvorbisfile.3 — libcanberra
# iOS device support (KF6Solid)
libplist
libusbmuxd
libimobiledevice-glue
libtatsu
libimobiledevice

# ── GPU/render closure (Mesa llvmpipe software GL + Kirigami) ──────────────────
libgomp                     # libgomp.so.1 — Kirigami / KDE
libxxf86vm                  # libXxf86vm.so.1 — Mesa GLX
spirv-tools                 # libSPIRV-Tools.so — Mesa Gallium

# ── KWin input stack ──────────────────────────────────────────────────────────
libevdev                    # libevdev.so.2 — KWin/libinput
mtdev                       # libmtdev.so.1 — KWin/libinput
libwacom                    # libwacom.so.9 — KWin tablet support
libgudev                    # libgudev-1.0.so.0 — libwacom

# Qt6 accessibility bridge (kwin QSpiAccessibleBridge)
at-spi2-core
liburing
libice
libsm
breeze-icons
xcb-util-cursor
xcb-util-wm
xcb-util-keysyms
xcb-util-image
xcb-util-renderutil
libfontenc
libxfont2
libxcvt
xorg-xwayland
libxkbfile
xorg-xkbcomp
libmd
libbsd
exiv2
libkexiv2
plasma-activities-stats
appstream                   # libAppStreamQt.so.3 — Plasma kicker (Application Launcher); pulls libxmlb + libfyaml
kirigami-addons             # org.kde.kirigamiaddons.components QML — Plasma kickoff launcher
parted                      # libparted.so.2 — Calamares 'welcome'/partition modules
libpwquality                # libpwquality.so.1 — Calamares 'users' module
qrencode                    # libqrencode.so.4 — Plasma clipboard/klipper applet
libdmtx                     # libdmtx.so.0 — Plasma clipboard/klipper (Data Matrix)
pulseaudio-qt               # libKF6PulseAudioQt.so.5 — Plasma volume/sound applet
libasyncns                  # libasyncns.so.0 — libpulse dep (volume applet)
libnsl                      # libnsl.so.3 — libpulse/volume (pulls libtirpc)
libtirpc                    # libtirpc.so.3 — libnsl dep
polkit-qt6                  # libpolkit-qt6-core-1.so.1 — Calamares/kpmcore disk-scan helper

# ── Runtime-closure libs consumed only by dlopen'd KDE plugins ────────────────
# Their owning package doesn't declare the dep, so the stage BFS won't reach them
# transitively — list them explicitly. (Enforced by tools/check-runtime-closure.py.)
taglib                      # libtag.so.2 — kfilemetadata audio tag extractor/writer
tslib                       # libts.so.0 — Qt eglfs touchscreen integration
openjpeg2                   # libopenjp2.so.7 — kimageformats JPEG 2000 thumbnails
gpgme                       # libgpgmepp.so.7 — kate GPG plugin
jansson                     # libjansson.so.4 — libddcutil (brightness) JSON
libsecret                   # libsecret-1.so.0 — qtkeychain secret store backend
ffmpeg                      # libav*/libsw* — qt6-multimedia + kpipewire record
libva                       # libva.so.2 — VA-API video acceleration
lm_sensors                  # libsensors.so.5 — ksystemstats / system monitor
ddcutil                     # libddcutil.so.5 — powerdevil brightness (DDC/CI)
libnl                       # libnl-3.so.200 — ksystemstats network plugin
hunspell                    # libhunspell-1.7.so.0 — sonnet spellcheck
libxslt                     # libxslt/libexslt — kio help (kio_help/kio_ghelp)
editorconfig-core-c         # libeditorconfig.so.0 — ktexteditor
qtkeychain-qt6              # libqt6keychain.so.1 — plasma-nm/Wi-Fi secrets
libei                       # libei/libeis — kwin emulated input
gtk3                        # libgtk-3/libgdk-3/libcairo/libpango/libgdk_pixbuf — qgtk3 platform theme + GTK apps
libcups                     # libcups.so.2 — printing (qt6 cups printsupport + gtk3)
qcoro                       # libQCoro6Core/DBus.so.0 — plasma-nm, powerdevil (network/brightness)
baloo-widgets               # libKF6BalooWidgets.so.6 — dolphin file metadata panel
kdoctools                   # libKF6DocTools.so.6 — kio_help / khelpcenter
poppler                     # libpoppler.so.161/libpoppler-qt6.so.3 — kfilemetadata PDF extractor
qalculate                   # libqalculate.so.23 — krunner calculator runner
ebook-tools                 # libepub.so.0 — kfilemetadata epub extractor
libjxl                      # libjxl.so.0.11 — kimageformats JPEG XL
zxing-cpp                   # libZXing.so.4 — KF6Prison (clipboard QR / barcode)
qt6-tools                   # libQt6UiTools.so.6 — kwin effect KCMs
qt6-quick3d                 # libQt6Quick3D*.so.6 — QtQuick3D SpatialAudio
