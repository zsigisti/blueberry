#!/bin/sh
# blueberry-install — launch Calamares as root from the live Plasma session.
#
# pkexec sanitises the environment, which strips WAYLAND_DISPLAY /
# XDG_RUNTIME_DIR / QT_QPA_PLATFORM. Without them the root Calamares (a Qt GUI)
# has no display to connect to and the window never appears — clicking "Install
# System" silently does nothing. We pass the live user's session env through to
# root (root can read the user's runtime dir and connect to its Wayland socket),
# so the installer GUI actually shows up.
#
# The live polkit rule (49-live-calamares.rules) grants org.freedesktop.policykit.exec
# to the 'wheel' group with Result.YES, so no password prompt is needed.
set -e
RT="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
# pkexec sanitises the environment, so the root Calamares does NOT inherit the
# session's software-GL setup (LIBGL_ALWAYS_SOFTWARE / GALLIUM_DRIVER, set for
# KWin via /etc/xdg/plasma-workspace/env). Without them a root Qt app on a
# GPU-less VM tries a *hardware* GL/EGL context and aborts a few seconds in —
# which is why the installer died right after the Welcome page. Pass the whole
# software-rendering set through so Calamares renders via llvmpipe like the rest
# of the live session. QT_QUICK_BACKEND=software also keeps Qt Quick off GL.
# calamares -d is teed to the serial console for the install smoke-test.
exec pkexec env \
    XDG_RUNTIME_DIR="$RT" \
    WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}" \
    QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland}" \
    QT_QUICK_BACKEND=software \
    LIBGL_ALWAYS_SOFTWARE=1 \
    GALLIUM_DRIVER=llvmpipe \
    MESA_LOADER_DRIVER_OVERRIDE=llvmpipe \
    __GLX_VENDOR_LIBRARY_NAME=mesa \
    QTWEBENGINE_CHROMIUM_FLAGS="--disable-gpu" \
    DISPLAY="${DISPLAY:-}" \
    XAUTHORITY="${XAUTHORITY:-}" \
    QT_SCALE_FACTOR="${QT_SCALE_FACTOR:-1}" \
    sh -c 'calamares -d 2>&1 | tee /dev/ttyS0 2>/dev/null || calamares'
