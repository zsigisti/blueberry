#%PAM-1.0
# Load /etc/environment (LANG=en_US.UTF-8) at BOTH auth and session so the greeter
# process — forked from the session — actually inherits the UTF-8 locale.
# Stock sddm-greeter only ran pam_env at auth, so Qt kept seeing "C"/ANSI.
auth        required    pam_env.so readenv=1
auth        required    pam_permit.so
account     required    pam_permit.so
password    required    pam_deny.so
session     required    pam_env.so readenv=1
session     required    pam_unix.so
session     optional    pam_systemd.so
