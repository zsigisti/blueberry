# Live session runs on QEMU/virtio-gpu (no virgl) or generic KMS where Mesa has
# no native GBM driver. Force KWin's software (QPainter) DRM backend + llvmpipe
# so the compositor renders without a GPU-specific GL driver. Harmless on real
# hardware where it still works (just unaccelerated); real installs can drop it.
KWIN_DRM_USE_QPAINTER=1
LIBGL_ALWAYS_SOFTWARE=1
# virtio-gpu (and most KMS under software rendering) does not expose a working
# hardware cursor plane → the mouse cursor is invisible. Force KWin to composite
# the cursor in software. Harmless on real hardware.
KWIN_FORCE_SW_CURSOR=1
# Default cursor theme so Xcursor/Plasma always resolve a cursor asset.
XCURSOR_THEME=breeze_cursors
XCURSOR_SIZE=24
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
