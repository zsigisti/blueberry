# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=frameworkintegration
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: integrate Qt apps with the KDE workspace'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'kconfig' 'kconfigwidgets' 'kcoreaddons' 'ki18n' 'kio' 'knewstuff' 'knotifications' 'kwidgetsaddons' 'kiconthemes' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/frameworkintegration-$pkgver.tar.xz")
sha256sums=('55eefe8ebc67a040e64c75482276c29a69d0c5877b7b3674f4c7a40238c6d44c')

build() {
  cmake -S "frameworkintegration-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
