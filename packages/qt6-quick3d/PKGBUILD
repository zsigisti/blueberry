# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-quick3d
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 Quick 3D rendering module'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-declarative' 'qt6-shadertools' 'assimp' )
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'perl' 'qt6-shadertools' 'assimp' )
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtquick3d-everywhere-src-$pkgver.tar.xz")
sha256sums=('c76b85de3f8aa2a4bee64987acfef560675c1b378b92076c7c6264613e5b456f')

build() {
  cmake -S "qtquick3d-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
