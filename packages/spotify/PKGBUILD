# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# Spotify's official Linux client (extracted from the vendor .deb).
pkgname=spotify
pkgver=1.2.63.394
pkgrel=1
pkgdesc='Spotify music streaming client (official binary)'
arch=('x86_64')
url='https://www.spotify.com/'
license=('custom')
depends=('gtk3' 'glib2' 'nss' 'alsa-lib' 'libpulse' 'libxcb' 'libx11'
         'libxext' 'libxrandr' 'libxcomposite' 'libxdamage' 'libxfixes'
         'mesa' 'libxshmfence' 'ffmpeg' 'openssl')
options=(!strip !debug)
_deb=spotify-client_${pkgver}.g7e3d287d_amd64.deb
source=("$_deb::https://repository.spotify.com/pool/non-free/s/spotify-client/$_deb")
sha256sums=('SKIP')
package() {
  bsdtar -xf data.tar.* -C "$pkgdir" 2>/dev/null || { ar x "$srcdir/$_deb"; bsdtar -xf data.tar.* -C "$pkgdir"; }
  # wrapper
  install -d "$pkgdir/usr/bin"
  ln -sf /usr/share/spotify/spotify "$pkgdir/usr/bin/spotify" 2>/dev/null || true
}
