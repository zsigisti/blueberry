# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kcompletion
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: text completion helpers'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'kconfig' 'kcodecs' 'kwidgetsaddons' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kcompletion-$pkgver.tar.xz")
sha256sums=('006864dcba5d5fc87b4ca5dcc1239538657a5d052057bae5d3bc3e71eaba0551')

build() {
  cmake -S "kcompletion-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
