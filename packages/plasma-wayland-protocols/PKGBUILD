# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=plasma-wayland-protocols
pkgver=1.21.0
pkgrel=1
pkgdesc='Plasma-specific Wayland protocol XML definitions (KWin, kwindowsystem)'
arch=('any')
url='https://invent.kde.org/libraries/plasma-wayland-protocols'
license=('LGPL-2.1-or-later')
depends=()
makedepends=('extra-cmake-modules' 'cmake' 'ninja')
source=("https://download.kde.org/stable/plasma-wayland-protocols/plasma-wayland-protocols-$pkgver.tar.xz")
sha256sums=('698a7b28b711270314e396e248ae86087cfeaed01372009063995be6e1dc85ba')

build() {
  cmake -S "plasma-wayland-protocols-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D BUILD_TESTING=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
