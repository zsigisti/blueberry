# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=vulkan-headers
pkgver=1.4.304
pkgrel=1
pkgdesc='Vulkan header files and API registry'
arch=('any')
url='https://github.com/KhronosGroup/Vulkan-Headers'
license=('Apache-2.0')
depends=()
makedepends=('cmake' 'ninja')
source=("$pkgname-$pkgver.tar.gz::https://github.com/KhronosGroup/Vulkan-Headers/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('5e1a06b3f27e7581b55d1dea176fd97ee0a2f299406db2f437c1d2f297ceba5b')

build() {
  cmake -S "Vulkan-Headers-$pkgver" -B build -G Ninja -D CMAKE_INSTALL_PREFIX=/usr
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "Vulkan-Headers-$pkgver/LICENSE.md" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE.md"
}
