# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# 32-bit (i686) GNU C Library — the foundation of the multilib layer that lets
# 32-bit software (Steam, older games) run on 64-bit Blueberry. Version-matched
# to the 64-bit glibc (2.43). Installs only /usr/lib32; the 64-bit glibc package
# provides the shared headers, locale data, and binaries.
pkgname=lib32-glibc
pkgver=2.43
pkgrel=1
pkgdesc='GNU C Library (32-bit) — multilib runtime for i686 software'
arch=('x86_64')
url='https://www.gnu.org/software/libc/'
license=('GPL-2.0-or-later' 'LGPL-2.1-or-later')
depends=('glibc')
# lib32-gcc-libs from Arch multilib provides the 32-bit libgcc needed for -m32
# linking during this build; linux-api-headers are arch-independent.
makedepends=('lib32-gcc-libs' 'linux-api-headers' 'python')
options=('staticlibs' '!lto')
source=("https://ftp.gnu.org/gnu/glibc/glibc-$pkgver.tar.xz")
sha256sums=('d9c86c6b5dbddb43a3e08270c5844fc5177d19442cf5b8df4be7c07cd5fa3831')

build() {
  export CC="gcc -m32" CXX="g++ -m32"
  # glibc manages its own hardening; strip makepkg's conflicting flags.
  export CFLAGS="${CFLAGS//-Wp,-D_FORTIFY_SOURCE=3/} -m32"
  export CFLAGS="${CFLAGS//-Werror=format-security/}"
  mkdir -p build && cd build
  ../"glibc-$pkgver"/configure \
    --prefix=/usr \
    --libdir=/usr/lib32 \
    --libexecdir=/usr/lib32 \
    --host=i686-pc-linux-gnu \
    --with-headers=/usr/include \
    --enable-kernel=5.4 \
    --enable-bind-now \
    --enable-stack-protector=strong \
    --disable-profile \
    --disable-werror \
    --without-selinux \
    --disable-nscd
  make
}

package() {
  cd build
  make install_root="$pkgdir" install
  # Keep only the 32-bit libraries; the 64-bit glibc owns everything else.
  install -d "$pkgdir/usr/lib32.keep"
  mv "$pkgdir/usr/lib32"/* "$pkgdir/usr/lib32.keep/" 2>/dev/null || true
  rm -rf "$pkgdir/usr/include" "$pkgdir/usr/bin" "$pkgdir/usr/sbin" \
         "$pkgdir/usr/share" "$pkgdir/etc" "$pkgdir/var" "$pkgdir/usr/lib" \
         "$pkgdir/sbin" "$pkgdir/lib"
  mkdir -p "$pkgdir/usr/lib32"
  mv "$pkgdir/usr/lib32.keep"/* "$pkgdir/usr/lib32/" 2>/dev/null || true
  rmdir "$pkgdir/usr/lib32.keep" 2>/dev/null || true
}
