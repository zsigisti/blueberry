# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=qt6-base
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 base toolkit: Core, Gui, Widgets, Network, DBus, the xcb + wayland platforms'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('glibc' 'gcc-libs' 'zlib' 'libpng' 'libjpeg-turbo' 'freetype2'
         'fontconfig' 'harfbuzz' 'pcre2' 'glib2' 'double-conversion' 'md4c'
         'libb2' 'openssl' 'dbus' 'libx11' 'libxcb' 'libxkbcommon' 'libxrender'
         'libxrandr' 'libxfixes' 'libxext' 'libxi' 'libxcursor'
         'xcb-util' 'xcb-util-image' 'xcb-util-keysyms' 'xcb-util-renderutil'
         'xcb-util-wm' 'xcb-util-cursor' 'libglvnd' 'mesa' 'wayland')
provides=('libQt6Core.so' 'libQt6Gui.so' 'libQt6Widgets.so' 'libQt6Network.so'
          'libQt6DBus.so' 'libQt6Concurrent.so' 'libQt6OpenGL.so'
          'libQt6OpenGLWidgets.so' 'libQt6PrintSupport.so' 'libQt6Sql.so'
          'libQt6Test.so' 'libQt6Xml.so')
# libxkbcommon-x11 is split out on Arch; needed at build for xkbcommon-x11.pc
# (Blueberry's libxkbcommon ships both libs in one package at runtime).
makedepends=('cmake' 'ninja' 'python' 'vulkan-headers' 'wayland-protocols'
             'libxkbcommon' 'libxkbcommon-x11' 'pkgconf' 'perl')
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtbase-everywhere-src-$pkgver.tar.xz")
sha256sums=('d9594a31228aa23ad6b531719a29b45f0f3989fe6c136d45767ea179f233c1ac')

build() {
  # System libraries everywhere (self-hosted from packages/), no bundled copies.
  cmake -S "qtbase-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D INSTALL_DATADIR=/usr/share/qt6 \
    -D INSTALL_DOCDIR=/usr/share/doc/qt6 \
    -D INSTALL_INCLUDEDIR=/usr/include/qt6 \
    -D INSTALL_MKSPECSDIR=/usr/lib/qt6/mkspecs \
    -D QT_FEATURE_system_zlib=ON \
    -D QT_FEATURE_system_libpng=ON \
    -D QT_FEATURE_system_libjpeg=ON \
    -D QT_FEATURE_system_freetype=ON \
    -D QT_FEATURE_system_harfbuzz=ON \
    -D QT_FEATURE_system_pcre2=ON \
    -D QT_FEATURE_system_doubleconversion=ON \
    -D QT_FEATURE_xcb=ON \
    -D QT_FEATURE_xcb_xlib=ON \
    -D QT_FEATURE_wayland=ON \
    -D QT_FEATURE_dbus=ON \
    -D QT_FEATURE_openssl_linked=ON \
    -D QT_FEATURE_vulkan=ON \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "qtbase-everywhere-src-$pkgver/LICENSES/LGPL-3.0-only.txt" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
