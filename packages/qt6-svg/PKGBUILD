# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-svg
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 SVG rendering module (icons, Plasma theming, Calamares branding)'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'zlib')
provides=('libQt6Svg.so' 'libQt6SvgWidgets.so')
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'perl')
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtsvg-everywhere-src-$pkgver.tar.xz")
sha256sums=('7f3cf02f4824bf03c2c5859ea6db173bf1482a1daf24e6cdf7bc78cfa26a8a94')

build() {
  cmake -S "qtsvg-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "qtsvg-everywhere-src-$pkgver/LICENSES/LGPL-3.0-only.txt" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
