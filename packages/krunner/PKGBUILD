# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=krunner
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: parallelized query/launcher framework'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'kconfig' 'kcoreaddons' 'ki18n' 'kio'  'kitemmodels')
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/krunner-$pkgver.tar.xz")
sha256sums=('46d06321bbccadb8f3fbb948ffaac5eff18dad9552fde677761ddddb9470202f')

build() {
  cmake -S "krunner-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
