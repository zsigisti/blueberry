# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=xcb-util-wm
pkgver=0.4.2
pkgrel=1
pkgdesc='XCB utility library: xcb-util-wm'
arch=('x86_64')
url='https://xcb.freedesktop.org/'
license=('MIT')
depends=('libxcb')
provides=('libxcb-ewmh.so' 'libxcb-icccm.so')
makedepends=('xcb-proto' 'xorgproto' 'xorg-util-macros' 'libxcb' 'pkgconf' 'gperf')
source=("https://xorg.freedesktop.org/archive/individual/lib/xcb-util-wm-0.4.2.tar.xz")
sha256sums=('62c34e21d06264687faea7edbf63632c9f04d55e72114aa4a57bb95e4f888a0b')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
