# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=binutils
pkgver=2.44
pkgrel=2
pkgdesc='GNU assembler, linker and binary utilities (as, ld, ar, objdump, ...)'
arch=('x86_64')
url='https://www.gnu.org/software/binutils/'
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later')
# elfutils: libdebuginfod client (addr2line/objdump fetch debug info on demand).
depends=('glibc' 'zlib' 'elfutils')
source=("https://ftp.gnu.org/gnu/binutils/binutils-$pkgver.tar.xz")
sha256sums=('ce2017e059d63e67ddb9240e9d4ec49c2893605035cd60e92ad53177f4377237')
build() {
  # binutils wants an out-of-tree build directory.
  mkdir -p build && cd build
  ../"$pkgname-$pkgver"/configure \
    --prefix=/usr \
    --with-system-zlib \
    --enable-deterministic-archives \
    --enable-default-hash-style=gnu \
    --disable-multilib \
    --disable-werror \
    --disable-gprofng \
    --disable-nls
  make
}
package() {
  cd build
  make DESTDIR="$pkgdir" install
  # Drop files that collide with a future libtool/gettext or are dev-only noise.
  rm -f "$pkgdir"/usr/share/man/man1/{dlltool,nlmconv,windmc,windres}* 2>/dev/null || true
}
