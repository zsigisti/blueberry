# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libdatrie
pkgver=0.2.14
pkgrel=1
pkgdesc='Double-array trie library'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('glibc' )
makedepends=('pkgconf' )
options=('!lto')
source=("libdatrie-0.2.14.tar.xz::https://github.com/tlwg/libdatrie/releases/download/v0.2.14/libdatrie-0.2.14.tar.xz")
sha256sums=('f04095010518635b51c2313efa4f290b7db828d6273e39b2b8858f859dfe81d5')

build() {
  cd "libdatrie-0.2.14"
  ./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var 
  make
}

package() {
  cd "libdatrie-0.2.14"; make DESTDIR="$pkgdir" install
}
