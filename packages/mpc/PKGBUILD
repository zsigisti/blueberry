# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=mpc
pkgver=1.3.1
pkgrel=2
pkgdesc='Library for complex-number arithmetic with arbitrary precision (libmpc)'
arch=('x86_64')
url='https://www.multiprecision.org/mpc/'
license=('LGPL-3.0-or-later')
# gmp (libgmp): mpc links it directly (mpfr does too, but declare it here).
depends=('mpfr' 'gmp')
provides=('libmpc.so')
source=("https://ftp.gnu.org/gnu/mpc/mpc-$pkgver.tar.gz")
sha256sums=('ab642492f5cf882b74aa0cb730cd410a81edcdbec895183ce930e706c1c759b8')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
