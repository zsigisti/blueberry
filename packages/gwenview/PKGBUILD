# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=gwenview
pkgver=26.04.2
pkgrel=1
pkgdesc='KDE: the Gwenview image viewer'
arch=('x86_64')
url='https://kde.org/plasma-desktop/'
license=('GPL-2.0-or-later')
depends=('baloo' 'cfitsio' 'exiv2' 'kcolorscheme' 'kcompletion' 'kconfig' 'kconfigwidgets' 'kcoreaddons' 'kcrash' 'kfilemetadata' 'kguiaddons' 'ki18n' 'kiconthemes' 'kio' 'kitemmodels' 'kitemviews' 'kjobwidgets' 'kparts' 'kservice' 'kwidgetsaddons' 'kxmlgui' 'lcms2' 'libjpeg-turbo' 'libkexiv2' 'libpng' 'libtiff' 'libx11' 'plasma-activities' 'purpose' 'qt6-base' 'qt6-multimedia' 'qt6-svg' 'solid' 'wayland' )
makedepends=('wayland-protocols' 'qt6-wayland' 'kdoctools' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-tools' 'exiv2' 'cfitsio' 'lcms2' 'libtiff' 'qt6-multimedia' )
options=('!lto')
source=("https://download.kde.org/stable/release-service/26.04.2/src/gwenview-$pkgver.tar.xz")
sha256sums=('150b601741f1fcf3aae5e8fa6dbd28ae83afe3e0914a1e91c84efa55312d9a69')

build() {
  cmake -S "gwenview-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_LIBEXECDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF \
    -D FORCE_NOT_REQUIRED_DEPENDENCIES="KDcrawQt6;kImageAnnotator-Qt6"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
