# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qqc2-breeze-style
pkgver=6.7.0
pkgrel=1
pkgdesc='KDE: Breeze style for QtQuick Controls 2'
arch=('x86_64')
url='https://kde.org/plasma-desktop/'
license=('GPL-2.0-or-later')
depends=('kcolorscheme' 'kconfig' 'kguiaddons' 'kiconthemes' 'kirigami' 'qt6-base' 'qt6-declarative' )
makedepends=('kdoctools' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-tools')
options=('!lto')
source=("https://download.kde.org/stable/plasma/6.7.0/qqc2-breeze-style-$pkgver.tar.xz")
sha256sums=('81fb0f43fe15c2bcd1c62e742caba84d60a4eb9380c0bcec447b5b7728e29fbb')

build() {
  cmake -S "qqc2-breeze-style-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_LIBEXECDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
