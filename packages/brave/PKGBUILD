# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# Binary repackage of Brave's official release (Chromium-based, self-contained).
pkgname=brave
pkgver=1.91.175
pkgrel=1
pkgdesc='Brave web browser (official binary)'
arch=('x86_64')
url='https://brave.com/'
license=('MPL-2.0')
depends=('gtk3' 'nss' 'alsa-lib' 'libcups' 'libxcb' 'libx11' 'libxext'
         'libxrandr' 'libxcomposite' 'libxdamage' 'libxfixes' 'libxkbcommon'
         'mesa' 'pango' 'cairo' 'dbus' 'libpulse')
options=(!strip !debug)
source=("brave-$pkgver.zip::https://github.com/brave/brave-browser/releases/download/v$pkgver/brave-browser-$pkgver-linux-amd64.zip"
        'brave.desktop')
sha256sums=('SKIP' 'SKIP')
package() {
  install -d "$pkgdir/opt/brave" "$pkgdir/usr/bin"
  cp -a brave-browser-$pkgver-linux-amd64/* "$pkgdir/opt/brave/" 2>/dev/null || cp -a ./* "$pkgdir/opt/brave/"
  rm -f "$pkgdir/opt/brave/brave.desktop"
  cat > "$pkgdir/usr/bin/brave" <<'EOF'
#!/bin/sh
exec /opt/brave/brave "$@"
EOF
  chmod 755 "$pkgdir/usr/bin/brave"
  [ -f "$pkgdir/opt/brave/product_logo_128.png" ] && install -Dm644 "$pkgdir/opt/brave/product_logo_128.png" "$pkgdir/usr/share/icons/hicolor/128x128/apps/brave.png"
  install -Dm644 "$srcdir/brave.desktop" "$pkgdir/usr/share/applications/brave.desktop"
}
