# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libevdev
pkgver=1.13.6
pkgrel=1
pkgdesc='Wrapper library for evdev input devices (KWin/libinput)'
arch=('x86_64')
url='https://www.freedesktop.org/wiki/Software/libevdev/'
license=('custom:MIT')
depends=('glibc')
makedepends=('meson' 'ninja' 'python')
options=('!lto')
source=("https://www.freedesktop.org/software/libevdev/libevdev-${pkgver}.tar.xz")
sha256sums=('73f215eccbd8233f414737ac06bca2687e67c44b97d2d7576091aa9718551110')
build() { meson setup "libevdev-${pkgver}" build --prefix=/usr --libdir=/usr/lib --buildtype=release -Dtests=disabled -Ddocumentation=disabled; ninja -C build; }
package() { DESTDIR="$pkgdir" ninja -C build install; }
