# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=strace
pkgver=6.13
pkgrel=2
pkgdesc='A diagnostic, debugging and instructional userspace tracer'
arch=('x86_64')
url='https://strace.io/'
license=('LGPL-2.1-or-later')
# elfutils (libdw): symbol/source resolution for -k stack traces.
depends=('glibc' 'elfutils')
options=('!lto')
source=("https://github.com/strace/strace/releases/download/v$pkgver/strace-$pkgver.tar.xz")
sha256sums=('e209daf0ee038ca5adcc4c277e9273b4d51f46a2ff86da575d36742ac3508a17')
build() {
  cd "$pkgname-$pkgver"
  # --enable-bundled=yes: use strace's bundled kernel headers; the container's
  # linux-api-headers are newer than 6.13 expects and a struct-size static_assert
  # (io_uring_buf_reg.resv) otherwise fails the build.
  # --disable-gcc-Werror: gcc 16 flags new warnings (e.g. discarded-qualifiers
  # in ioctl.c) that strace's default -Werror would turn into build failures.
  ./configure --prefix=/usr --enable-mpers=check --enable-bundled=yes \
    --disable-gcc-Werror
  make
}
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
