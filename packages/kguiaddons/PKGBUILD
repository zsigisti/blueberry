# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kguiaddons
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: utilities for graphical applications'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-wayland' 'wayland' )
makedepends=('plasma-wayland-protocols' 'qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-wayland' 'wayland-protocols' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kguiaddons-$pkgver.tar.xz")
sha256sums=('29b043480c45d3e51c57cac74fd83589cc7729c907a6585b72880cbf07feaf82')

build() {
  cmake -S "kguiaddons-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
