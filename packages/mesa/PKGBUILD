# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=mesa
pkgver=24.3.4
pkgrel=1
pkgdesc='Open-source OpenGL/Vulkan/EGL implementation (Gallium: llvmpipe, radeonsi, iris)'
arch=('x86_64')
url='https://www.mesa3d.org/'
license=('MIT')
depends=('libdrm' 'wayland' 'libxcb' 'libx11' 'libxext' 'libxfixes' 'libxrandr'
         'libxshmfence' 'expat' 'zlib' 'llvm' 'libglvnd' 'elfutils' 'glibc')
provides=('libgbm.so' 'libEGL_mesa.so' 'libGLX_mesa.so' 'libvulkan_intel.so'
          'libvulkan_radeon.so' 'libxatracker.so' 'opengl-driver')
# python-packaging is required: mesa's mako version check imports it (the
# distutils fallback is gone in Python 3.12+), and reports a misleading
# "mako required" error without it. python-yaml backs the driver descriptors.
makedepends=('meson' 'ninja' 'python' 'wayland-protocols' 'glslang'
             'llvm' 'libxml2' 'python-mako' 'python-packaging' 'python-yaml'
             'pkgconf')
source=("https://archive.mesa3d.org/mesa-$pkgver.tar.xz")
sha256sums=('e641ae27191d387599219694560d221b7feaa91c900bcec46bf444218ed66025')

prepare() {
  cd "$pkgname-$pkgver"
  # mesa only takes the system C11 <threads.h> path on Android; on Linux it
  # falls back to a pthread once_flag polyfill that now conflicts with glibc's
  # <threads.h> (once_flag/call_once redefined). glibc has full C11 threads, so
  # enable that path everywhere: it sets HAVE_THRD_CREATE + with_c11_threads,
  # which also drops the conflicting threads_posix.c from the build.
  sed -i 's/^  if with_platform_android$/  if true/' meson.build
}

build() {
  # Wayland-first build. Gallium llvmpipe (software) + radeonsi/r300/r600
  # (AMD) + iris/crocus (Intel); Vulkan for amd+intel. GLVND-based GL.
  # Call meson directly (not arch-meson): arch-meson forces --auto-features
  # enabled, which turns on android/d3d12/clc features that make no sense here
  # and pull heavy deps (libclc). --auto-features=auto enables only what fits.
  #
  # iris (Intel) + the Vulkan drivers need libclc (a clang/SPIR-V package),
  # deferred. llvmpipe guarantees software GL on any GPU; radeonsi covers AMD;
  # zink layers GL over Vulkan. Enough for KDE/GNOME compositing.
  # GCC 16 promotes -Wincompatible-pointer-types to an error; mesa's
  # cnd_monotonic.c passes a C11 mtx_t to pthread_cond_* (layout-compatible).
  # Relax to a warning (same GCC-16 stricter-defaults family as format-security).
  CFLAGS+=" -Wno-error=incompatible-pointer-types -Wno-error=implicit-function-declaration"
  meson setup "$pkgname-$pkgver" build \
    --prefix=/usr --libexecdir=lib --sbindir=bin --buildtype=plain \
    --auto-features=auto --wrap-mode=nodownload -D b_pie=true \
    -D platforms=wayland,x11 \
    -D gallium-drivers=llvmpipe,softpipe \
    -D vulkan-drivers= \
    -D glx=dri -D egl=enabled -D gbm=enabled -D opengl=true -D gles2=enabled \
    -D glvnd=enabled -D llvm=enabled -D shared-llvm=enabled \
    -D gallium-vdpau=disabled -D gallium-va=disabled -D gallium-xa=disabled \
    -D gallium-rusticl=false -D microsoft-clc=disabled \
    -D valgrind=disabled -D libunwind=disabled \
    -D lmsensors=disabled -D build-tests=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/docs/license.rst" \
    "$pkgdir/usr/share/licenses/$pkgname/license.rst" 2>/dev/null || true
}
