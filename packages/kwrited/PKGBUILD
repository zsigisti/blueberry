# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kwrited
pkgver=6.7.0
pkgrel=1
pkgdesc='KDE: daemon listening for wall/write messages'
arch=('x86_64')
url='https://kde.org/plasma-desktop/'
license=('GPL-2.0-or-later')
depends=('kcoreaddons' 'kdbusaddons' 'knotifications' 'kpty' 'qt6-base' )
makedepends=('extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-tools')
options=('!lto')
source=("https://download.kde.org/stable/plasma/6.7.0/kwrited-$pkgver.tar.xz")
sha256sums=('75439a92561f6c332804d1d27dae15bc5755b8c9af28da79d16c032d50903b10')

build() {
  cmake -S "kwrited-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_LIBEXECDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
