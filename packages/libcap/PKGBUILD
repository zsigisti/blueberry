# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libcap
pkgver=2.73
pkgrel=1
pkgdesc='POSIX 1003.1e capabilities library'
arch=('x86_64')
url='https://sites.google.com/site/fullycapable/'
license=('GPL2')
depends=('glibc')
provides=('libcap.so' 'libpsx.so')
source=("https://www.kernel.org/pub/linux/libs/security/linux-privs/libcap2/libcap-$pkgver.tar.xz")
sha256sums=('6405f6089cf4cdd8c271540cd990654d78dd0b1989b2d9bda20f933a75a795a5')
build() {
  cd "$pkgname-$pkgver"
  make CC=gcc GO= prefix=/usr lib=lib PAM_CAP=no
}
package() {
  cd "$pkgname-$pkgver"
  make install DESTDIR="$pkgdir" prefix=/usr lib=lib PAM_CAP=no RAISE_SETFCAP=no GO=
  install -Dm644 License "$pkgdir/usr/share/licenses/$pkgname/License"
}
