# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=diffutils
pkgver=3.10
pkgrel=1
pkgdesc='Utilities to compare files (diff, cmp, diff3, sdiff)'
arch=('x86_64')
url='https://www.gnu.org/software/diffutils/'
license=('GPL-3.0-or-later')
depends=('glibc')
source=("https://ftp.gnu.org/gnu/diffutils/diffutils-$pkgver.tar.xz")
sha256sums=('90e5e93cc724e4ebe12ede80df1634063c7a855692685919bfe60b556c9bd09e')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
