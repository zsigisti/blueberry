# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libglvnd
pkgver=1.7.0
pkgrel=1
pkgdesc='The GL Vendor-Neutral Dispatch library (EGL/GLES dispatch for Wayland)'
arch=('x86_64')
url='https://gitlab.freedesktop.org/glvnd/libglvnd'
license=('custom')
depends=('glibc' 'libx11' 'libxext')
# GLX dispatch must be enabled: libQt6Gui (and every Qt6 GUI app, incl. the SDDM
# greeter) links libGLX.so.0 unconditionally, even under Wayland. libx11/libxext
# are packaged and staged, so build the full EGL+GLES+GLX vendor-neutral stack.
provides=('libGL.so' 'libGLX.so' 'libGLdispatch.so' 'libEGL.so' 'libGLESv1_CM.so' 'libGLESv2.so' 'libOpenGL.so')
makedepends=('meson' 'ninja' 'python' 'libx11' 'libxext')
source=("https://gitlab.freedesktop.org/glvnd/libglvnd/-/archive/v$pkgver/libglvnd-v$pkgver.tar.gz")
sha256sums=('2b6e15b06aafb4c0b6e2348124808cbd9b291c647299eaaba2e3202f51ff2f3d')

build() {
  arch-meson "libglvnd-v$pkgver" build \
    -D x11=enabled -D glx=enabled -D egl=true -D gles1=true -D gles2=true
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "libglvnd-v$pkgver/README.md" \
    "$pkgdir/usr/share/licenses/$pkgname/README.md"
}
