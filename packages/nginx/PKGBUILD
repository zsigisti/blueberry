# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=nginx
pkgver=1.26.3
pkgrel=2
pkgdesc='Lightweight HTTP server and IMAP/POP3 proxy server'
arch=('x86_64')
url='https://nginx.org/'
license=('BSD-2-Clause')
depends=('glibc' 'pcre2' 'zlib' 'openssl')
source=("https://nginx.org/download/nginx-$pkgver.tar.gz")
sha256sums=('69ee2b237744036e61d24b836668aad3040dda461fe6f570f1787eab570c75aa')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/etc/nginx --sbin-path=/usr/bin/nginx \
    --conf-path=/etc/nginx/nginx.conf --pid-path=/run/nginx.pid \
    --lock-path=/run/lock/nginx.lock --http-log-path=/var/log/nginx/access.log \
    --error-log-path=/var/log/nginx/error.log \
    --http-client-body-temp-path=/var/lib/nginx/client-body \
    --http-proxy-temp-path=/var/lib/nginx/proxy \
    --with-http_ssl_module --with-http_v2_module --with-http_gzip_static_module \
    --with-http_realip_module --with-http_stub_status_module --with-pcre-jit \
    --with-threads --with-file-aio
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  rm -rf "$pkgdir/run"
  # runit service (disabled until `sv-enable nginx`); daemon off keeps nginx in
  # the foreground so runsv supervises it.
  install -dm755 "$pkgdir/etc/sv/nginx"
  printf '#!/bin/sh\nexec /usr/bin/nginx -g "daemon off;"\n' > "$pkgdir/etc/sv/nginx/run"
  chmod 755 "$pkgdir/etc/sv/nginx/run"
}
