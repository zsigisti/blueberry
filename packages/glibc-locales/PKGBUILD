# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# Pre-compiled glibc locale-archive (en_US.UTF-8 + C.UTF-8). glibc's package
# strips /usr/share/locale, and only C.UTF-8 is built in; SDDM/Qt want a real
# UTF-8 locale. localedef reads the toolchain glibc's /usr/share/i18n at build
# time (matching glibc version → compatible archive), so no source tarball.
pkgname=glibc-locales
pkgver=2.43
pkgrel=1
pkgdesc='Pre-generated UTF-8 locales (en_US.UTF-8) for the glibc locale-archive'
arch=('x86_64')
url='https://www.gnu.org/software/libc/'
license=('GPL-2.0-or-later' 'LGPL-2.1-or-later')
depends=('glibc')
makedepends=('glibc')
options=('!strip')
source=()
sha256sums=()
build() {
  # Generate DIRECTORY locales (--no-archive) into the build dir — the builder
  # user can't write the system /usr/lib/locale archive. glibc reads
  # /usr/lib/locale/<name>/ directory locales exactly like the archive.
  # localedef reads the toolchain glibc's /usr/share/i18n for the en_US source.
  localedef --no-archive -i en_US -f UTF-8 "$srcdir/en_US.utf8"
  localedef --no-archive -i C     -f UTF-8 "$srcdir/C.utf8" 2>/dev/null || true
}
package() {
  install -d "$pkgdir/usr/lib/locale"
  cp -a "$srcdir/en_US.utf8" "$pkgdir/usr/lib/locale/en_US.utf8"
  [ -d "$srcdir/C.utf8" ] && cp -a "$srcdir/C.utf8" "$pkgdir/usr/lib/locale/C.utf8" || true
  install -d "$pkgdir/etc"
  printf 'LANG=en_US.UTF-8\n' > "$pkgdir/etc/locale.conf"
}
