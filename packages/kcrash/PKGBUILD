# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kcrash
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: graceful crash handling'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'kcoreaddons' 'kwindowsystem' 'libx11' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kcrash-$pkgver.tar.xz")
sha256sums=('f8e1083863dac2c07068b10614ca7d4b52c6920df0228854cfc37e0d6578d902')

build() {
  cmake -S "kcrash-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
