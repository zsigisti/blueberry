# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libqaccessibilityclient-qt6
pkgver=0.6.0
pkgrel=1
pkgdesc='Accessibility client helper library (kwin_wayland)'
arch=('x86_64')
url='https://invent.kde.org/libraries/libqaccessibilityclient'
license=('LGPL-2.1-or-later')
depends=('qt6-base')
makedepends=('cmake' 'ninja' 'qt6-base' 'extra-cmake-modules')
options=('!lto')
source=("https://download.kde.org/stable/libqaccessibilityclient/libqaccessibilityclient-${pkgver}.tar.xz")
sha256sums=('4c50c448622dc9c5041ed10da7d87b3e4e71ccb49d4831a849211d423c5f5d33')
build() {
  cmake -S "libqaccessibilityclient-${pkgver}" -B build -G Ninja \
    -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib \
    -DBUILD_TESTING=OFF -DBUILD_WITH_QT6=ON
  cmake --build build
}
package() { DESTDIR="$pkgdir" cmake --install build; }
