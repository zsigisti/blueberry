# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=mandoc
pkgver=1.14.6
pkgrel=1
pkgdesc='Compact suite of tools to format and read man pages (provides man/apropos)'
arch=('x86_64')
url='https://mandoc.bsd.lv/'
license=('ISC')
depends=('glibc' 'zlib')
provides=('man' 'man-db')
source=("https://mandoc.bsd.lv/snapshots/mandoc-$pkgver.tar.gz")
sha256sums=('8bf0d570f01e70a6e124884088870cbed7537f36328d512909eb10cd53179d9c')

build() {
  cd "$pkgname-$pkgver"
  # mandoc takes its install paths from configure.local, not configure flags.
  cat > configure.local <<'EOF'
PREFIX=/usr
BINDIR=/usr/bin
SBINDIR=/usr/bin
MANDIR=/usr/share/man
INCLUDEDIR=/usr/include
LIBDIR=/usr/lib
LN="ln -sf"
MANM_MANCONF=mandoc.conf
BINM_MAN=man
BINM_APROPOS=apropos
BINM_WHATIS=whatis
BINM_MAKEWHATIS=makewhatis
EOF
  ./configure
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
