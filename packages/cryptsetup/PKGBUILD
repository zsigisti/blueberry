# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# cryptsetup — LUKS full-disk encryption. Uses the OpenSSL crypto backend and
# cryptsetup's built-in argon2 (no external libargon2 / libgcrypt needed).
pkgname=cryptsetup
pkgver=2.7.5
pkgrel=2
pkgdesc='LUKS disk encryption setup tool'
arch=('x86_64')
url='https://gitlab.com/cryptsetup/cryptsetup'
license=('GPL-2.0-or-later' 'LGPL-2.1-or-later')
# libdevmapper, libjson-c (LUKS2 metadata), libcrypto (openssl backend),
# libpopt (CLI), libuuid (util-linux), libz (zlib). blkid stays disabled.
depends=('glibc' 'device-mapper' 'json-c' 'openssl' 'popt' 'util-linux' 'zlib')
provides=('libcryptsetup.so')
source=("https://cdn.kernel.org/pub/linux/utils/cryptsetup/v2.7/cryptsetup-$pkgver.tar.xz")
sha256sums=('d2be4395b8f503b0ebf4b2d81db90c35a97050a358ee21fe62a0dfb66e5d5522')
build() {
  cd "$pkgname-$pkgver"
  ./configure \
    --prefix=/usr \
    --sbindir=/usr/bin \
    --disable-static \
    --disable-asciidoc \
    --disable-ssh-token \
    --disable-external-tokens \
    --disable-blkid \
    --with-crypto_backend=openssl
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
