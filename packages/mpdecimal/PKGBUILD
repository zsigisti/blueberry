# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# mpdecimal — correctly-rounded arbitrary precision decimal arithmetic. Python's
# _decimal C module links libmpdec.so.4.
pkgname=mpdecimal
pkgver=4.0.0
pkgrel=1
pkgdesc='Library for arbitrary precision correctly-rounded decimal arithmetic'
arch=('x86_64')
url='https://www.bytereef.org/mpdecimal/'
license=('BSD-2-Clause')
depends=('glibc' 'gcc-libs')
source=("https://www.bytereef.org/software/mpdecimal/releases/mpdecimal-$pkgver.tar.gz")
sha256sums=('942445c3245b22730fd41a67a7c5c231d11cb1b9936b9c0f76334fb7d0b4468c')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYRIGHT.txt "$pkgdir/usr/share/licenses/$pkgname/COPYRIGHT.txt"
}
