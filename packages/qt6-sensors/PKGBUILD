# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-sensors
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 sensors module'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-declarative' )
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'perl')
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtsensors-everywhere-src-$pkgver.tar.xz")
sha256sums=('23617062da7be526d023dec7f9b76231001a1098a7e5f94c646f2e4f87cfcf8f')

build() {
  cmake -S "qtsensors-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
