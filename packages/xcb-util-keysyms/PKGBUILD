# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=xcb-util-keysyms
pkgver=0.4.1
pkgrel=1
pkgdesc='XCB utility library: xcb-util-keysyms'
arch=('x86_64')
url='https://xcb.freedesktop.org/'
license=('MIT')
depends=('libxcb')
provides=('libxcb-keysyms.so')
makedepends=('xcb-proto' 'xorgproto' 'xorg-util-macros' 'libxcb' 'pkgconf' 'gperf')
source=("https://xorg.freedesktop.org/archive/individual/lib/xcb-util-keysyms-0.4.1.tar.xz")
sha256sums=('7c260a5294412aed429df1da2f8afd3bd07b7cba3fec772fba15a613a6d5c638')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
