# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=qt6-wayland
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 Wayland platform plugin and compositor APIs'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-declarative' 'wayland' 'libxkbcommon' 'libglvnd' 'mesa')
provides=('libQt6WaylandClient.so' 'libQt6WaylandCompositor.so'
          'libQt6WaylandEglClientHwIntegration.so')
# qt6-* pulled from Arch repos at build; Blueberry mirror at install.
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative'
             'wayland-protocols' 'vulkan-headers' 'perl')
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtwayland-everywhere-src-$pkgver.tar.xz")
sha256sums=('95788aa502f75441d4edf65932b235f76523084e13dbbb7b9ee2d207b32bd9b3')

build() {
  cmake -S "qtwayland-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "qtwayland-everywhere-src-$pkgver/LICENSES/LGPL-3.0-only.txt" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
