# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# Valve's Steam bootstrapper (downloads its own runtime on first launch).
# Pulls in Blueberry's 32-bit multilib layer (lib32-*) — the Steam client and its
# CEF store UI are 32-bit and link these before the Steam Runtime takes over.
pkgname=steam
pkgver=1.0.0.83
pkgrel=2
pkgdesc='Valve Steam client — bootstrapper + 32-bit multilib runtime'
arch=('x86_64')
url='https://store.steampowered.com/'
license=('custom')
depends=('glibc' 'libx11' 'libxcb' 'mesa' 'libglvnd' 'zenity'
         # 32-bit multilib layer the Steam client needs at runtime:
         'lib32-glibc' 'lib32-gcc-libs' 'lib32-zlib' 'lib32-libffi'
         'lib32-libx11' 'lib32-libxcb' 'lib32-libxau' 'lib32-libxdmcp'
         'lib32-libxext' 'lib32-libxfixes' 'lib32-libxrender' 'lib32-libxrandr'
         'lib32-libxinerama' 'lib32-libxcursor' 'lib32-libxi'
         'lib32-libglvnd' 'lib32-mesa' 'lib32-libdrm')
optdepends=('lib32-nss: in-client web store (CEF)'
            'lib32-libpulse: audio'
            'lib32-openal: positional audio in some games')
options=(!strip)
source=("steam.tar.gz::https://repo.steampowered.com/steam/archive/precise/steam_latest.tar.gz")
sha256sums=('SKIP')
package() {
  # The bootstrapper tarball ships a Debian-style tree (usr/ + etc/).
  cp -a steam/* "$pkgdir/" 2>/dev/null || cp -a ./* "$pkgdir/"
  rm -f "$pkgdir/PKGBUILD"
}
