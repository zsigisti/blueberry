# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kscreenlocker
pkgver=6.7.0
pkgrel=1
pkgdesc='KDE: secure screen locking framework'
arch=('x86_64')
url='https://kde.org/plasma-desktop/'
license=('GPL-2.0-or-later')
depends=('kcmutils' 'kconfig' 'kcoreaddons' 'kcrash' 'kdeclarative' 'kglobalaccel' 'ki18n' 'kidletime' 'kio' 'kirigami' 'knotifications' 'kpackage' 'ksvg' 'kwindowsystem' 'kxmlgui' 'layer-shell-qt' 'libkscreen' 'libx11' 'libxcb' 'libxi' 'pam' 'libplasma' 'qt6-base' 'qt6-declarative' 'wayland' 'xcb-util-keysyms' )
makedepends=('extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-tools' 'wayland-protocols' 'plasma-wayland-protocols' 'qt6-wayland' )
options=('!lto')
source=("https://download.kde.org/stable/plasma/6.7.0/kscreenlocker-$pkgver.tar.xz")
sha256sums=('c3154b68a885ed55d4cd577f813f5553ea0b31dbdd31b32b3744905550fec3d1')

build() {
  cmake -S "kscreenlocker-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_LIBEXECDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
