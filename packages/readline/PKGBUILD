# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# GNU readline — line editing + history. Used by sqlite, python, gdbm, etc.
pkgname=readline
pkgver=8.2
pkgrel=1
pkgdesc='GNU library for command-line editing and history'
arch=('x86_64')
url='https://tiswww.case.edu/php/chet/readline/rltop.html'
license=('GPL-3.0-or-later')
depends=('glibc' 'ncurses')
source=("https://ftp.gnu.org/gnu/readline/readline-$pkgver.tar.gz")
sha256sums=('3feb7171f16a84ee82ca18a36d7b9be109a52c04f492a053331d7d1095007c35')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  # link libreadline against ncursesw so termcap symbols resolve at load time
  make SHLIB_LIBS=-lncursesw
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
