# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=at-spi2-core
pkgver=2.60.4
pkgrel=1
pkgdesc='Assistive Technology Service Provider Interface (AT-SPI / libatspi — Qt6 a11y bridge)'
arch=('x86_64')
url='https://gitlab.gnome.org/GNOME/at-spi2-core'
license=('LGPL-2.1-or-later')
depends=('glibc' 'glib2' 'dbus' 'libx11' 'libxml2' 'libxtst' 'libxi')
makedepends=('meson' 'ninja' 'pkgconf' 'glib2-devel')
options=('!lto')
source=("https://download.gnome.org/sources/at-spi2-core/${pkgver%.*}/at-spi2-core-${pkgver}.tar.xz")
sha256sums=('1a1f5ba9805917f41fc6aa6823dcf887a291d607a427e2d5afb6b5dfa65070c7')
build() {
  meson setup "at-spi2-core-${pkgver}" build --prefix=/usr --libdir=/usr/lib \
    --buildtype=release -Dintrospection=disabled -Ddocs=false -Dtests=false
  ninja -C build
}
package() { DESTDIR="$pkgdir" ninja -C build install; }
