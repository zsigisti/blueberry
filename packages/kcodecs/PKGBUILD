# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kcodecs
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: text encoding/decoding utilities'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' )
makedepends=('extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'gperf' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kcodecs-$pkgver.tar.xz")
sha256sums=('77f51f7586e8b457534d95dd241280e8b7475915c656e661dc37b1e8a773c595')

build() {
  cmake -S "kcodecs-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
