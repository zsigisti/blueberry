# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=acl
pkgver=2.3.2
pkgrel=1
pkgdesc='Access control list utilities, libraries and headers'
arch=('x86_64')
url='https://savannah.nongnu.org/projects/acl'
license=('LGPL')
depends=('glibc' 'attr')
provides=('libacl.so')
source=("https://download.savannah.nongnu.org/releases/acl/acl-$pkgver.tar.gz")
sha256sums=('5f2bdbad629707aa7d85c623f994aa8a1d2dec55a73de5205bac0bf6058a2f7c')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
