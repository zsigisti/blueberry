# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kcmutils
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: utilities for KConfigModules (KCMs)'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'kconfigwidgets' 'kcoreaddons' 'kdeclarative' 'kio' 'kpackage' 'kxmlgui' 'kirigami' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kcmutils-$pkgver.tar.xz")
sha256sums=('beb0a50a22230fdd94164a5d6e53ea7f4cbc97b86cbab3ff2a592ea8663efa41')

build() {
  cmake -S "kcmutils-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
