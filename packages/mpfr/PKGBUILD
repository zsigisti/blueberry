# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=mpfr
pkgver=4.2.1
pkgrel=1
pkgdesc='Multiple-precision floating-point library (libmpfr)'
arch=('x86_64')
url='https://www.mpfr.org/'
license=('LGPL-3.0-or-later')
depends=('gmp')
provides=('libmpfr.so')
source=("https://www.mpfr.org/mpfr-$pkgver/mpfr-$pkgver.tar.xz")
sha256sums=('277807353a6726978996945af13e52829e3abd7a9a5b7fb2793894e18f1fcbb2')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --enable-thread-safe
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
