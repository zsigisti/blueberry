# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libxcb
pkgver=1.17.0
pkgrel=1
pkgdesc='X11 client-side C binding to the X protocol (XCB)'
arch=('x86_64')
url='https://xcb.freedesktop.org/'
license=('MIT')
depends=('libxau' 'libxdmcp' 'glibc')
provides=('libxcb.so' 'libxcb-composite.so' 'libxcb-damage.so' 'libxcb-dbe.so'
          'libxcb-dpms.so' 'libxcb-dri2.so' 'libxcb-dri3.so' 'libxcb-glx.so'
          'libxcb-present.so' 'libxcb-randr.so' 'libxcb-record.so'
          'libxcb-render.so' 'libxcb-res.so' 'libxcb-screensaver.so'
          'libxcb-shape.so' 'libxcb-shm.so' 'libxcb-sync.so' 'libxcb-xfixes.so'
          'libxcb-xinput.so' 'libxcb-xkb.so')
makedepends=('xcb-proto' 'xorgproto' 'python' 'libxslt' 'pkgconf')
source=("https://xorg.freedesktop.org/archive/individual/lib/libxcb-$pkgver.tar.xz")
sha256sums=('599ebf9996710fea71622e6e184f3a8ad5b43d0e5fa8c4e407123c88a59a6d55')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --enable-xinput --enable-xkb
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
