# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=icu
pkgver=78.3
pkgrel=1
pkgdesc='International Components for Unicode (libicuuc/libicui18n — Qt6Core)'
arch=('x86_64')
url='https://icu.unicode.org/'
license=('custom:icu')
depends=('gcc-libs' 'glibc')
makedepends=('python')
options=('!lto')
# Tarball extracts to icu/source.
source=("icu4c-${pkgver}-sources.tgz::https://github.com/unicode-org/icu/releases/download/release-${pkgver}/icu4c-${pkgver}-sources.tgz")
sha256sums=('3a2e7a47604ba702f345878308e6fefeca612ee895cf4a5f222e7955fabfe0c0')
build() {
  cd icu/source
  ./configure --prefix=/usr --libdir=/usr/lib --sysconfdir=/etc \
    --enable-static --disable-samples --disable-tests
  make
}
package() {
  cd icu/source
  make DESTDIR="$pkgdir" install
}
