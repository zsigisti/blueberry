# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libgcrypt
pkgver=1.11.0
pkgrel=1
pkgdesc='General purpose cryptographic library'
arch=('x86_64')
url='https://www.gnupg.org/'
license=('LGPL')
depends=('glibc' 'libgpg-error')
provides=('libgcrypt.so')
source=("https://gnupg.org/ftp/gcrypt/libgcrypt/libgcrypt-$pkgver.tar.bz2")
sha256sums=('09120c9867ce7f2081d6aaa1775386b98c2f2f246135761aae47d81f58685b9c')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
