# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libogg
pkgver=1.3.6
pkgrel=1
pkgdesc='Ogg bitstream library (libvorbis/libsndfile)'
arch=('x86_64')
url='https://www.xiph.org/ogg/'
license=('BSD-3-Clause')
depends=('glibc')
options=('!lto')
source=("https://downloads.xiph.org/releases/ogg/libogg-${pkgver}.tar.xz")
sha256sums=('5c8253428e181840cd20d41f3ca16557a9cc04bad4a3d04cce84808677fa1061')
build() { cd "libogg-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib; make; }
package() { cd "libogg-${pkgver}"; make DESTDIR="$pkgdir" install; }
