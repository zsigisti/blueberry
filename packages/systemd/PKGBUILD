# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
#
# systemd — PID 1, journald, logind, systemd-udevd, networkd, resolved,
# timesyncd. Slimmed for Blueberry: no PAM/SELinux/apparmor, no homed/userdbd/
# portabled/importd/machined/oomd, no boot loader (GRUB is used), no man pages.
pkgname=systemd
pkgver=256.7
pkgrel=1
pkgdesc='System and service manager (PID 1) — slimmed Blueberry build'
arch=('x86_64')
url='https://systemd.io/'
license=('LGPL-2.1-or-later' 'GPL-2.0-or-later')
depends=('glibc' 'libcap' 'util-linux' 'libseccomp' 'kmod' 'dbus' 'acl' 'xz' 'zstd' 'lz4' 'cryptsetup' 'pam')
makedepends=('meson' 'ninja' 'gperf' 'pkgconf' 'python-jinja' 'gettext' 'pam')
source=("https://github.com/systemd/systemd/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('896d76ff65c88f5fd9e42f90d152b0579049158a163431dd77cdc57748b1d7b0')

build() {
  cd "$pkgname-$pkgver"
  # meson option types: feature deps take enabled/disabled; component toggles
  # take true/false. Keep them straight or `meson setup` aborts.
  # systemd adds a fixed -Werror= list via add_project_arguments (meson.build),
  # which out-orders user c_args. gcc 16 makes -Werror=override-init fatal on the
  # generated errno-to-name.h (duplicate errno values), so drop just that flag.
  sed -i "/'-Werror=override-init',/d" meson.build
  meson setup build --prefix=/usr --buildtype=release \
    -Dmode=release -Dversion-tag="$pkgver-blueberry" \
    -Dsysvinit-path= -Dsysvrcnd-path= \
    -Ddbus=enabled -Dseccomp=enabled -Dblkid=enabled -Dkmod=enabled \
    -Dxz=enabled -Dzstd=enabled -Dlz4=enabled -Dacl=enabled \
    -Dnetworkd=true -Dresolve=true -Dtimesyncd=true -Dlogind=true \
    -Dhostnamed=true -Dlocaled=true -Dnss-systemd=false \
    -Dpam=enabled -Dselinux=disabled -Dapparmor=disabled -Dsmack=false \
    -Dhomed=disabled -Duserdb=false -Dportabled=false -Dsysext=false \
    -Dimportd=disabled -Dmachined=false -Doomd=false \
    -Drepart=disabled -Dsysupdate=disabled -Dukify=disabled \
    -Dbootloader=disabled -Defi=false \
    -Dman=disabled -Dhtml=disabled -Dtests=false -Dinstall-tests=false \
    -Daudit=disabled \
    -Dgnutls=disabled -Dopenssl=disabled -Dlibcurl=disabled -Dlibidn2=disabled \
    -Dxkbcommon=disabled -Dpwquality=disabled -Dp11kit=disabled \
    -Dqrencode=disabled -Delfutils=disabled -Dgcrypt=disabled \
    -Dpcre2=disabled -Dpolkit=disabled -Dbzip2=disabled \
    -Dfirstboot=true -Dhibernate=false -Dbacklight=false -Drandomseed=true \
    -Dbinfmt=true -Dvconsole=true -Dquotacheck=false -Dtmpfiles=true \
    -Dsysusers=true -Dadm-group=true -Dwheel-group=true \
    -Ddefault-dnssec=no -Ddefault-hierarchy=unified
  meson compile -C build
}

package() {
  cd "$pkgname-$pkgver"
  meson install -C build --destdir="$pkgdir"
  install -Dm644 LICENSE.LGPL2.1 "$pkgdir/usr/share/licenses/$pkgname/LICENSE.LGPL2.1"
}
