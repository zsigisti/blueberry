# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=spirv-tools
pkgver=1.4.350.1
pkgrel=1
pkgdesc='API and tools for processing SPIR-V modules (Mesa Gallium)'
arch=('x86_64')
url='https://github.com/KhronosGroup/SPIRV-Tools'
license=('Apache-2.0')
depends=('gcc-libs' 'glibc')
makedepends=('cmake' 'ninja' 'python')
options=('!lto')
source=("spirv-tools-${pkgver}.tar.gz::https://github.com/KhronosGroup/SPIRV-Tools/archive/refs/tags/vulkan-sdk-${pkgver}.tar.gz"
        "spirv-headers-${pkgver}.tar.gz::https://github.com/KhronosGroup/SPIRV-Headers/archive/refs/tags/vulkan-sdk-${pkgver}.tar.gz")
sha256sums=('6f7b9b9eed9a7aa485918466ea604b4edc7969d94e96c0c13ae266f4ec120f31'
            '9e6d5c78878172d2b810e97f3a74ecbbb14b4ad52b07384ce915fbbeb226d610')
build() {
  cmake -S "SPIRV-Tools-vulkan-sdk-${pkgver}" -B build -G Ninja \
    -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib \
    -DSPIRV-Headers_SOURCE_DIR="$PWD/SPIRV-Headers-vulkan-sdk-${pkgver}" \
    -DSPIRV_TOOLS_BUILD_STATIC=OFF -DBUILD_SHARED_LIBS=ON \
    -DSPIRV_SKIP_TESTS=ON -DSPIRV_SKIP_EXECUTABLES=OFF
  cmake --build build
}
package() { DESTDIR="$pkgdir" cmake --install build; }
