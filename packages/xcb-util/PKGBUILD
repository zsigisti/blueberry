# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=xcb-util
pkgver=0.4.1
pkgrel=1
pkgdesc='XCB utility library: xcb-util'
arch=('x86_64')
url='https://xcb.freedesktop.org/'
license=('MIT')
depends=('libxcb')
provides=('libxcb-util.so')
makedepends=('xcb-proto' 'xorgproto' 'xorg-util-macros' 'libxcb' 'pkgconf' 'gperf')
source=("https://xorg.freedesktop.org/archive/individual/lib/xcb-util-0.4.1.tar.xz")
sha256sums=('5abe3bbbd8e54f0fa3ec945291b7e8fa8cfd3cccc43718f8758430f94126e512')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
