# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=knotifications
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: desktop notifications'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'kconfig' 'kcoreaddons' 'kguiaddons' 'kwindowsystem' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/knotifications-$pkgver.tar.xz")
sha256sums=('eeb067fab001dd24735ad56e8ec4808fca76e5ecdf003cf614246c9abe1c3e19')

build() {
  cmake -S "knotifications-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
