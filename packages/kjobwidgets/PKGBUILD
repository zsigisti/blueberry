# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kjobwidgets
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: widgets for tracking KJob progress'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'kcoreaddons' 'kwidgetsaddons' 'kwindowsystem' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kjobwidgets-$pkgver.tar.xz")
sha256sums=('3149cd07d82204c6bfa8d86c590bf0c92905e1b5b075c7b543540916a61d7a03')

build() {
  cmake -S "kjobwidgets-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
