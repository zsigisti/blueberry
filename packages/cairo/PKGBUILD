# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=cairo
pkgver=1.18.4
pkgrel=1
pkgdesc='2D graphics library with hardware acceleration'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('fontconfig' 'freetype2' 'glib2' 'libpng' 'pixman' 'libx11' 'libxcb' 'libxext' 'libxrender' 'lzo' 'zlib' )
makedepends=('meson' 'ninja' 'pkgconf' )
options=('!lto')
source=("cairo-1.18.4.tar.xz::https://cairographics.org/releases/cairo-1.18.4.tar.xz")
sha256sums=('445ed8208a6e4823de1226a74ca319d3600e83f6369f99b14265006599c32ccb')

build() {
  arch-meson() { meson setup "$@"; }
  meson setup cairo-1.18.4 build --prefix=/usr --buildtype=release -Dwerror=false -Dtests=disabled -Dxlib=enabled -Dxcb=enabled
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
