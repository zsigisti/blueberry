# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=rsync
pkgver=3.4.1
pkgrel=2
pkgdesc='Fast incremental file transfer and synchronisation tool'
arch=('x86_64')
url='https://rsync.samba.org/'
license=('GPL-3.0-or-later')
# acl (libacl): rsync -A/--acls preserves POSIX ACLs.
depends=('glibc' 'popt' 'zlib' 'zstd' 'openssl' 'acl')
makedepends=('pkgconf')
source=("https://download.samba.org/pub/rsync/src/rsync-$pkgver.tar.gz")
sha256sums=('2924bcb3a1ed8b551fc101f740b9f0fe0a202b115027647cf69850d65fd88c52')

build() {
  cd "$pkgname-$pkgver"
  # Link the system popt/zlib/zstd/openssl (the bundled copies would bloat the
  # closure); drop lz4/xxhash to keep the dependency set to what Blueberry ships.
  ./configure \
    --prefix=/usr \
    --disable-lz4 \
    --disable-xxhash \
    --with-included-popt=no \
    --with-included-zlib=no
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
