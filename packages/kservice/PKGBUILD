# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kservice
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: service/plugin discovery (.desktop)'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'kconfig' 'kcoreaddons' 'kcrash' 'kdbusaddons' 'ki18n' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'bison' 'flex' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kservice-$pkgver.tar.xz")
sha256sums=('3736c6d6cd389efc89adbcb64fe7ba25ffc9d62eb8eaf6393f42bb85f655a8c7')

build() {
  cmake -S "kservice-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
