# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=lzo
pkgver=2.10
pkgrel=1
pkgdesc='Portable lossless data compression library'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('glibc' )
makedepends=()
options=('!lto')
source=("lzo-2.10.tar.gz::https://www.oberhumer.com/opensource/lzo/download/lzo-2.10.tar.gz")
sha256sums=('c0f892943208266f9b6543b3ae308fab6284c5c90e627931446fb49b4221a072')

build() {
  cd "lzo-2.10"
  ./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var --enable-shared
  make
}

package() {
  cd "lzo-2.10"; make DESTDIR="$pkgdir" install
}
