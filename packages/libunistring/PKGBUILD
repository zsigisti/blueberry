# GNU libunistring — Unicode string manipulation. Runtime dep of libidn2.
pkgname=libunistring
pkgver=1.2
pkgrel=1
pkgdesc='Library for manipulating Unicode strings and C strings'
arch=('x86_64')
url='https://www.gnu.org/software/libunistring/'
license=('LGPL-3.0-or-later')
depends=('glibc')
source=("https://ftp.gnu.org/gnu/libunistring/libunistring-$pkgver.tar.gz")
sha256sums=('fd6d5662fa706487c48349a758b57bc149ce94ec6c30624ec9fdc473ceabbc8e')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING.LIB "$pkgdir/usr/share/licenses/$pkgname/COPYING.LIB"
}
