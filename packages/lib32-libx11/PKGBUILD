# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=lib32-libx11
pkgver=1.8.10
pkgrel=1
pkgdesc='Core X11 client library (32-bit)'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('custom')
depends=('lib32-glibc' 'lib32-libxcb' )
makedepends=('lib32-glibc' 'lib32-gcc-libs' 'xorgproto' 'xorg-util-macros' 'pkgconf' 'lib32-libxcb' 'libx11' 'xtrans' )
options=('!lto' '!strip')
source=("libX11-1.8.10.tar.xz::https://www.x.org/releases/individual/lib/libX11-1.8.10.tar.xz")
sha256sums=('2b3b3dad9347db41dca56beb7db5878f283bde1142f04d9f8e478af435dfdc53')

build() {
  export CC="gcc -m32" CXX="g++ -m32" PKG_CONFIG_PATH=/usr/lib32/pkgconfig
  cd "libX11-1.8.10"
  ./configure --prefix=/usr --libdir=/usr/lib32 --host=i686-pc-linux-gnu --disable-static 
  make
}

package() {
  cd "libX11-1.8.10"; make DESTDIR="$pkgdir" install
  rm -rf "$pkgdir/usr/include" "$pkgdir/usr/share" "$pkgdir/usr/bin"
}
