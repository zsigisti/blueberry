# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=krb5
pkgver=1.22.2
pkgrel=1
pkgdesc='MIT Kerberos 5 (libgssapi_krb5)'
arch=('x86_64')
url='https://blueberry.linux/'
license=('custom')
depends=('glibc' 'e2fsprogs' 'libldap' 'keyutils' )
makedepends=('bison' 'perl' )
options=('!lto')
source=("krb5-1.22.2.tar.gz::https://kerberos.org/dist/krb5/1.22/krb5-1.22.2.tar.gz")
sha256sums=('3243ffbc8ea4d4ac22ddc7dd2a1dc54c57874c40648b60ff97009763554eaf13')
build() { cd "krb5-1.22.2/src"; ./configure --prefix=/usr --libdir=/usr/lib --without-system-verto --disable-rpath; make; }
package() { cd "krb5-1.22.2/src"; make DESTDIR="$pkgdir" install; }
