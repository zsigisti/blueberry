# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=pixman
pkgver=0.44.0
pkgrel=1
pkgdesc='Low-level pixel manipulation library'
arch=('x86_64')
url='https://pixman.org/'
license=('custom')
depends=('glibc')
provides=('libpixman-1.so')
makedepends=('meson' 'ninja')
source=("https://www.cairographics.org/releases/pixman-$pkgver.tar.gz")
sha256sums=('89a4c1e1e45e0b23dffe708202cb2eaffde0fe3727d7692b2e1739fec78a7dac')

build() {
  arch-meson "$pkgname-$pkgver" build \
    -D libpng=disabled -D gtk=disabled -D tests=disabled -D demos=disabled \
    -D loongson-mmi=disabled -D vmx=disabled -D arm-simd=disabled \
    -D neon=disabled -D a64-neon=disabled -D mips-dspr2=disabled -D rvv=disabled
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/COPYING" "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
