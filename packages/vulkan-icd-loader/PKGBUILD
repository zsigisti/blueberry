# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=vulkan-icd-loader
pkgver=1.4.304
pkgrel=1
pkgdesc='Vulkan Installable Client Driver (ICD) loader'
arch=('x86_64')
url='https://github.com/KhronosGroup/Vulkan-Loader'
license=('Apache-2.0')
depends=('glibc')
optdepends=('vulkan-headers: development')
provides=('libvulkan.so')
makedepends=('cmake' 'ninja' 'vulkan-headers' 'wayland' 'libx11' 'libxrandr' 'pkgconf')
source=("$pkgname-$pkgver.tar.gz::https://github.com/KhronosGroup/Vulkan-Loader/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('368d8281604a3f4dee038bfcc55c44e305031ec67f6e3fdd50cdeb83586c99f9')

build() {
  cmake -S "Vulkan-Loader-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D CMAKE_INSTALL_LIBDIR=lib \
    -D CMAKE_INSTALL_SYSCONFDIR=/etc \
    -D VULKAN_HEADERS_INSTALL_DIR=/usr \
    -D BUILD_WSI_WAYLAND_SUPPORT=ON \
    -D BUILD_WSI_XCB_SUPPORT=ON \
    -D BUILD_WSI_XLIB_SUPPORT=ON
  ninja -C build
}

package() {
  DESTDIR="$pkgdir" ninja -C build install
  install -Dm644 "Vulkan-Loader-$pkgver/LICENSE.txt" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE.txt"
}
