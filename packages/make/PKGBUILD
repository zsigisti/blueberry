# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=make
pkgver=4.4.1
pkgrel=2
pkgdesc='GNU make utility to maintain groups of programs'
arch=('x86_64')
url='https://www.gnu.org/software/make/'
license=('GPL-3.0-or-later')
depends=('glibc')
source=("https://mirrors.kernel.org/gnu/make/make-$pkgver.tar.gz")
sha256sums=('dd16fb1d67bfab79a72f5e8390735c49e3e8e70b4945a15ab1f81ddb78658fb3')
build() {
  cd "$pkgname-$pkgver"
  # --without-guile: don't auto-link GNU Guile for the (exotic) $(guile ...)
  # make extension — it would pull guile + libgc + libltdl, none of which
  # Blueberry packages. make is fully functional without it.
  ./configure --prefix=/usr --without-guile
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
