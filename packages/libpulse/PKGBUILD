# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libpulse
pkgver=17.0
pkgrel=1
pkgdesc='PulseAudio client library (Qt6Multimedia, plasma-pa)'
arch=('x86_64')
url='https://www.freedesktop.org/wiki/Software/PulseAudio/'
license=('LGPL-2.1-or-later')
depends=('glibc' 'dbus' 'libsndfile' 'glib2' 'libcap' 'systemd-libs')
makedepends=('meson' 'ninja' 'pkgconf')
options=('!lto')
source=("https://freedesktop.org/software/pulseaudio/releases/pulseaudio-${pkgver}.tar.xz")
sha256sums=('053794d6671a3e397d849e478a80b82a63cb9d8ca296bd35b73317bb5ceb87b5')
build() {
  # We only need the client library (libpulse.so.0). Disable the daemon and the
  # doc/test machinery; auto features disable themselves when their optional
  # deps are absent in the build container.
  meson setup "pulseaudio-${pkgver}" build \
    --prefix=/usr --libdir=/usr/lib --buildtype=release \
    -Ddaemon=false -Ddoxygen=false -Dman=false -Dtests=false
  ninja -C build
}
package() {
  DESTDIR="$pkgdir" ninja -C build install
  # Trim everything but the client library, headers and pkgconfig. NOTE: keep
  # /usr/lib/pulseaudio/libpulsecommon-*.so — libpulse.so.0 links it directly.
  rm -rf "$pkgdir/usr/bin" "$pkgdir/etc" "$pkgdir/usr/share" \
         "$pkgdir/usr/lib/systemd" "$pkgdir/usr/lib/cmake" 2>/dev/null || true
}
