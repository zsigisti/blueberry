# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libjpeg-turbo
pkgver=3.0.4
pkgrel=1
pkgdesc='JPEG image codec with accelerated baseline compression and decompression'
arch=('x86_64')
url='https://libjpeg-turbo.org/'
license=('custom')
depends=('glibc')
provides=('libjpeg.so' 'libturbojpeg.so')
makedepends=('cmake' 'ninja' 'nasm')
source=("https://github.com/libjpeg-turbo/libjpeg-turbo/releases/download/$pkgver/libjpeg-turbo-$pkgver.tar.gz")
sha256sums=('99130559e7d62e8d695f2c0eaeef912c5828d5b84a0537dcb24c9678c9d5b76b')

build() {
  cmake -S "$pkgname-$pkgver" -B build -G Ninja \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D CMAKE_INSTALL_LIBDIR=/usr/lib \
    -D CMAKE_BUILD_TYPE=Release \
    -D ENABLE_STATIC=OFF \
    -D WITH_JPEG8=ON
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "$pkgname-$pkgver/LICENSE.md" "$pkgdir/usr/share/licenses/$pkgname/LICENSE.md"
}
