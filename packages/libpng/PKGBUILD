# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libpng
pkgver=1.6.44
pkgrel=1
pkgdesc='PNG reference library'
arch=('x86_64')
url='http://www.libpng.org/pub/png/libpng.html'
license=('custom')
depends=('zlib' 'glibc')
provides=('libpng16.so')
source=("https://downloads.sourceforge.net/libpng/libpng-$pkgver.tar.xz")
sha256sums=('60c4da1d5b7f0aa8d158da48e8f8afa9773c1c8baa5d21974df61f1886b8ce8e')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
