# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=tcpdump
pkgver=4.99.5
pkgrel=2
pkgdesc='Command-line network packet analyzer'
arch=('x86_64')
url='https://www.tcpdump.org/'
license=('BSD-3-Clause')
# libcap-ng: tcpdump drops privileges after opening the capture device.
depends=('glibc' 'libpcap' 'openssl' 'libcap-ng')
source=("https://www.tcpdump.org/release/tcpdump-$pkgver.tar.xz")
sha256sums=('d76395ab82d659d526291b013eee200201380930793531515abfc6e77b4f2ee5')
build() { cd "$pkgname-$pkgver"; ./configure --prefix=/usr --with-crypto; make; }
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
