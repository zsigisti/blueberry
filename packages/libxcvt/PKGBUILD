# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libxcvt
pkgver=0.1.3
pkgrel=1
pkgdesc='VESA CVT timing library (KWin)'
arch=('x86_64')
url='https://blueberry.linux/'
license=('custom')
depends=('glibc' )
makedepends=('meson' 'ninja' )
options=('!lto')
source=("libxcvt-0.1.3.tar.xz::https://www.x.org/releases/individual/lib/libxcvt-0.1.3.tar.xz")
sha256sums=('a929998a8767de7dfa36d6da4751cdbeef34ed630714f2f4a767b351f2442e01')
build() { arch-meson() { meson setup "$@"; }; meson setup "libxcvt-0.1.3" build --prefix=/usr --buildtype=release -Dwerror=false ; meson compile -C build; }
package() { meson install -C build --destdir "$pkgdir"; }
