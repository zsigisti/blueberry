# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libxml2
# 2.15.x bumps the soname to libxml2.so.16, which is what the Arch-toolchain-built
# desktop stack (LLVM 22, Mesa, Qt6, libqalculate) links against.
pkgver=2.15.3
pkgrel=1
pkgdesc='XML C parser and toolkit'
arch=('x86_64')
url='https://gitlab.gnome.org/GNOME/libxml2/-/wikis/home'
license=('MIT')
depends=('zlib' 'glibc')
provides=('libxml2.so')
makedepends=('python')
options=('!emptydirs')
source=("https://download.gnome.org/sources/libxml2/${pkgver%.*}/libxml2-$pkgver.tar.xz")
sha256sums=('78262a6e7ac170d6528ebfe2efccdf220191a5af6a6cd61ea4a9a9a5042c7a07')

build() {
  cd "$pkgname-$pkgver"
  # --without-lzma: liblzma is host-provided in the base image, not a bpm
  # package, so don't create a runtime dependency the solver can't satisfy.
  ./configure --prefix=/usr \
    --with-threads --with-history --with-icu=no --without-python \
    --without-lzma --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 Copyright "$pkgdir/usr/share/licenses/$pkgname/Copyright"
}
