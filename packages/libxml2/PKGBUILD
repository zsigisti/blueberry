# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libxml2
pkgver=2.13.5
pkgrel=1
pkgdesc='XML C parser and toolkit'
arch=('x86_64')
url='https://gitlab.gnome.org/GNOME/libxml2/-/wikis/home'
license=('MIT')
depends=('zlib' 'glibc')
provides=('libxml2.so')
makedepends=('python')
options=('!emptydirs')
source=("https://download.gnome.org/sources/libxml2/${pkgver%.*}/libxml2-$pkgver.tar.xz")
sha256sums=('74fc163217a3964257d3be39af943e08861263c4231f9ef5b496b6f6d4c7b2b6')

build() {
  cd "$pkgname-$pkgver"
  # --without-lzma: liblzma is host-provided in the base image, not a bpm
  # package, so don't create a runtime dependency the solver can't satisfy.
  ./configure --prefix=/usr \
    --with-threads --with-history --with-icu=no --without-python \
    --without-lzma --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 Copyright "$pkgdir/usr/share/licenses/$pkgname/Copyright"
}
