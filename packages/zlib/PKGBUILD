# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=zlib
pkgver=1.3.1
pkgrel=1
pkgdesc='Compression library implementing the deflate compression method'
arch=('x86_64')
url='https://zlib.net/'
license=('Zlib')
depends=('glibc')
source=("https://github.com/madler/zlib/releases/download/v$pkgver/zlib-$pkgver.tar.gz")
sha256sums=('9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr
  make
}

check() {
  cd "$pkgname-$pkgver"
  make test
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
