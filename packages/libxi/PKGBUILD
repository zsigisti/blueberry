# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libxi
pkgver=1.8.2
pkgrel=1
pkgdesc='X11 Input extension library'
arch=('x86_64')
url='https://gitlab.freedesktop.org/xorg/lib'
license=('MIT')
depends=('libxext' 'libxfixes')
provides=('libXi.so')
makedepends=('xorg-util-macros' 'xorgproto' 'pkgconf')
source=("https://www.x.org/releases/individual/lib/libXi-1.8.2.tar.xz")
sha256sums=('d0e0555e53d6e2114eabfa44226ba162d2708501a25e18d99cfb35c094c6c104')

build() {
  cd "libXi-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --disable-static
  make
}

package() {
  cd "libXi-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
