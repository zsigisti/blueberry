# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libxkbcommon
pkgver=1.7.0
pkgrel=2
pkgdesc='Keyboard handling library using XKB data (Wayland + X11)'
arch=('x86_64')
url='https://xkbcommon.org/'
license=('MIT')
# X11 enabled (libxkbcommon-x11) now that libxcb is packaged — Qt's xcb platform
# needs it. xkeyboard-config supplies the runtime keymap data.
depends=('xkeyboard-config' 'libxml2' 'libxcb' 'glibc')
provides=('libxkbcommon.so' 'libxkbcommon-x11.so' 'libxkbregistry.so')
makedepends=('meson' 'ninja' 'bison' 'wayland' 'wayland-protocols' 'libxcb')
source=("https://xkbcommon.org/download/libxkbcommon-$pkgver.tar.xz")
sha256sums=('65782f0a10a4b455af9c6baab7040e2f537520caa2ec2092805cdfd36863b247')

build() {
  arch-meson "$pkgname-$pkgver" build \
    -D enable-docs=false -D enable-x11=true -D enable-wayland=true \
    -D xkb-config-root=/usr/share/X11/xkb
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
