# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=wireguard-tools
pkgver=1.0.20210914
pkgrel=1
pkgdesc='Userspace tools (wg, wg-quick) for the in-kernel WireGuard VPN'
arch=('x86_64')
url='https://www.wireguard.com/'
license=('GPL-2.0-only')
depends=('glibc' 'libmnl' 'bash')
source=("https://git.zx2c4.com/wireguard-tools/snapshot/wireguard-tools-$pkgver.tar.xz")
sha256sums=('942ed32d1d6631932c82ff86c91ae8428d4c90bfec231a14ebdf6c29f068e60b')

build() {
  make -C "$pkgname-$pkgver/src"
}

package() {
  make -C "$pkgname-$pkgver/src" \
    WITH_BASHCOMPLETION=yes \
    WITH_WGQUICK=yes \
    WITH_SYSTEMDUNITS=no \
    DESTDIR="$pkgdir" \
    PREFIX=/usr \
    install
  install -Dm644 "$pkgname-$pkgver/COPYING" \
    "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
