# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kiconthemes
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: icon theme loading and management'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'karchive' 'kconfig' 'kconfigwidgets' 'kcoreaddons' 'ki18n' 'kwidgetsaddons' 'qt6-svg' 'breeze-icons' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-svg' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kiconthemes-$pkgver.tar.xz")
sha256sums=('6fe86f0c0ff41044f44d1f37f9ae001b8d2c1a5a8bc06c41c43ed574138af5be')

build() {
  cmake -S "kiconthemes-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
