# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libevent
pkgver=2.1.12
pkgrel=1
pkgdesc='Event notification library'
arch=('x86_64')
url='https://libevent.org/'
license=('BSD')
depends=('glibc')
_srcdir="libevent-$pkgver-stable"
provides=('libevent-2.1.so' 'libevent_core-2.1.so' 'libevent_extra-2.1.so' 'libevent_pthreads-2.1.so')
source=("https://github.com/libevent/libevent/releases/download/release-$pkgver-stable/libevent-$pkgver-stable.tar.gz")
sha256sums=('92e6de1be9ec176428fd2367677e61ceffc2ee1cb119035037a27d346b0403bb')
build() {
  cd "$_srcdir"
  ./configure --prefix=/usr --disable-static --disable-openssl
  make
}
package() {
  cd "$_srcdir"
  make DESTDIR="$pkgdir" install
}
