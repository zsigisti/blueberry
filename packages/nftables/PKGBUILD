# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=nftables
pkgver=1.1.1
pkgrel=1
pkgdesc='Netfilter nftables userspace command-line tool'
arch=('x86_64')
url='https://www.netfilter.org/projects/nftables/'
license=('GPL-2.0-only')
depends=('glibc' 'libmnl' 'libnftnl' 'gmp')
makedepends=('pkgconf')
provides=('libnftables.so')
source=("https://www.netfilter.org/projects/nftables/files/nftables-$pkgver.tar.xz")
sha256sums=('6358830f3a64f31e39b0ad421d7dadcd240b72343ded48d8ef13b8faf204865a')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sbindir=/usr/bin --sysconfdir=/etc \
    --disable-man-doc --without-cli --with-json=no --disable-python
  make
}
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
