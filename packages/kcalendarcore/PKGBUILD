# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kcalendarcore
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: iCalendar (RFC 2445) library'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'libical' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'libical' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kcalendarcore-$pkgver.tar.xz")
sha256sums=('4228869722c5bb5325b7c5b10555e6b747bde0e36cbd43519d8681fe3b383173')

build() {
  cmake -S "kcalendarcore-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
