# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=lib32-libffi
pkgver=3.4.6
pkgrel=1
pkgdesc='Foreign Function Interface library (32-bit)'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('custom')
depends=('lib32-glibc' )
makedepends=('lib32-glibc' 'lib32-gcc-libs' 'pkgconf' )
options=('!lto' '!strip')
source=("libffi-3.4.6.tar.gz::https://github.com/libffi/libffi/releases/download/v3.4.6/libffi-3.4.6.tar.gz")
sha256sums=('b0dea9df23c863a7a50e825440f3ebffabd65df1497108e5d437747843895a4e')

build() {
  export CC="gcc -m32" CXX="g++ -m32" PKG_CONFIG_PATH=/usr/lib32/pkgconfig
  cd "libffi-3.4.6"
  ./configure --prefix=/usr --libdir=/usr/lib32 --host=i686-pc-linux-gnu --disable-static 
  make
}

package() {
  cd "libffi-3.4.6"; make DESTDIR="$pkgdir" install
  rm -rf "$pkgdir/usr/include" "$pkgdir/usr/share" "$pkgdir/usr/bin"
}
