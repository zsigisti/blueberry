# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=file
pkgver=5.46
pkgrel=2
pkgdesc='File type identification utility and libmagic'
arch=('x86_64')
url='https://www.darwinsys.com/file/'
license=('custom')
# libseccomp: file/libmagic sandbox the magic engine via seccomp; the binary
# (and any consumer of libmagic, e.g. nano) links libseccomp.so.2 at runtime.
depends=('glibc' 'zlib' 'bzip2' 'xz' 'libseccomp')
provides=('libmagic.so')
source=("https://astron.com/pub/file/file-$pkgver.tar.gz")
sha256sums=('c9cc77c7c560c543135edc555af609d5619dbef011997e988ce40a3d75d86088')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --enable-fsect-man5
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
