# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libtiff
pkgver=4.7.1
pkgrel=1
pkgdesc='TIFF image format library'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('zlib' 'libjpeg-turbo' 'xz' 'zstd' )
makedepends=('cmake' 'ninja' )
options=('!lto')
source=("tiff-4.7.1.tar.xz::https://download.osgeo.org/libtiff/tiff-4.7.1.tar.xz")
sha256sums=('b92017489bdc1db3a4c97191aa4b75366673cb746de0dce5d7a749d5954681ba')

build() {
  cmake -S tiff-4.7.1 -B build -G Ninja -D CMAKE_BUILD_TYPE=Release -D CMAKE_INSTALL_PREFIX=/usr 
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
