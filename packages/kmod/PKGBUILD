# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
#
# kmod — kernel module tools + libkmod. The Blueberry kernel is modless, so the
# tools are mostly inert, but pciutils links libkmod.so.2 to map devices to
# driver names.
pkgname=kmod
pkgver=33
pkgrel=1
pkgdesc='Library and tools for handling Linux kernel modules (libkmod)'
arch=('x86_64')
url='https://git.kernel.org/pub/scm/utils/kernel/kmod/kmod.git'
license=('LGPL-2.1-or-later')
depends=('glibc' 'zlib' 'xz' 'zstd')
makedepends=('pkgconf')
source=("https://www.kernel.org/pub/linux/utils/kernel/kmod/kmod-$pkgver.tar.xz")
sha256sums=('dc768b3155172091f56dc69430b5481f2d76ecd9ccb54ead8c2540dbcf5ea9bc')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --disable-static \
    --with-zstd --with-xz --with-zlib --disable-manpages
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
