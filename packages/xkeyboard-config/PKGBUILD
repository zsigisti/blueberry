# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=xkeyboard-config
pkgver=2.43
pkgrel=1
pkgdesc='X keyboard configuration files (keymap data for libxkbcommon)'
arch=('any')
url='https://www.freedesktop.org/wiki/Software/XKeyboardConfig/'
license=('MIT')
depends=()
makedepends=('meson' 'ninja' 'python' 'xorg-xkbcomp' 'gettext')
source=("https://www.x.org/releases/individual/data/xkeyboard-config/xkeyboard-config-$pkgver.tar.xz")
sha256sums=('c810f362c82a834ee89da81e34cd1452c99789339f46f6037f4b9e227dd06c01')

build() {
  arch-meson "$pkgname-$pkgver" build -D compat-rules=true
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/COPYING" "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
