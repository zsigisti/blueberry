# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=dosfstools
pkgver=4.2
pkgrel=1
pkgdesc='DOS filesystem utilities (mkfs.fat, fsck.fat)'
arch=('x86_64')
url='https://github.com/dosfstools/dosfstools'
license=('GPL-3.0-or-later')
depends=('glibc')
source=("https://github.com/dosfstools/dosfstools/releases/download/v$pkgver/dosfstools-$pkgver.tar.gz")
sha256sums=('64926eebf90092dca21b14259a5301b7b98e7b1943e8a201c7d726084809b527')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --enable-compat-symlinks --mandir=/usr/share/man
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
