# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=patch
pkgver=2.7.6
pkgrel=2
pkgdesc='Apply a diff file to an original'
arch=('x86_64')
url='https://savannah.gnu.org/projects/patch/'
license=('GPL-3.0-or-later')
# attr (libattr): patch preserves extended attributes on patched files.
depends=('glibc' 'attr')
source=("https://ftp.gnu.org/gnu/patch/patch-$pkgver.tar.xz")
sha256sums=('ac610bda97abe0d9f6b7c963255a11dcb196c25e337c61f94e4778d632f1d8fd')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
