# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=networkmanager-qt
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: Qt wrapper for NetworkManager'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'networkmanager' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'networkmanager' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/networkmanager-qt-$pkgver.tar.xz")
sha256sums=('a8193895b420d576fac228388ba8fd1b24d6f229c43b7963e2ed581ef82cad9a')

build() {
  cmake -S "networkmanager-qt-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
