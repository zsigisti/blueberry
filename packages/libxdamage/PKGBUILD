# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libxdamage
pkgver=1.1.7
pkgrel=1
pkgdesc='X11 Damage extension library'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('libx11' 'libxfixes' )
makedepends=('pkgconf' 'xorgproto' )
options=('!lto')
source=("libXdamage-1.1.7.tar.xz::https://www.x.org/releases/individual/lib/libXdamage-1.1.7.tar.xz")
sha256sums=('127067f521d3ee467b97bcb145aeba1078e2454d448e8748eb984d5b397bde24')

build() {
  cd "libXdamage-1.1.7"
  ./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var 
  make
}

package() {
  cd "libXdamage-1.1.7"; make DESTDIR="$pkgdir" install
}
