# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=git
pkgver=2.49.0
pkgrel=2
pkgdesc='The fast distributed version control system'
arch=('x86_64')
url='https://git-scm.com/'
license=('GPL-2.0-only')
# curl for https remotes, openssl for crypto, expat for http-push, zlib for
# objects, pcre2 for `git grep -P` (USE_LIBPCRE is enabled — ifdef-defined).
depends=('curl' 'openssl' 'expat' 'zlib' 'pcre2')
source=("https://mirrors.kernel.org/pub/software/scm/git/git-$pkgver.tar.xz")
sha256sums=('618190cf590b7e9f6c11f91f23b1d267cd98c3ab33b850416d8758f8b5a85628')
_make() {
  make prefix=/usr \
    CURLDIR=/usr \
    NO_GETTEXT=1 \
    NO_TCLTK=1 \
    NO_PERL=1 \
    NO_PYTHON=1 \
    USE_LIBPCRE=0 \
    INSTALL_SYMLINKS=1 \
    "$@"
}
build() {
  cd "$pkgname-$pkgver"
  _make all
}
package() {
  cd "$pkgname-$pkgver"
  _make DESTDIR="$pkgdir" install
}
