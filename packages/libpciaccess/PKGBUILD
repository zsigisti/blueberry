# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libpciaccess
pkgver=0.18.1
pkgrel=1
pkgdesc='X11 library for PCI device access'
arch=('x86_64')
url='https://gitlab.freedesktop.org/xorg/lib/libpciaccess'
license=('custom')
depends=('glibc')
provides=('libpciaccess.so')
makedepends=('meson' 'ninja' 'xorg-util-macros')
source=("https://www.x.org/releases/individual/lib/libpciaccess-$pkgver.tar.xz")
sha256sums=('4af43444b38adb5545d0ed1c2ce46d9608cc47b31c2387fc5181656765a6fa76')

build() {
  arch-meson "$pkgname-$pkgver" build
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/COPYING" "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
