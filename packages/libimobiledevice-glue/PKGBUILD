license=('LGPL-2.1-or-later')
depends=('glibc' 'libplist')
makedepends=('pkgconf' 'libplist')
options=('!lto')
source=("https://github.com/libimobiledevice/libimobiledevice-glue/releases/download/${pkgver}/libimobiledevice-glue-${pkgver}.tar.bz2")
sha256sums=('6e2849f221e6ab970566a115d42f3c20f8848e4d40c2ed61ac20dc85f40fa54f')
build() { cd "libimobiledevice-glue-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib; make; }
package() { cd "libimobiledevice-glue-${pkgver}"; make DESTDIR="$pkgdir" install; }
