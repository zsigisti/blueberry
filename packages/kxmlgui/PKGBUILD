# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kxmlgui
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: framework for building user interfaces (menus/toolbars)'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'attica' 'kconfig' 'kconfigwidgets' 'kcoreaddons' 'kglobalaccel' 'kguiaddons' 'ki18n' 'kiconthemes' 'kitemviews' 'kwidgetsaddons' 'kwindowsystem' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kxmlgui-$pkgver.tar.xz")
sha256sums=('36d5c9cf8a851a63c1064d6a9987e961c0860ebd1396cda99119e570847df721')

build() {
  cmake -S "kxmlgui-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
