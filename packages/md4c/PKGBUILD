# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=md4c
pkgver=0.5.2
pkgrel=1
pkgdesc='C Markdown parser (Qt6 dep: libmd4c-html)'
arch=('x86_64')
url='https://github.com/mity/md4c'
license=('MIT')
depends=('glibc')
provides=('libmd4c.so' 'libmd4c-html.so')
makedepends=('cmake' 'ninja')
source=("$pkgname-$pkgver.tar.gz::https://github.com/mity/md4c/archive/refs/tags/release-$pkgver.tar.gz")
sha256sums=('55d0111d48fb11883aaee91465e642b8b640775a4d6993c2d0e7a8092758ef21')

build() {
  cmake -S "$pkgname-release-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D CMAKE_INSTALL_LIBDIR=lib \
    -D BUILD_SHARED_LIBS=ON
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "$pkgname-release-$pkgver/LICENSE.md" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE.md"
}
