# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=prison
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: barcode/QR generation library'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'qrencode' 'libdmtx' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qrencode' 'libdmtx' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/prison-$pkgver.tar.xz")
sha256sums=('760903e9ae401f8bcdb9efc9ad6548982642e7411a223c8ceb41e5491a6b1135')

build() {
  cmake -S "prison-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
