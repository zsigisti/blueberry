# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=pcre2
pkgver=10.44
pkgrel=1
pkgdesc='Perl Compatible Regular Expressions v2'
arch=('x86_64')
url='https://github.com/PCRE2Project/pcre2'
license=('BSD-3-Clause')
depends=('glibc' 'zlib' 'bzip2')
provides=('libpcre2-8.so' 'libpcre2-16.so' 'libpcre2-32.so')
source=("https://github.com/PCRE2Project/pcre2/releases/download/pcre2-$pkgver/pcre2-$pkgver.tar.bz2")
sha256sums=('d34f02e113cf7193a1ebf2770d3ac527088d485d4e047ed10e5d217c6ef5de96')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --enable-jit --enable-pcre2-16 --enable-pcre2-32 \
    --enable-pcre2grep-libz --enable-pcre2grep-libbz2 --disable-static
  make
}
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
