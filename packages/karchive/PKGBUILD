# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=karchive
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: reading/writing archives (tar, zip, 7z, ar)'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'bzip2' 'zlib' 'xz' 'zstd' )
makedepends=('extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/karchive-$pkgver.tar.xz")
sha256sums=('434edf78df8f4c9f25000d107ad1520d7ac14db580a202047bf19cbf77376522')

build() {
  cmake -S "karchive-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
