# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=graphene
pkgver=1.10.8
pkgrel=1
pkgdesc='Thin type library for graphics (SIMD vectors/matrices)'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('glib2' )
makedepends=('meson' 'ninja' 'pkgconf' 'python' )
options=('!lto')
source=("graphene-1.10.8.tar.xz::https://download.gnome.org/sources/graphene/1.10/graphene-1.10.8.tar.xz")
sha256sums=('a37bb0e78a419dcbeaa9c7027bcff52f5ec2367c25ec859da31dfde2928f279a')

build() {
  arch-meson() { meson setup "$@"; }
  meson setup graphene-1.10.8 build --prefix=/usr --buildtype=release -Dwerror=false -Dtests=false -Dintrospection=disabled -Dgtk_doc=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
