# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libffi
pkgver=3.4.6
pkgrel=1
pkgdesc='Portable foreign-function interface library (libffi)'
arch=('x86_64')
url='https://sourceware.org/libffi/'
license=('MIT')
depends=('glibc')
provides=('libffi.so')
source=("https://github.com/libffi/libffi/releases/download/v$pkgver/libffi-$pkgver.tar.gz")
sha256sums=('b0dea9df23c863a7a50e825440f3ebffabd65df1497108e5d437747843895a4e')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --disable-exec-static-tramp
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
