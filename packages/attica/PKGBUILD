# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=attica
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: Open Collaboration Services API client'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/attica-$pkgver.tar.xz")
sha256sums=('8f3d3d61ec8a7456db8a75caa801a2e5f5e046728bd240a003e71b8813093ae4')

build() {
  cmake -S "attica-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
