# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# libseccomp — high-level interface to the kernel's seccomp syscall filtering.
# Needed by `file` (its libmagic sandbox) and useful to container/runtime tools.
pkgname=libseccomp
pkgver=2.5.5
pkgrel=1
pkgdesc='High level interface to the Linux seccomp filter'
arch=('x86_64')
url='https://github.com/seccomp/libseccomp'
license=('LGPL-2.1-only')
depends=('glibc')
makedepends=('gperf')
source=("https://github.com/seccomp/libseccomp/releases/download/v$pkgver/libseccomp-$pkgver.tar.gz")
sha256sums=('248a2c8a4d9b9858aa6baf52712c34afefcf9c9e94b76dce02c1c9aa25fb3375')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
