# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kwallet
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: secure storage of passwords'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'kcodecs' 'kconfig' 'kconfigwidgets' 'kcoreaddons' 'kdbusaddons' 'ki18n' 'kwidgetsaddons' 'kwindowsystem' 'libgcrypt' 'gpgme' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'libgcrypt' 'gpgme' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kwallet-$pkgver.tar.xz")
sha256sums=('daa03acc40eec873bb450fd8116ae7c788b86a7ceebc9fa555b4a166feeb7983')

build() {
  cmake -S "kwallet-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
