# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=sudo
pkgver=1.9.16p2
pkgrel=2
pkgdesc='Give certain users the ability to run some commands as root'
arch=('x86_64')
url='https://www.sudo.ws/sudo/'
license=('custom')
# openssl (libcrypto/libssl): message digest verification of sudoers commands.
depends=('glibc' 'openssl')
source=("https://www.sudo.ws/dist/sudo-$pkgver.tar.gz")
sha256sums=('976aa56d3e3b2a75593307864288addb748c9c136e25d95a9cc699aafa77239c')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sbindir=/usr/bin --libexecdir=/usr/lib \
    --with-rundir=/run/sudo --with-vardir=/var/lib/sudo \
    --without-pam --with-env-editor --with-secure-path
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  # ship a minimal sudoers granting wheel group full access
  install -dm755 "$pkgdir/etc"
  printf '%%wheel ALL=(ALL:ALL) ALL\nroot ALL=(ALL:ALL) ALL\n' > "$pkgdir/etc/sudoers"
  chmod 440 "$pkgdir/etc/sudoers"
}
