# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=yaml-cpp
pkgver=0.9.0
pkgrel=1
pkgdesc='YAML parser for C++ (Calamares)'
arch=('x86_64')
url='https://blueberry.linux/'
license=('custom')
depends=('gcc-libs' 'glibc' )
makedepends=('cmake' 'ninja' )
options=('!lto')
# Tag is "yaml-cpp-0.9.0"; the GitHub archive extracts to yaml-cpp-yaml-cpp-0.9.0/.
# 0.9.0 is the version Calamares links against (libyaml-cpp.so.0.9).
source=("yaml-cpp-0.9.0.tar.gz::https://github.com/jbeder/yaml-cpp/archive/refs/tags/yaml-cpp-0.9.0.tar.gz")
sha256sums=('25cb043240f828a8c51beb830569634bc7ac603978e0f69d6b63558dadefd49a')
_srcdir="yaml-cpp-yaml-cpp-0.9.0"
build() { cmake -S "$_srcdir" -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib -DYAML_BUILD_SHARED_LIBS=ON -DYAML_CPP_BUILD_TESTS=OFF; cmake --build build; }
package() { DESTDIR="$pkgdir" cmake --install build; }
