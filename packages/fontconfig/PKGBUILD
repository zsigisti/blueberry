# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=fontconfig
pkgver=2.15.0
pkgrel=1
pkgdesc='Library for configuring and customizing font access'
arch=('x86_64')
url='https://www.freedesktop.org/wiki/Software/fontconfig/'
license=('custom')
depends=('expat' 'freetype2' 'glibc')
provides=('libfontconfig.so')
makedepends=('meson' 'ninja' 'gperf' 'python')
source=("https://www.freedesktop.org/software/fontconfig/release/fontconfig-$pkgver.tar.xz")
sha256sums=('63a0658d0e06e0fa886106452b58ef04f21f58202ea02a94c39de0d3335d7c0e')

build() {
  arch-meson "$pkgname-$pkgver" build \
    -D doc=disabled -D tests=disabled -D nls=disabled
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/COPYING" "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
