# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=xcb-util-cursor
pkgver=0.1.5
pkgrel=1
pkgdesc='XCB utility library: xcb-util-cursor'
arch=('x86_64')
url='https://xcb.freedesktop.org/'
license=('MIT')
depends=('libxcb' 'xcb-util-image' 'xcb-util-renderutil')
provides=('libxcb-cursor.so')
makedepends=('xcb-proto' 'xorgproto' 'xorg-util-macros' 'libxcb' 'pkgconf' 'gperf')
source=("https://xorg.freedesktop.org/archive/individual/lib/xcb-util-cursor-0.1.5.tar.xz")
sha256sums=('0caf99b0d60970f81ce41c7ba694e5eaaf833227bb2cbcdb2f6dc9666a663c57')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
