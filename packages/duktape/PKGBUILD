# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=duktape
pkgver=2.7.0
pkgrel=1
pkgdesc='Embeddable Javascript engine (polkit rules backend)'
arch=('x86_64')
url='https://duktape.org/'
license=('MIT')
depends=('glibc')
provides=('libduktape.so' 'libduktaped.so')
makedepends=('make')
source=("https://duktape.org/duktape-$pkgver.tar.xz")
sha256sums=('90f8d2fa8b5567c6899830ddef2c03f3c27960b11aca222fa17aa7ac613c2890')

build() {
  cd "$pkgname-$pkgver"
  make -f Makefile.sharedlibrary INSTALL_PREFIX=/usr
}

package() {
  cd "$pkgname-$pkgver"
  make -f Makefile.sharedlibrary INSTALL_PREFIX=/usr DESTDIR="$pkgdir" install
  install -Dm644 LICENSE.txt "$pkgdir/usr/share/licenses/$pkgname/LICENSE.txt"
}
