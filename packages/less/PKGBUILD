# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=less
pkgver=668
pkgrel=1
pkgdesc='Terminal pager — the default pager for git, man and friends'
arch=('x86_64')
url='https://www.greenwoodsoftware.com/less/'
license=('GPL-3.0-or-later')
depends=('glibc' 'ncurses')
source=("https://www.greenwoodsoftware.com/less/less-$pkgver.tar.gz")
sha256sums=('2819f55564d86d542abbecafd82ff61e819a3eec967faa36cd3e68f1596a44b8')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --with-regex=posix
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
