# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
#
# The Blueberry kernel as an updatable package. The kernel is monolithic (no
# loadable modules — CONFIG_MODULES is off), and the initramfs is pure
# userspace, so a kernel update is just a new /boot/vmlinuz plus a regenerated
# grub.cfg. The .INSTALL hook handles the latter via blueberry-grub-mkconfig.
pkgname=linux
pkgver=7.0
pkgrel=3
pkgdesc='The Blueberry Linux kernel (monolithic, no modules)'
arch=('x86_64')
url='https://www.kernel.org/'
license=('GPL-2.0-only')
depends=('glibc')
makedepends=('bc' 'flex' 'bison' 'openssl' 'perl' 'cpio' 'xz' 'pahole')
install=linux.install
source=("https://cdn.kernel.org/pub/linux/kernel/v${pkgver%%.*}.x/linux-$pkgver.tar.xz")
sha256sums=('bb7f6d80b387c757b7d14bb93028fcb90f793c5c0d367736ee815a100b3891f0')

build() {
  cd "linux-$pkgver"
  # Use the same config the image build ships; olddefconfig fills any gaps.
  cp "$startdir/../../src/kernel/config" .config
  make olddefconfig
  make -j"$(nproc)" bzImage
}

package() {
  cd "linux-$pkgver"
  # Active kernel grub.cfg points at, plus a versioned archive copy.
  install -Dm644 arch/x86/boot/bzImage "$pkgdir/boot/vmlinuz"
  install -Dm644 arch/x86/boot/bzImage "$pkgdir/boot/vmlinuz-$pkgver-blueberry"
  install -Dm644 System.map "$pkgdir/boot/System.map-$pkgver-blueberry"
  # On-device grub.cfg regenerator, invoked by the post-install hook.
  install -Dm755 "$startdir/blueberry-grub-mkconfig" \
    "$pkgdir/usr/bin/blueberry-grub-mkconfig"
}
