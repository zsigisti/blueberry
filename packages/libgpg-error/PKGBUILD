# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libgpg-error
pkgver=1.51
pkgrel=1
pkgdesc='Support library for libgcrypt'
arch=('x86_64')
url='https://www.gnupg.org/'
license=('LGPL')
depends=('glibc')
provides=('libgpg-error.so')
source=("https://gnupg.org/ftp/gcrypt/libgpg-error/libgpg-error-$pkgver.tar.bz2")
sha256sums=('be0f1b2db6b93eed55369cdf79f19f72750c8c7c39fc20b577e724545427e6b2')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
