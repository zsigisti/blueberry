# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=ksvg
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: scalable SVG-based theming'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'qt6-svg' 'karchive' 'kconfig' 'kcoreaddons' 'kguiaddons' 'kcolorscheme' 'kirigami' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-svg' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/ksvg-$pkgver.tar.xz")
sha256sums=('68d43f014639ae6097012cdd67bdbbefd5425b17d2322d94f55be2b138613e0a')

build() {
  cmake -S "ksvg-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
