# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-location
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 mapping and navigation module'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-declarative' 'qt6-positioning' )
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'perl' 'qt6-positioning' )
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtlocation-everywhere-src-$pkgver.tar.xz")
sha256sums=('3791ce77299e6f600a593d0fbfa5bd32fbcfc2d16104782b84acc489e382e41b')

build() {
  cmake -S "qtlocation-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
