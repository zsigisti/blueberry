# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libinput
pkgver=1.31.3
pkgrel=1
pkgdesc='Input device library (KWin)'
arch=('x86_64')
url='https://blueberry.linux/'
license=('custom')
depends=('glibc' 'libevdev' 'mtdev' 'systemd' 'libwacom' )
makedepends=('meson' 'ninja' 'libevdev' 'mtdev' 'libwacom' 'check' 'doxygen' )
options=('!lto')
source=("libinput-1.31.3.tar.gz::https://gitlab.freedesktop.org/libinput/libinput/-/archive/1.31.3/libinput-1.31.3.tar.gz")
sha256sums=('b6749bf6f1890f6631c0a70a027c35fec9d2e096a39f720548896e41474a9854')
build() { arch-meson() { meson setup "$@"; }; meson setup "libinput-1.31.3" build --prefix=/usr --buildtype=release -Dwerror=false -Ddocumentation=false -Dtests=false -Ddebug-gui=false; meson compile -C build; }
package() { meson install -C build --destdir "$pkgdir"; }
