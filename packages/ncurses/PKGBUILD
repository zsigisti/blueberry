# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=ncurses
pkgver=6.5
pkgrel=1
pkgdesc='System V Release 4.0 curses emulation library (wide-character)'
arch=('x86_64')
url='https://invisible-island.net/ncurses/'
license=('MIT')
depends=('glibc' 'gcc-libs')
source=("https://ftp.gnu.org/gnu/ncurses/ncurses-$pkgver.tar.gz")
sha256sums=('136d91bc269a9a5785e5f9e980bc76ab57428f604ce3e5a5a90cebc767971cc6')

build() {
  cd "$pkgname-$pkgver"
  ./configure \
    --prefix=/usr \
    --mandir=/usr/share/man \
    --with-shared \
    --without-cxx-binding \
    --enable-widec \
    --enable-pc-files \
    --with-pkg-config-libdir=/usr/lib/pkgconfig \
    --without-debug \
    --without-ada \
    --enable-overwrite
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  # Symlink the wide-char libs to the non-widec names so consumers that link
  # -lncurses/-ltinfo find them.
  for lib in ncurses form panel menu; do
    ln -sf "lib${lib}w.so" "$pkgdir/usr/lib/lib${lib}.so"
  done
  ln -sf libncursesw.so "$pkgdir/usr/lib/libcurses.so"
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
