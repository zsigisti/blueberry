pkgname=libnftnl
pkgver=1.2.8
pkgrel=1
pkgdesc='Netlink programming interface to the in-kernel nf_tables subsystem'
arch=('x86_64')
url='https://netfilter.org/projects/libnftnl/'
license=('GPL-2.0-or-later')
depends=('glibc' 'libmnl')
makedepends=('pkgconf')
provides=('libnftnl.so')
source=("https://www.netfilter.org/projects/libnftnl/files/libnftnl-$pkgver.tar.xz")
sha256sums=('37fea5d6b5c9b08de7920d298de3cdc942e7ae64b1a3e8b880b2d390ae67ad95')
build() { cd "$pkgname-$pkgver"; ./configure --prefix=/usr --disable-static; make; }
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
