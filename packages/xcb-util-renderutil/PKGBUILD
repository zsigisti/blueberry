# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=xcb-util-renderutil
pkgver=0.3.10
pkgrel=1
pkgdesc='XCB utility library: xcb-util-renderutil'
arch=('x86_64')
url='https://xcb.freedesktop.org/'
license=('MIT')
depends=('libxcb')
provides=('libxcb-render-util.so')
makedepends=('xcb-proto' 'xorgproto' 'xorg-util-macros' 'libxcb' 'pkgconf' 'gperf')
source=("https://xorg.freedesktop.org/archive/individual/lib/xcb-util-renderutil-0.3.10.tar.xz")
sha256sums=('3e15d4f0e22d8ddbfbb9f5d77db43eacd7a304029bf25a6166cc63caa96d04ba')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
