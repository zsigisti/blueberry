pkgname=lcms2
pkgver=2.19
pkgrel=1
pkgdesc='Little CMS color management'
arch=('x86_64')
url='https://blueberry.linux/'
license=('custom')
depends=('glibc' 'libtiff' 'zlib' )
makedepends=('' )
options=('!lto')
source=("lcms2-2.19.tar.gz::https://github.com/mm2/Little-CMS/releases/download/lcms2.19/lcms2-2.19.tar.gz")
sha256sums=('49e7e134e4299733dd0eda434fa468997a28ab3d33fa397c642b03644f552216')
build() { cd "lcms2-2.19"; ./configure --prefix=/usr --libdir=/usr/lib ; make; }
package() { cd "lcms2-2.19"; make DESTDIR="$pkgdir" install; }
