# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=lib32-libxdmcp
pkgver=1.1.5
pkgrel=1
pkgdesc='X11 DMCP library (32-bit)'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('custom')
depends=('lib32-glibc' )
makedepends=('lib32-glibc' 'lib32-gcc-libs' 'xorgproto' 'xorg-util-macros' 'pkgconf' 'lib32-libxau' )
options=('!lto' '!strip')
source=("libXdmcp-1.1.5.tar.xz::https://www.x.org/releases/individual/lib/libXdmcp-1.1.5.tar.xz")
sha256sums=('d8a5222828c3adab70adf69a5583f1d32eb5ece04304f7f8392b6a353aa2228c')

build() {
  export CC="gcc -m32" CXX="g++ -m32" PKG_CONFIG_PATH=/usr/lib32/pkgconfig
  cd "libXdmcp-1.1.5"
  ./configure --prefix=/usr --libdir=/usr/lib32 --host=i686-pc-linux-gnu --disable-static 
  make
}

package() {
  cd "libXdmcp-1.1.5"; make DESTDIR="$pkgdir" install
  rm -rf "$pkgdir/usr/include" "$pkgdir/usr/share" "$pkgdir/usr/bin"
}
