# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=ncdu
pkgver=1.21
pkgrel=1
pkgdesc='Disk usage analyzer with an ncurses interface'
arch=('x86_64')
url='https://dev.yorhel.nl/ncdu'
license=('MIT')
depends=('glibc' 'ncurses')
source=("https://dev.yorhel.nl/download/ncdu-$pkgver.tar.gz")
sha256sums=('a894d3a9b46bce578a6039bef48f54533ec402fb589b0769bfbb1d1edf9601a6')
build() { cd "$pkgname-$pkgver"; ./configure --prefix=/usr --with-ncursesw; make; }
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
