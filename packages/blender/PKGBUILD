# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# Binary repackage of blender.org's official build (bundles Python + all libs).
pkgname=blender
pkgver=5.1.2
pkgrel=1
pkgdesc='Blender 3D creation suite (official binary, self-contained)'
arch=('x86_64')
url='https://www.blender.org/'
license=('GPL-3.0-or-later')
depends=('libx11' 'libxi' 'libxxf86vm' 'libxfixes' 'libxrender' 'libxkbcommon'
         'mesa' 'libglvnd')
options=(!strip !debug)
_dir=blender-$pkgver-linux-x64
source=("https://download.blender.org/release/Blender${pkgver%.*}/$_dir.tar.xz"
        'blender.desktop')
sha256sums=('SKIP' 'SKIP')
package() {
  install -d "$pkgdir/opt" "$pkgdir/usr/bin"
  cp -a "$_dir" "$pkgdir/opt/blender"
  ln -s /opt/blender/blender "$pkgdir/usr/bin/blender"
  install -Dm644 "$pkgdir/opt/blender/blender.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/blender.svg" 2>/dev/null || true
  install -Dm644 "$srcdir/blender.desktop" "$pkgdir/usr/share/applications/blender.desktop"
}
