# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=popt
pkgver=1.19
pkgrel=1
pkgdesc='Library for parsing command line options'
arch=('x86_64')
url='https://github.com/rpm-software-management/popt'
license=('MIT')
depends=('glibc')
provides=('libpopt.so')
source=("http://ftp.rpm.org/popt/releases/popt-1.x/popt-$pkgver.tar.gz")
sha256sums=('c25a4838fc8e4c1c8aacb8bd620edb3084a3d63bf8987fdad3ca2758c63240f9')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
