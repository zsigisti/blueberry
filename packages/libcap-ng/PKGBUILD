# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# libcap-ng — easier POSIX capabilities. tcpdump uses it to drop privileges.
pkgname=libcap-ng
pkgver=0.8.5
pkgrel=1
pkgdesc='Library for handling POSIX capabilities'
arch=('x86_64')
url='https://people.redhat.com/sgrubb/libcap-ng/'
license=('LGPL-2.1-or-later')
depends=('glibc')
source=("https://people.redhat.com/sgrubb/libcap-ng/libcap-ng-$pkgver.tar.gz")
sha256sums=('3ba5294d1cbdfa98afaacfbc00b6af9ed2b83e8a21817185dfd844cc8c7ac6ff')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --without-python --without-python3
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING.LIB "$pkgdir/usr/share/licenses/$pkgname/COPYING.LIB"
}
