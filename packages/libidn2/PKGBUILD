# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
#
# GNU libidn2 — internationalized domain names (IDNA2008). wget links it.
pkgname=libidn2
pkgver=2.3.7
pkgrel=1
pkgdesc='Implementation of the IDNA2008, Punycode and TR46 specifications'
arch=('x86_64')
url='https://www.gnu.org/software/libidn/'
license=('GPL-2.0-or-later OR LGPL-3.0-or-later')
depends=('glibc' 'libunistring')
source=("https://ftp.gnu.org/gnu/libidn/libidn2-$pkgver.tar.gz")
sha256sums=('4c21a791b610b9519b9d0e12b8097bf2f359b12f8dd92647611a929e6bfd7d64')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --disable-doc
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
