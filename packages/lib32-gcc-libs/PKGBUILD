# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# 32-bit GCC runtime libraries (libgcc_s, libstdc++, libatomic, libgomp) — the
# second half of the multilib foundation (with lib32-glibc). Built by configuring
# GCC --enable-multilib and keeping only the i686 runtime libraries.
pkgname=lib32-gcc-libs
pkgver=16.1.0
pkgrel=1
pkgdesc='32-bit GCC runtime libraries (libgcc/libstdc++) — multilib for i686 software'
arch=('x86_64')
url='https://gcc.gnu.org/'
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later')
depends=('lib32-glibc' 'gcc-libs')
makedepends=('lib32-glibc' 'binutils' 'gmp' 'mpfr' 'mpc' 'zlib' 'linux-api-headers')
options=('!lto')
source=("https://ftp.gnu.org/gnu/gcc/gcc-$pkgver/gcc-$pkgver.tar.xz")
sha256sums=('50efb4d94c3397aff3b0d61a5abd748b4dd31d9d3f2ab7be05b171d36a510f79')

build() {
  cd "gcc-$pkgver"
  CFLAGS="${CFLAGS//-Werror=format-security/}"
  CXXFLAGS="${CXXFLAGS//-Werror=format-security/}"
  export CFLAGS CXXFLAGS
  mkdir -p ../build && cd ../build
  ../"gcc-$pkgver"/configure \
    --prefix=/usr \
    --libdir=/usr/lib \
    --libexecdir=/usr/lib \
    --enable-languages=c,c++ \
    --enable-multilib \
    --enable-default-pie \
    --enable-default-ssp \
    --enable-__cxa_atexit \
    --disable-bootstrap \
    --disable-werror \
    --disable-nls \
    --without-isl \
    --with-system-zlib
  make
}

package() {
  cd build
  make -j1 DESTDIR="$pkgdir" install
  # Keep ONLY the 32-bit runtime shared libraries.
  install -d "$srcdir/keep"
  for lib in libgcc_s libstdc++ libatomic libgomp libquadmath libitm libssp; do
    cp -a "$pkgdir/usr/lib32/$lib".so* "$srcdir/keep/" 2>/dev/null || true
  done
  rm -rf "$pkgdir"/*
  install -d "$pkgdir/usr/lib32"
  cp -a "$srcdir/keep"/* "$pkgdir/usr/lib32/" 2>/dev/null || true
}
