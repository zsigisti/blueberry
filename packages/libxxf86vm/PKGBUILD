# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libxxf86vm
pkgver=1.1.7
pkgrel=1
pkgdesc='X11 XFree86 video mode extension library (Mesa GLX)'
arch=('x86_64')
url='https://xorg.freedesktop.org/'
license=('custom')
depends=('glibc' 'libx11' 'libxext')
makedepends=('xorgproto' 'pkgconf')
options=('!lto')
source=("https://www.x.org/pub/individual/lib/libXxf86vm-${pkgver}.tar.xz")
sha256sums=('ae50c0f669e0af5a67cc4cd0f54f21d64a64d2660af883e80e95d3fe51b945d8')
build() { cd "libXxf86vm-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib --disable-static; make; }
package() { cd "libXxf86vm-${pkgver}"; make DESTDIR="$pkgdir" install; }
