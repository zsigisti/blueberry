# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libtatsu
pkgver=1.0.5
pkgrel=1
pkgdesc="Library handling Apple's TSS server (libimobiledevice 1.4)"
arch=('x86_64')
url='https://libimobiledevice.org/'
license=('LGPL-2.1-or-later')
depends=('glibc' 'libplist' 'curl' 'openssl')
makedepends=('pkgconf' 'curl' 'openssl')
options=('!lto')
source=("https://github.com/libimobiledevice/libtatsu/releases/download/${pkgver}/libtatsu-${pkgver}.tar.bz2")
sha256sums=('536fa228b14f156258e801a7f4d25a3a9dd91bb936bf6344e23171403c57e440')
build() { cd "libtatsu-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib; make; }
package() { cd "libtatsu-${pkgver}"; make DESTDIR="$pkgdir" install; }
