# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=ca-certificates
pkgver=20260514
pkgrel=1
pkgdesc='Common CA certificates (Mozilla bundle) — the trust store bpm and curl use for HTTPS'
arch=('any')
url='https://curl.se/docs/caextract.html'
license=('MPL-2.0')
# The dated bundle URL is immutable, so the checksum stays stable (the rolling
# cacert.pem would drift and break verification on every Mozilla update).
source=("cacert-${pkgver}.pem::https://curl.se/ca/cacert-2026-05-14.pem")
sha256sums=('86a1f3366afac7c6f8ae9f3c779ac221129328c43f0ab2b8817eb2f362a5025c')

package() {
  # bpm and curl both read /etc/ssl/certs/ca-certificates.crt.
  install -Dm644 "cacert-${pkgver}.pem" \
    "$pkgdir/etc/ssl/certs/ca-certificates.crt"
  # Common aliases other tools look for.
  ln -s ca-certificates.crt "$pkgdir/etc/ssl/certs/cert.pem"
  install -Dm644 "cacert-${pkgver}.pem" \
    "$pkgdir/etc/ssl/cert.pem"
}
