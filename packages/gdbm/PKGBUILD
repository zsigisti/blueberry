# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# GNU dbm — key/value database. Ships the libgdbm_compat (ndbm/dbm) shim that
# python's dbm.gnu module links.
pkgname=gdbm
pkgver=1.24
pkgrel=1
pkgdesc='GNU database library (dbm) with the ndbm/dbm compatibility shim'
arch=('x86_64')
url='https://www.gnu.org/software/gdbm/'
license=('GPL-3.0-or-later')
depends=('glibc' 'readline')
source=("https://ftp.gnu.org/gnu/gdbm/gdbm-$pkgver.tar.gz")
sha256sums=('695e9827fdf763513f133910bc7e6cfdb9187943a4fec943e57449723d2b8dbf')

build() {
  cd "$pkgname-$pkgver"
  # gcc 16 defaults to C23, where `bool` is a keyword; gdbm 1.24's var.c still
  # uses `bool` as an identifier. Build as gnu17 so it compiles.
  ./configure --prefix=/usr --disable-static --enable-libgdbm-compat \
    CFLAGS="${CFLAGS:-} -std=gnu17"
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
