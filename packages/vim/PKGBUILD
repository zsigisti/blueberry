# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=vim
pkgver=9.1.0863
pkgrel=1
pkgdesc='Vi Improved, a highly configurable text editor'
arch=('x86_64')
url='https://www.vim.org/'
license=('Vim')
depends=('glibc' 'ncurses' 'acl' 'libgcrypt')
makedepends=('gpm')
source=("$pkgname-$pkgver.tar.gz::https://github.com/vim/vim/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('07a0f185b9327b0e9cc383dd3706cec469fd5376a0b2eeb733c17b353aefa20a')

build() {
  cd "$pkgname-$pkgver/src"
  ./configure \
    --prefix=/usr \
    --localstatedir=/var/lib/vim \
    --with-features=huge \
    --enable-multibyte \
    --enable-gui=no \
    --without-x \
    --disable-netbeans \
    --disable-gpm \
    --enable-terminal
  make
}

package() {
  cd "$pkgname-$pkgver/src"
  make DESTDIR="$pkgdir" install
  # vim ships its own runtime; drop the GUI desktop bits we didn't build
  rm -rf "$pkgdir/usr/share/applications" "$pkgdir/usr/share/icons"
  install -Dm644 "../README.txt" "$pkgdir/usr/share/licenses/$pkgname/README.txt"
}
