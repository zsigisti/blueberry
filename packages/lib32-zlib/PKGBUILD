# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=lib32-zlib
pkgver=1.3.1
pkgrel=1
pkgdesc='Compression library (32-bit)'
arch=('x86_64')
url='https://www.zlib.net/'
license=('Zlib')
depends=('lib32-glibc')
makedepends=('lib32-glibc' 'lib32-gcc-libs')
options=('!lto')
source=("zlib-$pkgver.tar.gz::https://github.com/madler/zlib/releases/download/v$pkgver/zlib-$pkgver.tar.gz")
sha256sums=('9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23')

build() {
  cd "zlib-$pkgver"
  # zlib's hand-written configure: drive it with a 32-bit CC and lib32 libdir.
  CC='gcc -m32' ./configure --prefix=/usr --libdir=/usr/lib32
  make
}

package() {
  cd "zlib-$pkgver"
  make DESTDIR="$pkgdir" install
  rm -rf "$pkgdir/usr/include" "$pkgdir/usr/share"
}
