# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kded
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: central daemon for background services'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'kcoreaddons' 'kdbusaddons' 'kservice' 'kcrash' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kded-$pkgver.tar.xz")
sha256sums=('4f24067915b05a1d0cc87e2c37f37eb0e8c441e8fccdf06ca27ee7b923058243')

build() {
  cmake -S "kded-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
