# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=pkgconf
pkgver=2.4.3
pkgrel=1
pkgdesc='pkg-config compatible utility to manage compile/link flags'
arch=('x86_64')
url='https://github.com/pkgconf/pkgconf'
license=('ISC')
depends=('glibc')
provides=('pkg-config' 'libpkgconf.so')
source=("https://distfiles.ariadne.space/pkgconf/pkgconf-$pkgver.tar.xz")
sha256sums=('51203d99ed573fa7344bf07ca626f10c7cc094e0846ac4aa0023bd0c83c25a41')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  # The conventional `pkg-config` name most build systems invoke.
  ln -s pkgconf "$pkgdir/usr/bin/pkg-config"
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
