# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libcanberra
pkgver=0.30
pkgrel=1
pkgdesc='Event sound library (XDG Sound Theme) — Plasma/SDDM sounds'
arch=('x86_64')
url='https://0pointer.de/lennart/projects/libcanberra/'
license=('LGPL-2.1-or-later')
depends=('glibc' 'libvorbis' 'libltdl' 'alsa-lib' 'libpulse')
makedepends=('gtk3' 'libpulse' 'libtool')
options=('!lto')
source=("libcanberra-0.30.tar.xz::https://0pointer.de/lennart/projects/libcanberra/libcanberra-0.30.tar.xz")
sha256sums=('c2b671e67e0c288a69fc33dc1b6f1b534d07882c2aceed37004bf48c601afa72')
build() { cd "libcanberra-$pkgver"; ./configure --prefix=/usr --libdir=/usr/lib --disable-static --enable-pulse --enable-alsa --disable-oss; make; }
package() { cd "libcanberra-$pkgver"; make DESTDIR="$pkgdir" install; }
