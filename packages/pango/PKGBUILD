# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=pango
pkgver=1.57.1
pkgrel=1
pkgdesc='Library for layout and rendering of text'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('cairo' 'fontconfig' 'freetype2' 'fribidi' 'harfbuzz' 'libxft' 'libthai' 'glib2' )
makedepends=('meson' 'ninja' 'pkgconf' )
options=('!lto')
source=("pango-1.57.1.tar.xz::https://download.gnome.org/sources/pango/1.57/pango-1.57.1.tar.xz")
sha256sums=('e65d6d117080dc3aeeb7d8b4b3b518f7383aa2e6cfce23117c623cd624764c2f')

build() {
  arch-meson() { meson setup "$@"; }
  meson setup pango-1.57.1 build --prefix=/usr --buildtype=release -Dwerror=false -Dintrospection=disabled -Ddocumentation=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
