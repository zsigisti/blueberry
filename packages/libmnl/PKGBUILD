# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libmnl
pkgver=1.0.5
pkgrel=1
pkgdesc='Minimalistic user-space library oriented to Netlink developers'
arch=('x86_64')
url='https://netfilter.org/projects/libmnl/'
license=('LGPL2.1')
depends=('glibc')
provides=('libmnl.so')
source=("https://www.netfilter.org/projects/libmnl/files/libmnl-$pkgver.tar.bz2")
sha256sums=('274b9b919ef3152bfb3da3a13c950dd60d6e2bcd54230ffeca298d03b40d0525')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
