# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-virtualkeyboard
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 on-screen virtual keyboard'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-declarative' 'qt6-svg' )
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'perl' 'qt6-svg' )
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtvirtualkeyboard-everywhere-src-$pkgver.tar.xz")
sha256sums=('a1c6967b326243b2ca8d50bc7b7f7852c3975d9aa6ce4b186ebdf35bb1007e1c')

build() {
  cmake -S "qtvirtualkeyboard-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
