# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libepoxy
pkgver=1.5.10
pkgrel=1
pkgdesc='OpenGL function pointer management library'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('mesa' 'libglvnd' )
makedepends=('meson' 'ninja' 'pkgconf' 'python' 'xorgproto' )
options=('!lto')
source=("libepoxy-1.5.10.tar.gz::https://github.com/anholt/libepoxy/archive/1.5.10/libepoxy-1.5.10.tar.gz")
sha256sums=('a7ced37f4102b745ac86d6a70a9da399cc139ff168ba6b8002b4d8d43c900c15')

build() {
  arch-meson() { meson setup "$@"; }
  meson setup libepoxy-1.5.10 build --prefix=/usr --buildtype=release -Dwerror=false -Dtests=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
