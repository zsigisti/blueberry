# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# Full OpenSSH (sshd, ssh, scp, sftp) for deployments that need more than the
# base image's Dropbear — certificates, sftp-server, full config surface.
pkgname=openssh
pkgver=9.9p2
pkgrel=1
pkgdesc='OpenSSH — full SSH server and client suite'
arch=('x86_64')
url='https://www.openssh.com/'
license=('BSD-2-Clause')
depends=('glibc' 'openssl' 'zlib')
source=("https://cdn.openbsd.org/pub/OpenBSD/OpenSSH/portable/openssh-$pkgver.tar.gz")
sha256sums=('91aadb603e08cc285eddf965e1199d02585fa94d994d6cae5b41e1721e215673')
build() {
  cd "$pkgname-$pkgver"
  ./configure \
    --prefix=/usr \
    --sysconfdir=/etc/ssh \
    --with-privsep-path=/var/empty \
    --with-privsep-user=nobody \
    --without-pam \
    --with-ssl-engine \
    --with-zlib
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
