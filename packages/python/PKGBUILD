# Maintainer: Blueberry Linux <packages@blueberry.linux>
# CPython — the reference Python interpreter. Built against the base libraries
# already packaged for Blueberry (zlib, openssl, bzip2, libffi via gdbm-less
# minimal config). A large build.
pkgname=python
pkgver=3.13.3
pkgrel=2
pkgdesc='CPython — the Python programming language interpreter'
arch=('x86_64')
url='https://www.python.org/'
license=('Python-2.0.1')
# Stdlib C modules link these at runtime: ncurses (curses/_curses_panel),
# readline (readline), gdbm (dbm.gnu), mpdecimal (_decimal), sqlite (sqlite3),
# expat (pyexpat), e2fsprogs (libuuid → uuid).
depends=('glibc' 'zlib' 'openssl' 'bzip2' 'libffi' 'xz'
         'ncurses' 'readline' 'gdbm' 'mpdecimal' 'sqlite' 'expat' 'e2fsprogs')
provides=('python3')
source=("https://www.python.org/ftp/python/$pkgver/Python-$pkgver.tar.xz")
sha256sums=('40f868bcbdeb8149a3149580bb9bfd407b3321cd48f0be631af955ac92c0e041')
build() {
  cd "Python-$pkgver"
  # PGO (--enable-optimizations) is skipped: it runs the test suite for
  # profiling, which roughly triples build time and can hang in a container.
  ./configure \
    --prefix=/usr \
    --enable-shared \
    --with-system-expat \
    --with-ensurepip=install \
    --without-static-libpython
  make
}
package() {
  cd "Python-$pkgver"
  make DESTDIR="$pkgdir" install
  ln -sf python3 "$pkgdir/usr/bin/python"
}
