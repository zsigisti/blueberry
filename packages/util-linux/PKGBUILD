# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
#
# util-linux — core system utilities and the canonical libuuid / libblkid /
# libmount / libfdisk / libsmartcols libraries that systemd links. On Blueberry
# util-linux (not e2fsprogs) owns libuuid/libblkid; e2fsprogs is rebuilt without
# them. Ships agetty, login, mount, lsblk, lscpu, setpriv, etc.
pkgname=util-linux
pkgver=2.40.2
pkgrel=1
pkgdesc='Miscellaneous system utilities + libuuid/libblkid/libmount'
arch=('x86_64')
url='https://github.com/util-linux/util-linux'
license=('GPL-2.0-or-later' 'LGPL-2.1-or-later' 'BSD-3-Clause')
depends=('glibc' 'libcap-ng' 'readline' 'file')
makedepends=('pkgconf')
provides=('libuuid.so' 'libblkid.so' 'libmount.so' 'libfdisk.so' 'libsmartcols.so')
source=("https://www.kernel.org/pub/linux/utils/util-linux/v${pkgver%.*}/util-linux-$pkgver.tar.xz")
sha256sums=('d78b37a66f5922d70edf3bdfb01a6b33d34ed3c3cafd6628203b2a2b67c8e8b3')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --bindir=/usr/bin --sbindir=/usr/bin \
    --sysconfdir=/etc --disable-static --disable-rpath \
    --enable-libuuid --enable-libblkid --enable-libmount \
    --enable-fs-paths-extra=/usr/bin --disable-lsfd \
    --without-python --without-systemd --without-systemdsystemunitdir \
    --without-selinux --without-audit
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 README.licensing "$pkgdir/usr/share/licenses/$pkgname/README.licensing" 2>/dev/null || true
}
