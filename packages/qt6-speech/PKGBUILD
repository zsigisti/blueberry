# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-speech
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt6 Text-to-Speech'
arch=('x86_64')
url='https://blueberry.linux/'
license=('custom')
depends=('qt6-base' 'qt6-declarative' )
makedepends=('cmake' 'ninja' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("qtspeech-everywhere-src-6.11.1.tar.xz::https://download.qt.io/official_releases/qt/6.11/6.11.1/submodules/qtspeech-everywhere-src-6.11.1.tar.xz")
sha256sums=('c035c318012025875a653245701a23d3807e8e46b8bf7987877842219c273f14')
build() { cmake -S "qtspeech-everywhere-src-6.11.1" -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib -DQT_BUILD_EXAMPLES=OFF -DQT_BUILD_TESTS=OFF; cmake --build build; }
package() { DESTDIR="$pkgdir" cmake --install build; }
