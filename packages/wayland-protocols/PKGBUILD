# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=wayland-protocols
pkgver=1.38
pkgrel=1
pkgdesc='Specifications of extended Wayland protocols'
arch=('any')
url='https://wayland.freedesktop.org/'
license=('MIT')
depends=('wayland')
makedepends=('meson' 'ninja' 'wayland')
source=("https://gitlab.freedesktop.org/wayland/wayland-protocols/-/releases/$pkgver/downloads/wayland-protocols-$pkgver.tar.xz")
sha256sums=('ff17292c05159d2b20ce6cacfe42d7e31a28198fa1429a769b03af7c38581dbe')

build() {
  arch-meson "$pkgname-$pkgver" build -D tests=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/COPYING" "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
