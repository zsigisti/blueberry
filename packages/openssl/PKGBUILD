# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=openssl
pkgver=3.4.0
pkgrel=1
pkgdesc='TLS/SSL and crypto library'
arch=('x86_64')
url='https://www.openssl.org/'
license=('Apache')
depends=('glibc' 'zlib')
makedepends=('perl')
provides=('libcrypto.so' 'libssl.so')
source=("https://github.com/openssl/openssl/releases/download/openssl-$pkgver/openssl-$pkgver.tar.gz")
sha256sums=('e15dda82fe2fe8139dc2ac21a36d4ca01d5313c75f99f46c4e8a27709b7294bf')
build() {
  cd "$pkgname-$pkgver"
  ./Configure --prefix=/usr --openssldir=/etc/ssl --libdir=lib \
    shared zlib enable-ktls linux-x86_64
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" MANSUFFIX=ssl install_sw install_ssldirs
}
