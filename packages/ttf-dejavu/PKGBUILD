# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=ttf-dejavu
pkgver=2.37
pkgrel=1
pkgdesc='DejaVu font family — broad Latin/Greek/Cyrillic + symbol coverage (desktop default UI font)'
arch=('any')
url='https://dejavu-fonts.github.io/'
license=('custom')
depends=('fontconfig')
options=('!strip')
source=("https://github.com/dejavu-fonts/dejavu-fonts/releases/download/version_2_37/dejavu-fonts-ttf-${pkgver}.tar.bz2")
sha256sums=('fa9ca4d13871dd122f61258a80d01751d603b4d3ee14095d65453b4e846e17d7')
package() {
  cd "dejavu-fonts-ttf-${pkgver}"
  install -d "$pkgdir/usr/share/fonts/TTF"
  install -m644 ttf/*.ttf "$pkgdir/usr/share/fonts/TTF/"
  # fontconfig presets so Sans/Serif/Monospace resolve to DejaVu out of the box.
  install -d "$pkgdir/usr/share/fontconfig/conf.avail" "$pkgdir/etc/fonts/conf.d"
  for c in fontconfig/*.conf; do install -m644 "$c" "$pkgdir/usr/share/fontconfig/conf.avail/" 2>/dev/null || true; done
}
