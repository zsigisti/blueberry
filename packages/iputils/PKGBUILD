# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=iputils
pkgver=20250605
pkgrel=1
pkgdesc='Network monitoring tools — ping, tracepath, arping'
arch=('x86_64')
url='https://github.com/iputils/iputils'
license=('BSD' 'GPL2')
depends=('glibc' 'libcap')
makedepends=('meson' 'ninja' 'pkgconf' 'libcap')
provides=('ping')
options=('!lto')
source=("iputils-$pkgver.tar.gz::https://github.com/iputils/iputils/archive/refs/tags/$pkgver.tar.gz")
sha256sums=('19e680c9eef8c079da4da37040b5f5453763205b4edfb1e2c114de77908927e4')

build() {
  # IDN/gettext off → no libidn2/gettext dep; mans off → no docbook; ping links libcap only.
  meson setup "iputils-$pkgver" build \
    --prefix=/usr --buildtype=release \
    -D USE_IDN=false \
    -D USE_GETTEXT=false \
    -D BUILD_MANS=false \
    -D BUILD_HTML_MANS=false \
    -D BUILD_CLOCKDIFF=false \
    -D SKIP_TESTS=true
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
