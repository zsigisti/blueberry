# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=threadweaver
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: high-level multithreading job framework'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/threadweaver-$pkgver.tar.xz")
sha256sums=('6be89d43b4d7cfd4ce519ed24b8bcf8400c93bcfc6f42d9931cd0f852269bdcb')

build() {
  cmake -S "threadweaver-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
