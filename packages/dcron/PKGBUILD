# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=dcron
pkgver=4.5
pkgrel=1
pkgdesc='Dillon cron daemon'
arch=('x86_64')
url='https://www.jimpryor.net/linux/dcron.html'
license=('GPL-2.0-or-later')
depends=('glibc')
provides=('cron')
source=("https://www.jimpryor.net/linux/releases/dcron-$pkgver.tar.gz")
sha256sums=('9e50edb6f5bd8153b16bad05087d985e5153ce45cc01ae77e7f842213fb4a824')
build() { cd "$pkgname-$pkgver"; make CC="${CC:-gcc}" CFLAGS="$CFLAGS -std=gnu17"; }
package() {
  cd "$pkgname-$pkgver"
  install -Dm755 crond "$pkgdir/usr/bin/crond"
  install -Dm4755 crontab "$pkgdir/usr/bin/crontab"
}
