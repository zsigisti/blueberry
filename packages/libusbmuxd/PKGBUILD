pkgname=libusbmuxd
pkgver=2.1.1
pkgrel=1
pkgdesc='USB multiplexer client library for iOS devices (libimobiledevice)'
arch=('x86_64')
url='https://libimobiledevice.org/'
license=('LGPL-2.1-or-later')
depends=('glibc' 'libplist' 'libimobiledevice-glue')
makedepends=('pkgconf' 'libimobiledevice-glue')
options=('!lto')
source=("https://github.com/libimobiledevice/libusbmuxd/releases/download/${pkgver}/libusbmuxd-${pkgver}.tar.bz2")
sha256sums=('5546f1aba1c3d1812c2b47d976312d00547d1044b84b6a461323c621f396efce')
build() { cd "libusbmuxd-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib; make; }
package() { cd "libusbmuxd-${pkgver}"; make DESTDIR="$pkgdir" install; }
