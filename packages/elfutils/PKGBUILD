# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
#
# elfutils — ELF/DWARF libraries. Provides libelf, libdw (strace stack unwind)
# and the libdebuginfod client (binutils links libdebuginfod.so.1).
pkgname=elfutils
pkgver=0.192
pkgrel=1
pkgdesc='Libraries and tools for ELF and DWARF (libelf, libdw, libdebuginfod)'
arch=('x86_64')
url='https://sourceware.org/elfutils/'
license=('GPL-3.0-or-later')
# json-c: libdebuginfod.so links it. We ship libraries only (libelf, libdw,
# libdebuginfod) — the eu-* tools are dropped, so libarchive isn't needed.
depends=('glibc' 'zlib' 'bzip2' 'xz' 'zstd' 'curl' 'json-c')
makedepends=('pkgconf')
# elfutils + LTO trips gcc 16's -Werror=null-dereference during ltrans (and the
# release has no --disable-werror knob), so build without LTO.
options=('!lto')
source=("https://sourceware.org/elfutils/ftp/$pkgver/elfutils-$pkgver.tar.bz2")
sha256sums=('616099beae24aba11f9b63d86ca6cc8d566d968b802391334c91df54eab416b4')

build() {
  cd "$pkgname-$pkgver"
  # client libdebuginfod (needs libcurl); skip the debuginfod *server* (which
  # would pull in libmicrohttpd). elfutils bakes -Werror into AM_CFLAGS and has
  # no configure toggle; autotools compiles as $(AM_CFLAGS) $(CFLAGS), so a
  # trailing -Wno-error in CFLAGS overrides it (gcc 16 finds new warnings, e.g.
  # discarded-qualifiers in riscv_disasm.c).
  ./configure --prefix=/usr \
    --enable-libdebuginfod --disable-debuginfod --program-prefix="eu-" \
    CFLAGS="${CFLAGS:-} -Wno-error"
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  rm -f "$pkgdir"/usr/lib/*.a            # drop static archives
  # Ship the libraries only — strace/binutils need libdw + libdebuginfod, not
  # the eu-* command-line tools (binutils already provides readelf/nm/...). This
  # also drops the libarchive dependency (only eu-srcfiles used it).
  rm -rf "$pkgdir"/usr/bin
  install -Dm644 COPYING-GPLV2 "$pkgdir/usr/share/licenses/$pkgname/COPYING-GPLV2"
}
