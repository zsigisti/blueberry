# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=nano
pkgver=8.2
pkgrel=1
pkgdesc='Pico editor clone with enhancements'
arch=('x86_64')
url='https://www.nano-editor.org/'
license=('GPL-3.0-or-later')
depends=('glibc' 'ncurses' 'file')
source=("https://www.nano-editor.org/dist/v${pkgver%%.*}/nano-$pkgver.tar.xz")
sha256sums=('d5ad07dd862facae03051c54c6535e54c7ed7407318783fcad1ad2d7076fffeb')

build() {
  cd "$pkgname-$pkgver"
  ./configure \
    --prefix=/usr \
    --sysconfdir=/etc \
    --enable-utf8 \
    --enable-color \
    --enable-nanorc
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
