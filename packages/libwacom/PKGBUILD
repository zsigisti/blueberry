# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libwacom
pkgver=2.19.0
pkgrel=1
pkgdesc='Library to identify Wacom tablets (KWin tablet support)'
arch=('x86_64')
url='https://github.com/linuxwacom/libwacom'
license=('MIT')
depends=('glibc' 'glib2' 'libgudev' 'libevdev')
makedepends=('meson' 'ninja' 'pkgconf' 'python')
options=('!lto')
source=("https://github.com/linuxwacom/libwacom/releases/download/libwacom-${pkgver}/libwacom-${pkgver}.tar.xz")
sha256sums=('8dd84e75d322aa5f33b2fe781cb67efa5706fedcf483737b4657557f33055a93')
build() { meson setup "libwacom-${pkgver}" build --prefix=/usr --libdir=/usr/lib --buildtype=release -Dtests=disabled -Ddocumentation=disabled; ninja -C build; }
package() { DESTDIR="$pkgdir" ninja -C build install; }
