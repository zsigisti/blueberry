# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=iptables
pkgver=1.8.11
pkgrel=2
pkgdesc='Userspace tools for the Linux kernel packet filter (legacy + nft)'
arch=('x86_64')
url='https://www.netfilter.org/projects/iptables/'
license=('GPL-2.0-only')
# libnfnetlink + libnetfilter_conntrack: the conntrack/state/NAT-helper matches
# (xt_conntrack etc.) link these at runtime.
depends=('glibc' 'libmnl' 'libnftnl' 'libnfnetlink' 'libnetfilter_conntrack')
makedepends=('pkgconf')
source=("https://www.netfilter.org/projects/iptables/files/iptables-$pkgver.tar.xz")
sha256sums=('d87303d55ef8c92bcad4dd3f978b26d272013642b029425775f5bad1009fe7b2')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sbindir=/usr/bin --sysconfdir=/etc \
    --disable-nftables --enable-libipq --without-kernel
  make
}
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
