# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=htop
pkgver=3.3.0
pkgrel=1
pkgdesc='Interactive process viewer'
arch=('x86_64')
url='https://htop.dev/'
license=('GPL-2.0-or-later')
depends=('glibc' 'ncurses' 'libcap')
source=("https://github.com/htop-dev/htop/releases/download/$pkgver/htop-$pkgver.tar.xz")
sha256sums=('a69acf9b42ff592c4861010fce7d8006805f0d6ef0e8ee647a6ee6e59b743d5c')

build() {
  cd "$pkgname-$pkgver"
  ./configure \
    --prefix=/usr \
    --sysconfdir=/etc \
    --enable-unicode \
    --enable-affinity \
    --enable-capabilities \
    --disable-delayacct
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
