# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=ki18n
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: internationalization (Gettext-based i18n)'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'gettext' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/ki18n-$pkgver.tar.xz")
sha256sums=('cd812ae95b0e95b40e46a50b9dea6d188eec001be96b1e1a5d962730e5f9bc58')

build() {
  cmake -S "ki18n-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
