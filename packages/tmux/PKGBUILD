# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=tmux
pkgver=3.5a
pkgrel=1
pkgdesc='Terminal multiplexer'
arch=('x86_64')
url='https://github.com/tmux/tmux'
license=('ISC')
depends=('glibc' 'ncurses' 'libevent')
source=("https://github.com/tmux/tmux/releases/download/$pkgver/tmux-$pkgver.tar.gz")
sha256sums=('16216bd0877170dfcc64157085ba9013610b12b082548c7c9542cc0103198951')

build() {
  cd "$pkgname-$pkgver"
  ./configure \
    --prefix=/usr \
    --sysconfdir=/etc
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 example_tmux.conf "$pkgdir/usr/share/tmux/example_tmux.conf"
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
