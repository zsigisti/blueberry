# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=sonnet
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: spell-checking framework'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/sonnet-$pkgver.tar.xz")
sha256sums=('f8dcbba58d3479dfa4922146270f6ecb7ce0d987d82edc59b0c7c27ff965f65a')

build() {
  cmake -S "sonnet-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
