# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=gmp
pkgver=6.3.0
pkgrel=1
pkgdesc='GNU multiple precision arithmetic library (libgmp)'
arch=('x86_64')
url='https://gmplib.org/'
license=('LGPL-3.0-or-later' 'GPL-2.0-or-later')
depends=('glibc')
provides=('libgmp.so' 'libgmpxx.so')
# GNU mirror — gmplib.org is frequently flaky mid-download (SSL EOF).
source=("https://ftp.gnu.org/gnu/gmp/gmp-$pkgver.tar.xz")
sha256sums=('a3c2b80201b89e68616f4ad30bc66aee4927c3ce50e33929ca819d5c43538898')
build() {
  cd "$pkgname-$pkgver"
  # gmp 6.3.0's configure probes (the "long long reliability test") use
  # K&R-style declarations that GCC 16's default C23 mode rejects as hard
  # errors. Pin the C standard via CC so every probe inherits it.
  export CC="${CC:-gcc} -std=gnu17"
  # --enable-fat: runtime CPU dispatch so the binary runs on any x86-64.
  ./configure --prefix=/usr --enable-cxx --enable-fat
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
