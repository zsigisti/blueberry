# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=expat
pkgver=2.6.4
pkgrel=1
pkgdesc='Stream-oriented XML parser library (libexpat)'
arch=('x86_64')
url='https://libexpat.github.io/'
license=('MIT')
depends=('glibc')
provides=('libexpat.so')
source=("https://github.com/libexpat/libexpat/releases/download/R_${pkgver//./_}/expat-$pkgver.tar.xz")
sha256sums=('a695629dae047055b37d50a0ff4776d1d45d0a4c842cf4ccee158441f55ff7ee')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --without-docbook --disable-static
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
