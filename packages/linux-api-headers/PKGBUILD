# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# Sanitized Linux kernel headers (UAPI) for userspace compilation. Matches the
# Blueberry kernel (Linux 7.0). Half of the on-device dev SDK — pair with glibc.
pkgname=linux-api-headers
pkgver=7.0
pkgrel=1
pkgdesc='Sanitized kernel headers for userspace (UAPI), matching Linux 7.0'
arch=('x86_64')
url='https://www.kernel.org/'
license=('GPL-2.0-only WITH Linux-syscall-note')
makedepends=('rsync')
provides=('linux-headers')
_kmajor=7
source=("https://cdn.kernel.org/pub/linux/kernel/v${_kmajor}.x/linux-$pkgver.tar.xz")
sha256sums=('bb7f6d80b387c757b7d14bb93028fcb90f793c5c0d367736ee815a100b3891f0')
build() {
  cd "linux-$pkgver"
  make mrproper
}
package() {
  cd "linux-$pkgver"
  make INSTALL_HDR_PATH="$pkgdir/usr" headers_install
  # keep only the headers; drop the install bookkeeping files
  find "$pkgdir" \( -name '.install' -o -name '..install.cmd' \) -delete
}
