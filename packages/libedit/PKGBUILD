# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
#
# libedit — BSD line-editing library (readline-compatible API). Used by chrony's
# chronyc interactive prompt.
pkgname=libedit
pkgver=20240808_3.1
_distver=${pkgver/_/-}
pkgrel=1
pkgdesc='BSD command-line editing library (readline replacement)'
arch=('x86_64')
url='https://thrysoee.dk/editline/'
license=('BSD-3-Clause')
depends=('glibc' 'ncurses')
source=("https://thrysoee.dk/editline/libedit-$_distver.tar.gz")
sha256sums=('5f0573349d77c4a48967191cdd6634dd7aa5f6398c6a57fe037cc02696d6099f')

build() {
  cd "libedit-$_distver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "libedit-$_distver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
