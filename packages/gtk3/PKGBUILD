# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=gtk3
pkgver=3.24.52
pkgrel=1
pkgdesc='GTK 3 GUI toolkit (runtime for Firefox, Brave, Spotify, GTK apps)'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('cairo' 'pango' 'gdk-pixbuf2' 'at-spi2-core' 'glib2' 'libepoxy' 'fribidi' 'harfbuzz' 'libxcursor' 'libxcomposite' 'libxdamage' 'libxfixes' 'libxinerama' 'libxrandr' 'libxi' 'libxext' 'libxkbcommon' 'wayland' 'mesa' 'libcups' 'shared-mime-info' 'graphene' 'fontconfig' 'adwaita-icon-theme' )
makedepends=('meson' 'ninja' 'pkgconf' 'wayland-protocols' 'gtk-update-icon-cache' 'hicolor-icon-theme' )
options=('!lto')
source=("gtk-3.24.52.tar.xz::https://download.gnome.org/sources/gtk/3.24/gtk-3.24.52.tar.xz")
sha256sums=('80931fa472a77b9a164f6740e3c0b444fac6770054632d35a7ff9d679e5e7b9f')

build() {
  arch-meson() { meson setup "$@"; }
  meson setup gtk-3.24.52 build --prefix=/usr --buildtype=release -Dwerror=false -Dintrospection=false -Dman=false -Dtests=false -Ddemos=false -Dexamples=false -Dwayland_backend=true -Dx11_backend=true -Dcolord=no -Dcloudproviders=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
