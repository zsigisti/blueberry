# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libxrandr
pkgver=1.5.4
pkgrel=1
pkgdesc='X Resize and Rotate extension library'
arch=('x86_64')
url='https://gitlab.freedesktop.org/xorg/lib'
license=('MIT')
depends=('libxext' 'libxrender')
provides=('libXrandr.so')
makedepends=('xorg-util-macros' 'xorgproto' 'pkgconf')
source=("https://www.x.org/releases/individual/lib/libXrandr-1.5.4.tar.xz")
sha256sums=('1ad5b065375f4a85915aa60611cc6407c060492a214d7f9daf214be752c3b4d3')

build() {
  cd "libXrandr-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --disable-static
  make
}

package() {
  cd "libXrandr-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
