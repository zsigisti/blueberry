# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libxdmcp
pkgver=1.1.5
pkgrel=1
pkgdesc='X Display Manager Control Protocol library'
arch=('x86_64')
url='https://gitlab.freedesktop.org/xorg/lib'
license=('MIT')
depends=('glibc')
provides=('libXdmcp.so')
makedepends=('xorg-util-macros' 'xorgproto' 'pkgconf')
source=("https://www.x.org/releases/individual/lib/libXdmcp-1.1.5.tar.xz")
sha256sums=('d8a5222828c3adab70adf69a5583f1d32eb5ece04304f7f8392b6a353aa2228c')

build() {
  cd "libXdmcp-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --disable-static
  make
}

package() {
  cd "libXdmcp-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
