# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libtool
pkgver=2.5.4
pkgrel=1
pkgdesc='GNU libtool — provides libltdl (dynamic module loader for libcanberra)'
arch=('x86_64')
url='https://www.gnu.org/software/libtool'
license=('GPL-2.0-or-later')
depends=('glibc')
makedepends=('m4')
options=('!lto')
source=("https://ftp.gnu.org/gnu/libtool/libtool-${pkgver}.tar.xz")
sha256sums=('f81f5860666b0bc7d84baddefa60d1cb9fa6fceb2398cc3baca6afaa60266675')
build() { cd "libtool-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib; make; }
package() {
  cd "libtool-${pkgver}"
  make DESTDIR="$pkgdir" install
  # We only ship libltdl for the runtime closure; the libtool/m4 dev tooling is
  # not needed in the desktop image.
  rm -rf "$pkgdir/usr/bin" "$pkgdir/usr/share" 2>/dev/null || true
}
