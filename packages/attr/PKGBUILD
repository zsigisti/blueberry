# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=attr
pkgver=2.5.2
pkgrel=1
pkgdesc='Extended attribute support library for ACL'
arch=('x86_64')
url='https://savannah.nongnu.org/projects/attr'
license=('LGPL')
depends=('glibc')
provides=('libattr.so')
source=("https://download.savannah.nongnu.org/releases/attr/attr-$pkgver.tar.gz")
sha256sums=('39bf67452fa41d0948c2197601053f48b3d78a029389734332a6309a680c6c87')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --sysconfdir=/etc
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
