# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=json-c
pkgver=0.18
pkgrel=1
pkgdesc='JSON manipulation library (libjson-c) — LUKS2 metadata backend'
arch=('x86_64')
url='https://github.com/json-c/json-c'
license=('MIT')
depends=('glibc')
makedepends=('cmake')
provides=('libjson-c.so')
source=("https://s3.amazonaws.com/json-c_releases/releases/json-c-$pkgver.tar.gz")
sha256sums=('876ab046479166b869afc6896d288183bbc0e5843f141200c677b3e8dfb11724')
build() {
  # json-c's apps/CMakeLists.txt sets cmake_minimum_required < 3.5, which
  # CMake 4.x rejects; pin the policy version to configure anyway.
  cmake -S "json-c-$pkgver" -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
    -DBUILD_STATIC_LIBS=OFF \
    -DBUILD_TESTING=OFF
  cmake --build build
}
package() {
  DESTDIR="$pkgdir" cmake --install build
}
