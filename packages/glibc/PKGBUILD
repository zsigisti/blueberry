# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# The GNU C Library — full dev tree (headers + crt objects + linker scripts +
# static libs + the shared libraries). Version-matched to the runtime glibc
# that the base image bundles (2.43), so installing this completes the on-device
# dev SDK without an ABI mismatch. Pair with linux-api-headers + gcc + binutils.
pkgname=glibc
pkgver=2.43
pkgrel=1
pkgdesc='GNU C Library — headers, startup objects, and libraries (on-device SDK)'
arch=('x86_64')
url='https://www.gnu.org/software/libc/'
license=('GPL-2.0-or-later' 'LGPL-2.1-or-later')
depends=('linux-api-headers')
makedepends=('linux-api-headers' 'python')
# Keep the static libs: libc_nonshared.a is REQUIRED by the libc.so linker
# script, and crt*.o are needed to link anything. LTO breaks glibc's build.
options=('staticlibs' '!lto')
source=("https://ftp.gnu.org/gnu/glibc/glibc-$pkgver.tar.xz")
sha256sums=('d9c86c6b5dbddb43a3e08270c5844fc5177d19442cf5b8df4be7c07cd5fa3831')
build() {
  # glibc manages its own hardening; makepkg's fortify/format-security flags
  # conflict with its build, so strip them.
  CFLAGS="${CFLAGS//-Wp,-D_FORTIFY_SOURCE=3/}"
  CFLAGS="${CFLAGS//-Werror=format-security/}"
  export CFLAGS
  # glibc refuses an in-source build.
  mkdir -p build && cd build
  ../"glibc-$pkgver"/configure \
    --prefix=/usr \
    --libdir=/usr/lib \
    --libexecdir=/usr/lib \
    --with-headers=/usr/include \
    --enable-kernel=5.4 \
    --enable-cet \
    --enable-bind-now \
    --enable-stack-protector=strong \
    --disable-profile \
    --disable-werror \
    --without-selinux \
    --disable-nscd
  make
}
package() {
  cd build
  make install_root="$pkgdir" install
  # Trim docs; keep headers, crt objects, libraries, and the linker scripts.
  rm -rf "$pkgdir/usr/share/info" "$pkgdir/usr/share/man" "$pkgdir/usr/share/locale"
}
