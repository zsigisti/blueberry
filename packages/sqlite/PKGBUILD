# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=sqlite
pkgver=3.49.1
pkgrel=2
_srcver=3490100
pkgdesc='Self-contained, serverless, zero-configuration SQL database engine'
arch=('x86_64')
url='https://sqlite.org/'
license=('blessing')
# readline: the sqlite3 CLI links libreadline.so.8 for interactive line editing.
depends=('glibc' 'zlib' 'readline')
provides=('libsqlite3.so')
source=("https://sqlite.org/2025/sqlite-autoconf-$_srcver.tar.gz")
sha256sums=('106642d8ccb36c5f7323b64e4152e9b719f7c0215acf5bfeac3d5e7f97b59254')
build() {
  cd "sqlite-autoconf-$_srcver"
  ./configure --prefix=/usr --disable-static \
    CPPFLAGS="-DSQLITE_ENABLE_FTS5 -DSQLITE_ENABLE_RTREE -DSQLITE_ENABLE_COLUMN_METADATA"
  make
}
package() { cd "sqlite-autoconf-$_srcver"; make DESTDIR="$pkgdir" install; }
