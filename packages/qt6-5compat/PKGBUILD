# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-5compat
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 5 compatibility module for Qt 6 (Qt5Compat.GraphicalEffects, used by Plasma + Calamares)'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-declarative')
provides=('libQt6Core5Compat.so')
# qt6-shadertools: graphicaleffects5 compiles .frag shaders at build time.
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-shadertools' 'perl')
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qt5compat-everywhere-src-$pkgver.tar.xz")
sha256sums=('cfcb9fdaa051aad54b0e61b24ac5693b4887a86e07609f665fea67328a6f161b')

build() {
  cmake -S "qt5compat-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "qt5compat-everywhere-src-$pkgver/LICENSES/LGPL-3.0-only.txt" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
