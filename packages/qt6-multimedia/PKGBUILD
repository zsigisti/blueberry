# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qt6-multimedia
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 multimedia (audio/video/camera) module'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-declarative' 'qt6-shadertools' 'ffmpeg' 'libpulse' 'libva' 'pipewire' )
makedepends=('vulkan-headers' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'perl' 'qt6-shadertools' 'ffmpeg' 'pipewire')
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtmultimedia-everywhere-src-$pkgver.tar.xz")
sha256sums=('390f8e52ddee3aca5c4de7eead900c84c4fa61ff6d1f0ebea9c7543365c09b0a')

build() {
  cmake -S "qtmultimedia-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
