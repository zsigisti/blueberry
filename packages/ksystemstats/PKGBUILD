# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=ksystemstats
pkgver=6.7.0
pkgrel=1
pkgdesc='KDE: system statistics daemon'
arch=('x86_64')
url='https://kde.org/plasma-desktop/'
license=('GPL-2.0-or-later')
depends=('kcoreaddons' 'kcrash' 'ki18n' 'kio' 'libksysguard' 'lm_sensors' 'qt6-base' 'solid'  'networkmanager-qt')
makedepends=('networkmanager-qt' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-tools')
options=('!lto')
source=("https://download.kde.org/stable/plasma/6.7.0/ksystemstats-$pkgver.tar.xz")
sha256sums=('2224ce41e42e75845aa886e192e7833ce638b86aa31ca0e4e3cb31ef36e4066b')

build() {
  cmake -S "ksystemstats-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_LIBEXECDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
