# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# libdevmapper + dmsetup, built from the LVM2 source (just the device-mapper
# parts). Needed by cryptsetup to drive the kernel dm-crypt target.
pkgname=device-mapper
pkgver=2.03.30
pkgrel=1
pkgdesc='Device mapper userspace library and tool (libdevmapper, dmsetup)'
arch=('x86_64')
url='https://sourceware.org/lvm2/'
license=('GPL-2.0-only' 'LGPL-2.1-only')
depends=('glibc')
provides=('libdevmapper.so')
source=("https://sourceware.org/ftp/lvm2/LVM2.$pkgver.tgz")
sha256sums=('ad76abecb8dc887733e06c449cb9add04a3506f9f0780c128817a6e1a17cec05')
build() {
  cd "LVM2.$pkgver"
  ./configure \
    --prefix=/usr \
    --sbindir=/usr/bin \
    --with-default-dm-run-dir=/run \
    --enable-dmeventd=no \
    --disable-selinux \
    --enable-pkgconfig
  make device-mapper
}
package() {
  cd "LVM2.$pkgver"
  make install_device-mapper DESTDIR="$pkgdir"
}
