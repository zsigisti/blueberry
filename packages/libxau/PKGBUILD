# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=libxau
pkgver=1.0.11
pkgrel=1
pkgdesc='X11 authorization protocol library'
arch=('x86_64')
url='https://gitlab.freedesktop.org/xorg/lib'
license=('MIT')
depends=('glibc')
provides=('libXau.so')
makedepends=('xorg-util-macros' 'xorgproto' 'pkgconf')
source=("https://www.x.org/releases/individual/lib/libXau-1.0.11.tar.xz")
sha256sums=('f3fa3282f5570c3f6bd620244438dbfbdd580fc80f02f549587a0f8ab329bbeb')

build() {
  cd "libXau-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --disable-static
  make
}

package() {
  cd "libXau-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
