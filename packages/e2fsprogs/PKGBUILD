# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=e2fsprogs
pkgver=1.47.2
pkgrel=2
pkgdesc='Ext2/3/4 filesystem utilities (mkfs.ext4, e2fsck) + libext2fs/libcom_err'
arch=('x86_64')
url='https://e2fsprogs.sourceforge.net/'
license=('GPL-2.0-only' 'LGPL-2.0-only' 'MIT')
# util-linux is the canonical provider of libuuid/libblkid on Blueberry (systemd
# needs util-linux's libmount, which pairs with its libblkid). e2fsprogs builds
# --disable-libuuid/--disable-libblkid and links util-linux's instead, so the two
# packages no longer collide on libuuid.so.1 / libblkid.so.1.
depends=('glibc' 'util-linux')
provides=('libe2p.so' 'libext2fs.so' 'libcom_err.so' 'libss.so')
source=("https://mirrors.kernel.org/pub/linux/kernel/people/tytso/e2fsprogs/v$pkgver/e2fsprogs-$pkgver.tar.xz")
sha256sums=('08242e64ca0e8194d9c1caad49762b19209a06318199b63ce74ae4ef2d74e63c')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --with-root-prefix=/usr --enable-elf-shlibs \
    --disable-libuuid --disable-libblkid --disable-fsck --disable-uuidd
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}
