# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=fribidi
pkgver=1.0.16
pkgrel=1
pkgdesc='Unicode bidirectional algorithm library'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('glibc' )
makedepends=('meson' 'ninja' 'pkgconf' )
options=('!lto')
source=("fribidi-1.0.16.tar.xz::https://github.com/fribidi/fribidi/releases/download/v1.0.16/fribidi-1.0.16.tar.xz")
sha256sums=('1b1cde5b235d40479e91be2f0e88a309e3214c8ab470ec8a2744d82a5a9ea05c')

build() {
  arch-meson() { meson setup "$@"; }
  meson setup fribidi-1.0.16 build --prefix=/usr --buildtype=release -Dwerror=false -Ddocs=false -Dtests=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
