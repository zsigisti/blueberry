pkgname=libaio
pkgver=0.3.113
pkgrel=1
pkgdesc='Asynchronous I/O library'
arch=('x86_64')
url='https://pagure.io/libaio'
license=('LGPL-2.1-or-later')
depends=('glibc')
options=('!lto')
provides=('libaio.so')
source=("https://releases.pagure.org/libaio/libaio-$pkgver.tar.gz")
sha256sums=('2c44d1c5fd0d43752287c9ae1eb9c023f04ef848ea8d4aafa46e9aedb678200b')
build() { cd "$pkgname-$pkgver"; make prefix=/usr; }
package() { cd "$pkgname-$pkgver"; make prefix=/usr DESTDIR="$pkgdir" install; }
