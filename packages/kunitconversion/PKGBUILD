# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kunitconversion
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: unit conversion library'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' )
makedepends=('extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kunitconversion-$pkgver.tar.xz")
sha256sums=('404e064114c95eca0ef759b96ca4e0ba5f9b8bc563138574358270963f3f5554')

build() {
  cmake -S "kunitconversion-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
