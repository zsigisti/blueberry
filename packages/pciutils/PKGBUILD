# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=pciutils
pkgver=3.13.0
pkgrel=2
pkgdesc='PCI bus configuration space access library and tools (lspci, setpci)'
arch=('x86_64')
url='https://mj.ucw.cz/sw/pciutils/'
license=('GPL-2.0-or-later')
# kmod (libkmod): `lspci -k` maps devices to driver names. HWDB=no avoids the
# libudev hwdb lookup (Blueberry ships no hwdb and runs no udevd).
depends=('glibc' 'zlib' 'kmod')
provides=('libpci.so')
source=("https://mirrors.kernel.org/pub/software/utils/pciutils/pciutils-$pkgver.tar.xz")
sha256sums=('77f11f78298502634d1af50308f15a5788629f6cf45cba376f5009aea4cb4926')
build() {
  cd "$pkgname-$pkgver"
  make PREFIX=/usr SHARED=yes ZLIB=yes HWDB=no LIBKMOD=yes
}
package() {
  cd "$pkgname-$pkgver"
  make PREFIX=/usr DESTDIR="$pkgdir" SHARED=yes ZLIB=yes HWDB=no LIBKMOD=yes \
    install install-lib
}
