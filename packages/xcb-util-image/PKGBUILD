# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=xcb-util-image
pkgver=0.4.1
pkgrel=1
pkgdesc='XCB utility library: xcb-util-image'
arch=('x86_64')
url='https://xcb.freedesktop.org/'
license=('MIT')
depends=('libxcb' 'xcb-util')
provides=('libxcb-image.so')
makedepends=('xcb-proto' 'xorgproto' 'xorg-util-macros' 'libxcb' 'pkgconf' 'gperf')
source=("https://xorg.freedesktop.org/archive/individual/lib/xcb-util-image-0.4.1.tar.xz")
sha256sums=('ccad8ee5dadb1271fd4727ad14d9bd77a64e505608766c4e98267d9aede40d3d')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
