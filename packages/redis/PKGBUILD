# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=redis
pkgver=7.4.2
pkgrel=3
pkgdesc='In-memory data structure store, used as database, cache and message broker'
arch=('x86_64')
url='https://redis.io/'
license=('BSD-3-Clause')
depends=('glibc')
source=("https://download.redis.io/releases/redis-$pkgver.tar.gz")
sha256sums=('4ddebbf09061cbb589011786febdb34f29767dd7f89dbe712d2b68e808af6a1f')
# USE_SYSTEMD=no: don't link libsystemd for sd_notify — Blueberry runs runit,
# not systemd, so the notify socket is never present and the call is a no-op.
build() { cd "$pkgname-$pkgver"; make MALLOC=libc USE_SYSTEMD=no; }
package() {
  cd "$pkgname-$pkgver"
  # redis's install target doesn't honour DESTDIR; point PREFIX at the pkgdir.
  make PREFIX="$pkgdir/usr" install
  install -Dm644 redis.conf "$pkgdir/etc/redis/redis.conf"
  # runit service (disabled until `sv-enable redis`).
  install -dm755 "$pkgdir/etc/sv/redis"
  printf '#!/bin/sh\nexec /usr/bin/redis-server /etc/redis/redis.conf --daemonize no\n' \
    > "$pkgdir/etc/sv/redis/run"
  chmod 755 "$pkgdir/etc/sv/redis/run"
}
