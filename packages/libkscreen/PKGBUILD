# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libkscreen
pkgver=6.7.0
pkgrel=1
pkgdesc='KDE: screen management library'
arch=('x86_64')
url='https://kde.org/plasma-desktop/'
license=('GPL-2.0-or-later')
depends=('libxcb' 'qt6-base' 'qt6-declarative' 'wayland' 'kconfig' 'kwayland' )
makedepends=('extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-tools' 'wayland-protocols' 'plasma-wayland-protocols' 'qt6-wayland' )
options=('!lto')
source=("https://download.kde.org/stable/plasma/6.7.0/libkscreen-$pkgver.tar.xz")
sha256sums=('6efba58057a2635da6f1855ba6b08e57e636c976421ba5e3f5f667e6a57b0ce1')

build() {
  cmake -S "libkscreen-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_LIBEXECDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
