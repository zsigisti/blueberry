# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=polkit-kde-agent-1
pkgver=6.7.0
pkgrel=1
pkgdesc='KDE: PolicyKit authentication agent (password prompts)'
arch=('x86_64')
url='https://kde.org/plasma-desktop/'
license=('GPL-2.0-or-later')
depends=('kcoreaddons' 'kcrash' 'kdbusaddons' 'ki18n' 'kiconthemes' 'kwidgetsaddons' 'kwindowsystem' 'knotifications' 'polkit-qt6' 'qt6-base' 'qt6-declarative' )
makedepends=('extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' 'qt6-tools' 'polkit-qt6' )
options=('!lto')
source=("https://download.kde.org/stable/plasma/6.7.0/polkit-kde-agent-1-$pkgver.tar.xz")
sha256sums=('0f27ff2aa3610418620c42804b9c3dc22f6979e5c03822f93979d44fbed1dabf')

build() {
  cmake -S "polkit-kde-agent-1-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_LIBEXECDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
