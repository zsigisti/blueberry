# libnfnetlink — low-level netlink helper for the netfilter libraries. Required
# by libnetfilter_conntrack and the legacy iptables conntrack matches.
pkgname=libnfnetlink
pkgver=1.0.2
pkgrel=1
pkgdesc='Low-level library for netfilter related kernel/userspace communication'
arch=('x86_64')
url='https://www.netfilter.org/projects/libnfnetlink/'
license=('GPL-2.0-only')
depends=('glibc')
source=("https://www.netfilter.org/projects/libnfnetlink/files/libnfnetlink-$pkgver.tar.bz2")
sha256sums=('b064c7c3d426efb4786e60a8e6859b82ee2f2c5e49ffeea640cfe4fe33cbc376')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
