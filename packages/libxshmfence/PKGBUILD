# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libxshmfence
pkgver=1.3.3
pkgrel=1
pkgdesc='Shared-memory fence library (DRI3/mesa)'
arch=('x86_64')
url='https://gitlab.freedesktop.org/xorg/lib/libxshmfence'
license=('MIT')
depends=('glibc')
provides=('libxshmfence.so')
makedepends=('xorg-util-macros' 'xorgproto' 'pkgconf')
source=("https://www.x.org/releases/individual/lib/libxshmfence-$pkgver.tar.xz")
sha256sums=('d4a4df096aba96fea02c029ee3a44e11a47eb7f7213c1a729be83e85ec3fde10')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static --enable-futex
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
