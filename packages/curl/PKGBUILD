# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=curl
pkgver=8.11.1
pkgrel=1
pkgdesc='Command-line tool and library for transferring data with URLs'
arch=('x86_64')
url='https://curl.se/'
license=('MIT')
depends=('glibc' 'ca-certificates' 'zlib' 'zstd' 'openssl' 'brotli')
makedepends=('pkgconf')
provides=('libcurl.so')
source=("https://curl.se/download/curl-$pkgver.tar.xz")
sha256sums=('c7ca7db48b0909743eaef34250da02c19bc61d4f1dcedd6603f109409536ab56')

build() {
  cd "$pkgname-$pkgver"
  # Pin the feature set so the dependency closure is deterministic (only what
  # Blueberry packages). IDN and public-suffix are dropped; HTTP/2, TLS and
  # zlib/zstd/brotli compression are kept.
  ./configure \
    --prefix=/usr \
    --mandir=/usr/share/man \
    --disable-static \
    --with-openssl \
    --with-ca-bundle=/etc/ssl/certs/ca-certificates.crt \
    --enable-threaded-resolver \
    --with-zlib \
    --with-zstd \
    --with-brotli \
    --without-nghttp2 \
    --without-libpsl \
    --without-libidn2 \
    --without-libssh2 \
    --without-gssapi \
    --without-librtmp \
    --disable-ldap --disable-ldaps
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
