# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=keyutils
pkgver=1.6.3
pkgrel=1
pkgdesc='Linux key management utilities (libkeyutils — krb5/gssapi)'
arch=('x86_64')
url='https://www.kernel.org/'
license=('GPL-2.0-or-later' 'LGPL-2.1-or-later')
depends=('glibc')
options=('!lto')
source=("keyutils-${pkgver}.tar.gz::https://git.kernel.org/pub/scm/linux/kernel/git/dhowells/keyutils.git/snapshot/keyutils-${pkgver}.tar.gz")
sha256sums=('a61d5706136ae4c05bd48f86186bcfdbd88dd8bd5107e3e195c924cfc1b39bb4')
build() { cd "keyutils-${pkgver}"; make NO_ARLIB=1 LIBDIR=/usr/lib USRLIBDIR=/usr/lib BINDIR=/usr/bin SBINDIR=/usr/bin; }
package() { cd "keyutils-${pkgver}"; make NO_ARLIB=1 LIBDIR=/usr/lib USRLIBDIR=/usr/lib BINDIR=/usr/bin SBINDIR=/usr/bin DESTDIR="$pkgdir" install; }
