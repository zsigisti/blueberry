# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=mtdev
pkgver=1.1.7
pkgrel=1
pkgdesc='Multitouch protocol translation library (KWin/libinput)'
arch=('x86_64')
url='https://bitmath.org/code/mtdev/'
license=('MIT')
depends=('glibc')
options=('!lto')
source=("https://bitmath.org/code/mtdev/mtdev-${pkgver}.tar.bz2")
sha256sums=('a107adad2101fecac54ac7f9f0e0a0dd155d954193da55c2340c97f2ff1d814e')
build() { cd "mtdev-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib --disable-static; make; }
package() { cd "mtdev-${pkgver}"; make DESTDIR="$pkgdir" install; }
