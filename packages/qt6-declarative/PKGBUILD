# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=qt6-declarative
pkgver=6.11.1
pkgrel=1
pkgdesc='Qt 6 QML and Quick: the declarative UI engine behind Plasma and SDDM greeters'
arch=('x86_64')
url='https://www.qt.io/'
license=('LGPL-3.0-only')
depends=('qt6-base' 'qt6-shadertools')
provides=('libQt6Qml.so' 'libQt6Quick.so' 'libQt6QuickControls2.so'
          'libQt6QuickWidgets.so' 'libQt6QuickShapes.so' 'libQt6QuickTemplates2.so'
          'libQt6QmlModels.so' 'libQt6QmlWorkerScript.so' 'libQt6LabsQmlModels.so')
# qt6-base/qt6-shadertools pulled from Arch repos at build; Blueberry mirror at install.
makedepends=('cmake' 'ninja' 'python' 'qt6-base' 'qt6-shadertools'
             'vulkan-headers' 'perl')
options=('!lto')
source=("https://download.qt.io/official_releases/qt/${pkgver%.*}/$pkgver/submodules/qtdeclarative-everywhere-src-$pkgver.tar.xz")
sha256sums=('52e670f670b0304f534b24f98c47ceb8a41bb710464414ebc9527ec71cc86aa4')

build() {
  cmake -S "qtdeclarative-everywhere-src-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D INSTALL_LIBDIR=/usr/lib \
    -D INSTALL_ARCHDATADIR=/usr/lib/qt6 \
    -D QT_BUILD_EXAMPLES=OFF \
    -D QT_BUILD_TESTS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "qtdeclarative-everywhere-src-$pkgver/LICENSES/LGPL-3.0-only.txt" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
