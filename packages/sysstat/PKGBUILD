# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=sysstat
pkgver=12.7.6
pkgrel=1
pkgdesc='System performance tools (sar, iostat, mpstat, pidstat)'
arch=('x86_64')
url='https://github.com/sysstat/sysstat'
license=('GPL-2.0-or-later')
depends=('glibc')
source=("https://github.com/sysstat/sysstat/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('dc77a08871f8e8813448ea31048833d4acbab7276dd9a456cd2526c008bd5301')
build() {
  cd "$pkgname-$pkgver"
  sa_lib_dir=/usr/lib/sa conf_dir=/etc ./configure --prefix=/usr --disable-sensors
  make
}
package() { cd "$pkgname-$pkgver"; make DESTDIR="$pkgdir" install; }
