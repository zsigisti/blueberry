# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=kpackage
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: installing and loading content packages'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'karchive' 'kconfig' 'kcoreaddons' 'ki18n' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kpackage-$pkgver.tar.xz")
sha256sums=('5fa4b07f729c3ff6b7f362d318374810fa55b13a922d2b240462eb8efc1045e8')

build() {
  cmake -S "kpackage-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
