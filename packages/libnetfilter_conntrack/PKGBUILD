# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# libnetfilter_conntrack — userspace API to the in-kernel connection tracking
# table. Needed by iptables' conntrack/state/NAT-helper matches.
pkgname=libnetfilter_conntrack
pkgver=1.0.9
pkgrel=1
pkgdesc='Userspace library for the in-kernel connection tracking state table'
arch=('x86_64')
url='https://www.netfilter.org/projects/libnetfilter_conntrack/'
license=('GPL-2.0-or-later')
depends=('glibc' 'libnfnetlink' 'libmnl')
makedepends=('pkgconf')
source=("https://www.netfilter.org/projects/libnetfilter_conntrack/files/libnetfilter_conntrack-$pkgver.tar.bz2")
sha256sums=('67bd9df49fe34e8b82144f6dfb93b320f384a8ea59727e92ff8d18b5f4b579a8')

build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --disable-static
  make
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
