# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=knewstuff
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: framework for downloadable content (Get Hot New Stuff)'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'qt6-declarative' 'attica' 'karchive' 'kcompletion' 'kconfig' 'kconfigwidgets' 'kcoreaddons' 'ki18n' 'kio' 'kirigami' 'kitemviews' 'kpackage' 'kservice' 'kwidgetsaddons' 'kxmlgui' 'syndication' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base' 'qt6-declarative' )
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/knewstuff-$pkgver.tar.xz")
sha256sums=('8c19df7ba5940c36ff15051703acd3a16c664b4a570817b6770fafc7ab59d6de')

build() {
  cmake -S "knewstuff-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
