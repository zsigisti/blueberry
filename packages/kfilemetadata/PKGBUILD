# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=kfilemetadata
pkgver=6.27.0
pkgrel=1
pkgdesc='KDE: file metadata extraction'
arch=('x86_64')
url='https://community.kde.org/Frameworks'
license=('LGPL-2.1-or-later')
depends=('qt6-base' 'karchive' 'kconfig' 'kcoreaddons' 'ki18n' )
makedepends=('qt6-tools' 'qt6-declarative' 'extra-cmake-modules' 'cmake' 'ninja' 'python' 'qt6-base')
options=('!lto')
source=("https://download.kde.org/stable/frameworks/${pkgver%.*}/kfilemetadata-$pkgver.tar.xz")
sha256sums=('27f68558259394ad84d357aa316821672ee66481fa851ddf2a6109f668a6c6a3')

build() {
  cmake -S "kfilemetadata-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D KDE_INSTALL_LIBDIR=lib \
    -D KDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -D BUILD_TESTING=OFF \
    -D BUILD_QCH=OFF \
    -D BUILD_PYTHON_BINDINGS=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
