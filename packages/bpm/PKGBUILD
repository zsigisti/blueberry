# Maintainer: Blueberry Linux <packages@blueberry.linux>
#
# bpm packages itself so a running system can self-update:  bpm install bpm.
# Source is the in-tree Rust crate src/bpm-rs (the streaming rewrite); built in
# the same container as every other package. The old binary can always install
# this one — it is small — so even a memory-starved bpm can pull a fixed bpm.
pkgname=bpm
pkgver=1.6.0
pkgrel=1
pkgdesc='Blueberry Package Manager — streaming installs, SHA-256 verified, post-install hooks (Rust)'
arch=('x86_64')
url='https://github.com/zsigisti/blueberry'
license=('MIT')
depends=('glibc' 'gcc-libs')
makedepends=('rust')
# makepkg's global LTO turns zstd-sys's C objects into LTO bitcode that clashes
# with the crate's own (Cargo.toml) LTO at link time — lld bails with "too many
# errors". Cargo already does release LTO internally, so just opt out of
# makepkg's.
options=('!lto')
# No source=(): built from the repo tree mounted into the build container.

build() {
  rm -rf bpmsrc
  cp -r "$startdir/../../src/bpm-rs" bpmsrc
  cd bpmsrc
  export CARGO_HOME="$srcdir/cargo"
  cargo build --release --locked
}

package() {
  install -Dm755 "$srcdir/bpmsrc/target/release/bpm" "$pkgdir/usr/bin/bpm"
  # Ship the default repo + provided config as references (don't clobber a
  # user's edited /etc copies — keep these under /usr/share).
  install -Dm644 "$startdir/../../etc/bpm/repos.conf" "$pkgdir/usr/share/bpm/repos.conf"
  install -Dm644 "$startdir/../../etc/bpm/provided"   "$pkgdir/usr/share/bpm/provided"
}
