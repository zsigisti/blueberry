# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libgudev
pkgver=238
pkgrel=1
pkgdesc='GObject bindings for libudev (libwacom)'
arch=('x86_64')
url='https://gitlab.gnome.org/GNOME/libgudev'
license=('LGPL-2.1-or-later')
depends=('glibc' 'glib2' 'systemd-libs')
makedepends=('meson' 'ninja' 'pkgconf' 'glib2' 'glib2-devel')
options=('!lto')
source=("https://download.gnome.org/sources/libgudev/${pkgver}/libgudev-${pkgver}.tar.xz")
sha256sums=('61266ab1afc9d73dbc60a8b2af73e99d2fdff47d99544d085760e4fa667b5dd1')
build() { meson setup "libgudev-${pkgver}" build --prefix=/usr --libdir=/usr/lib --buildtype=release -Dtests=disabled -Dvapi=disabled -Dintrospection=disabled; ninja -C build; }
package() { DESTDIR="$pkgdir" ninja -C build install; }
