# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# libgomp (GNU OpenMP runtime) split from the GCC sources. Kirigami and a few
# KDE libs link libgomp.so.1; the base gcc-libs ships only libgcc_s/libstdc++,
# so we build libgomp from the same GCC 16.1.0 tree (self-hosted, no Arch bins).
pkgname=libgomp
pkgver=16.1.0
pkgrel=1
pkgdesc='GNU OpenMP runtime library (libgomp.so.1 — Kirigami/KDE)'
arch=('x86_64')
url='https://gcc.gnu.org/'
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later')
depends=('glibc')
makedepends=('binutils' 'gmp' 'mpfr' 'mpc' 'zlib')
options=('!lto')
source=("https://ftp.gnu.org/gnu/gcc/gcc-$pkgver/gcc-$pkgver.tar.xz")
sha256sums=('50efb4d94c3397aff3b0d61a5abd748b4dd31d9d3f2ab7be05b171d36a510f79')
build() {
  CFLAGS="${CFLAGS//-Werror=format-security/}"
  CXXFLAGS="${CXXFLAGS//-Werror=format-security/}"
  export CFLAGS CXXFLAGS
  mkdir -p build && cd build
  ../"gcc-$pkgver"/configure \
    --prefix=/usr --libdir=/usr/lib --libexecdir=/usr/lib \
    --enable-languages=c --disable-multilib --disable-bootstrap \
    --disable-werror --disable-nls --without-isl --with-system-zlib
  # Build the stage-1 C compiler then only the libgomp target library.
  make all-target-libgomp
}
package() {
  cd build
  make DESTDIR="$pkgdir" install-target-libgomp
  # Keep only the shared runtime; drop static archive, headers, .la, gcc spec.
  find "$pkgdir" -name 'libgomp.a' -o -name 'libgomp.la' -o -name '*.h' -o -name '*.spec' | xargs -r rm -f
  rm -rf "$pkgdir/usr/lib/gcc" "$pkgdir/usr/share" 2>/dev/null || true
  # Ensure the versioned soname symlinks live in /usr/lib.
  install -d "$pkgdir/usr/lib"
}
