# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libvorbis
pkgver=1.3.7
pkgrel=1
pkgdesc='Vorbis audio codec (libvorbisfile — libcanberra event sounds)'
arch=('x86_64')
url='https://www.xiph.org/vorbis/'
license=('BSD-3-Clause')
depends=('glibc' 'libogg')
makedepends=('libogg')
options=('!lto')
source=("https://downloads.xiph.org/releases/vorbis/libvorbis-${pkgver}.tar.xz")
sha256sums=('b33cc4934322bcbf6efcbacf49e3ca01aadbea4114ec9589d1b1e9d20f72954b')
build() { cd "libvorbis-${pkgver}"; ./configure --prefix=/usr --libdir=/usr/lib; make; }
package() { cd "libvorbis-${pkgver}"; make DESTDIR="$pkgdir" install; }
