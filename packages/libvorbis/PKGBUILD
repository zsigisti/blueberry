# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libvorbis
pkgver=1.3.7
pkgrel=1
pkgdesc='Vorbis audio codec (libvorbisfile — libcanberra event sounds)'
arch=('x86_64')
url='https://www.xiph.org/vorbis/'
license=('BSD-3-Clause')
depends=('glibc' 'libogg')
makedepends=('libogg')
options=('!lto')
source=("https://downloads.xiph.org/releases/vorbis/libvorbis-${pkgver}.tar.xz")
sha256sums=('b33cc4934322bcbf6efcbacf49e3ca01aadbea4114ec9589d1b1e9d20f72954b')
build() {
  cd "libvorbis-${pkgver}"
  # Disable auto-vectorised libm calls so libvorbis.so.0 does not pull glibc's
  # libmvec.so.1 — the base (source-built) glibc in the rootfs ships no libmvec.
  export CFLAGS="$CFLAGS -fno-tree-vectorize -fno-tree-slp-vectorize"
  ./configure --prefix=/usr --libdir=/usr/lib
  make
}
package() { cd "libvorbis-${pkgver}"; make DESTDIR="$pkgdir" install; }
