pkgname=libimobiledevice
pkgver=1.4.0
pkgrel=1
pkgdesc='Library to communicate with Apple iOS devices (kio-extras)'
arch=('x86_64')
url='https://libimobiledevice.org/'
license=('LGPL-2.1-or-later')
depends=('glibc' 'libplist' 'libusbmuxd' 'openssl')
makedepends=('libplist' 'libusbmuxd' 'openssl' 'cython' 'python')
options=('!lto')
source=("libimobiledevice-1.4.0.tar.bz2::https://github.com/libimobiledevice/libimobiledevice/releases/download/1.4.0/libimobiledevice-1.4.0.tar.bz2")
sha256sums=('23cc0077e221c7d991bd0eb02150a0d49199bcca1ddf059edccee9ffd914939d')
build() { cd "libimobiledevice-$pkgver"; ./configure --prefix=/usr --libdir=/usr/lib --without-cython; make; }
package() { cd "libimobiledevice-$pkgver"; make DESTDIR="$pkgdir" install; }
