# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
# GNU coreutils — the essential cat/ls/cp/tail/tty/env/sleep/... binaries. The
# systemd base dropped busybox, so without this package the system has no core
# command-line utilities (KDE/Plasma startup shells out to them).
pkgname=coreutils
pkgver=9.7
pkgrel=1
pkgdesc='The basic file, shell and text manipulation utilities of the GNU OS'
arch=('x86_64')
url='https://www.gnu.org/software/coreutils/'
license=('GPL-3.0-or-later')
depends=('glibc' 'libcap' 'openssl' 'gmp')
source=("https://ftp.gnu.org/gnu/coreutils/coreutils-$pkgver.tar.xz")
sha256sums=('SKIP')
build() {
  cd "$pkgname-$pkgver"
  # Allow configure to proceed under the container's root build user.
  export FORCE_UNSAFE_CONFIGURE=1
  export CFLAGS="${CFLAGS:-} -std=gnu17"
  ./configure --prefix=/usr --libexecdir=/usr/lib \
    --enable-no-install-program=kill,uptime \
    --with-openssl
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  # Provide the historical /bin paths a few scripts still hard-code.
  install -d "$pkgdir/bin"
  for b in cat ls cp mv rm ln mkdir rmdir echo pwd sleep env tty head tail \
           chmod chown chgrp date stat readlink basename dirname mktemp; do
    [ -e "$pkgdir/usr/bin/$b" ] && ln -sf "../usr/bin/$b" "$pkgdir/bin/$b"
  done
}
