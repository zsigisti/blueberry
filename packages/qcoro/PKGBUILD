# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=qcoro
pkgver=0.13.0
pkgrel=1
pkgdesc='C++ coroutines for Qt 6 (used by powerdevil, plasma-nm, plasma-workspace)'
arch=('x86_64')
url='https://qcoro.dev/'
license=('MIT')
depends=('qt6-base')
provides=('qcoro6')
makedepends=('cmake' 'ninja' 'qt6-base' 'qt6-declarative' 'qt6-websockets')
options=('!lto')
source=("https://github.com/qcoro/qcoro/archive/v$pkgver/qcoro-$pkgver.tar.gz")
sha256sums=('4bff7513c5c8e301b66308df05795043b1792ed16381a484e5c990171b8ff19e')

build() {
  cmake -S "qcoro-$pkgver" -B build -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D QCORO_BUILD_EXAMPLES=OFF \
    -D QCORO_WITH_QTWEBSOCKETS=OFF \
    -D BUILD_TESTING=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
