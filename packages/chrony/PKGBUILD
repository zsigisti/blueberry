# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=chrony
pkgver=4.6.1
pkgrel=3
pkgdesc='Versatile implementation of the Network Time Protocol (NTP)'
arch=('x86_64')
url='https://chrony-project.org/'
license=('GPL-2.0-only')
# libedit: chronyc's interactive line editing (configure auto-detects editline
# since readline is disabled); the binary links libedit.so.0.
depends=('glibc' 'libcap' 'libedit')
source=("https://chrony-project.org/releases/chrony-$pkgver.tar.gz")
sha256sums=('571ff73fbf0ae3097f0604eca2e00b1d8bb2e91affe1a3494785ff21d6199c5c')
build() {
  cd "$pkgname-$pkgver"
  ./configure --prefix=/usr --sysconfdir=/etc --without-readline --without-nettle \
    --without-gnutls --without-nss --without-seccomp --disable-sechash
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  # runit service (disabled until `sv-enable chrony`); -d runs in the foreground.
  install -dm755 "$pkgdir/etc/sv/chrony"
  printf '#!/bin/sh\nexec /usr/bin/chronyd -d\n' > "$pkgdir/etc/sv/chrony/run"
  chmod 755 "$pkgdir/etc/sv/chrony/run"
}
