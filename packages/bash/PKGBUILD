# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=bash
pkgver=5.2.37
pkgrel=1
pkgdesc='The GNU Bourne Again shell'
arch=('x86_64')
url='https://www.gnu.org/software/bash/bash.html'
license=('GPL-3.0-or-later')
depends=('glibc' 'ncurses')
provides=('sh')
source=("https://mirrors.kernel.org/gnu/bash/bash-$pkgver.tar.gz")
sha256sums=('9599b22ecd1d5787ad7d3b7bf0c59f312b3396d1e281175dd1f8a4014da621ff')
build() {
  cd "$pkgname-$pkgver"
  # 5.2.37 has K&R-style declarations GCC 16's default C23 mode rejects.
  export CFLAGS="${CFLAGS:-} -std=gnu17"
  ./configure --prefix=/usr --without-bash-malloc --with-curses \
    --enable-readline --with-installed-readline=no
  make
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
  mkdir -p "$pkgdir/bin"
  ln -sf ../usr/bin/bash "$pkgdir/bin/bash"
  # Honour provides=(sh): the systemd base has no busybox to supply sh, so
  # #!/bin/sh scripts (SDDM's wayland-session, plasma-dbus-run-session) need it.
  ln -sf bash "$pkgdir/usr/bin/sh"
  ln -sf ../usr/bin/bash "$pkgdir/bin/sh"
}
