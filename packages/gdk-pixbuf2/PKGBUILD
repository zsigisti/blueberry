# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=gdk-pixbuf2
pkgver=2.44.6
pkgrel=1
pkgdesc='Image loading and manipulation library for GTK'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('glib2' 'libpng' 'libjpeg-turbo' 'libtiff' 'shared-mime-info' )
makedepends=('meson' 'ninja' 'pkgconf' 'python' )
options=('!lto')
source=("gdk-pixbuf-2.44.6.tar.xz::https://download.gnome.org/sources/gdk-pixbuf/2.44/gdk-pixbuf-2.44.6.tar.xz")
sha256sums=('140c2d0b899fcf853ee92b26373c9dc228dbcde0820a4246693f4328a27466fa')

build() {
  arch-meson() { meson setup "$@"; }
  meson setup gdk-pixbuf-2.44.6 build --prefix=/usr --buildtype=release -Dwerror=false -Dintrospection=disabled -Dman=false -Ddocs=false -Dtests=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
