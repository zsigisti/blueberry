# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=wayland
pkgver=1.25.0
pkgrel=1
pkgdesc='A protocol for a compositor to talk to its clients'
arch=('x86_64')
url='https://wayland.freedesktop.org/'
license=('MIT')
depends=('libffi' 'libxml2' 'glibc')
provides=('libwayland-client.so' 'libwayland-cursor.so' 'libwayland-egl.so' 'libwayland-server.so')
makedepends=('meson' 'ninja')
source=("https://gitlab.freedesktop.org/wayland/wayland/-/releases/$pkgver/downloads/wayland-$pkgver.tar.xz")
sha256sums=('c065f040afdff3177680600f249727e41a1afc22fccf27222f15f5306faa1f03')

build() {
  arch-meson "$pkgname-$pkgver" build \
    -D documentation=false -D tests=false
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$pkgname-$pkgver/COPYING" "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}
