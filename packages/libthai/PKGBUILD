# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=libthai
pkgver=0.1.30
pkgrel=1
pkgdesc='Thai language support library'
arch=('x86_64')
url='https://www.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=('libdatrie' 'glibc' )
makedepends=('pkgconf' 'libdatrie' )
options=('!lto')
source=("libthai-0.1.30.tar.xz::https://github.com/tlwg/libthai/releases/download/v0.1.30/libthai-0.1.30.tar.xz")
sha256sums=('ddba8b53dfe584c3253766030218a88825488a51a7deef041d096e715af64bdd')

build() {
  cd "libthai-0.1.30"
  ./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var 
  make
}

package() {
  cd "libthai-0.1.30"; make DESTDIR="$pkgdir" install
}
