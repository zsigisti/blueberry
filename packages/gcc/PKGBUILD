# Maintainer: Blueberry Linux <blueberry@mmzsigmond.me>
pkgname=gcc
pkgver=16.1.0
pkgrel=2
pkgdesc='The GNU Compiler Collection (C and C++)'
arch=('x86_64')
url='https://gcc.gnu.org/'
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later' 'GFDL-1.3-or-later')
# gmp/mpfr/mpc are needed at runtime by cc1; binutils provides as/ld.
# linux-api-headers ships the kernel UAPI headers gcc needs to compile C
# (glibc is "provided" by the base image's runtime; install it explicitly —
# `bpm install gcc glibc` — to also get glibc's headers + crt objects).
# Built --without-isl so cc1 has no external libisl dependency (no Graphite).
depends=('glibc' 'binutils' 'gmp' 'mpfr' 'mpc' 'zlib' 'linux-api-headers')
# LTO isn't needed to build the compiler and only slows the build.
options=('!lto')
source=("https://ftp.gnu.org/gnu/gcc/gcc-$pkgver/gcc-$pkgver.tar.xz")
sha256sums=('50efb4d94c3397aff3b0d61a5abd748b4dd31d9d3f2ab7be05b171d36a510f79')
build() {
  cd "$pkgname-$pkgver"
  # makepkg defaults to -Werror=format-security, which gcc 16's own libcpp
  # (expr.cc) trips over while bootstrapping — strip it for this build.
  CFLAGS="${CFLAGS//-Werror=format-security/}"
  CXXFLAGS="${CXXFLAGS//-Werror=format-security/}"
  export CFLAGS CXXFLAGS
  # gcc refuses an in-source build; use a sibling build dir.
  mkdir -p ../build && cd ../build
  ../"$pkgname-$pkgver"/configure \
    --prefix=/usr \
    --libdir=/usr/lib \
    --libexecdir=/usr/lib \
    --enable-languages=c,c++ \
    --enable-default-pie \
    --enable-default-ssp \
    --enable-__cxa_atexit \
    --disable-multilib \
    --disable-bootstrap \
    --disable-werror \
    --disable-nls \
    --without-isl \
    --with-system-zlib
  make
}
package() {
  cd build
  make DESTDIR="$pkgdir" install
  # Provide the conventional `cc` alias.
  ln -sf gcc "$pkgdir/usr/bin/cc"
  # Trim large dev/doc artefacts to keep the package lean.
  rm -rf "$pkgdir"/usr/share/man/man7 "$pkgdir"/usr/share/info
}
