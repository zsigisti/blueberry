# Maintainer: Blueberry Linux <packages@blueberry.linux>
pkgname=mdadm
pkgver=4.4
pkgrel=2
pkgdesc='Tool for managing Linux software RAID arrays'
arch=('x86_64')
url='https://kernel.org/'
license=('GPL-2.0-or-later')
# eudev (libudev): mdadm links libudev for array/device event handling.
depends=('glibc' 'eudev')
options=('!lto')
source=("https://www.kernel.org/pub/linux/utils/raid/mdadm/mdadm-$pkgver.tar.xz")
sha256sums=('9b488f35ed153df99924b5fe41eed380e8512de8f18a118628cacdd681b1d573')
build() {
  cd "$pkgname-$pkgver"
  # mdadm's CWFLAGS hard-codes -Werror; gcc 16 turns new warnings into errors,
  # so drop -Werror. Functional -D defines live in the Makefile's own CFLAGS.
  make CXFLAGS="$CFLAGS" CWFLAGS="-Wall"
}
package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" BINDIR=/usr/bin install
}
