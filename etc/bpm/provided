# Packages whose shared libraries / files the Blueberry base image already ships.
# A dep named here is treated as satisfied and is NOT installed, so packages
# don't try to reinstall what the base already provides. One name per line;
# #comments and blanks ignored. The built-in list in bpm's is_provided() (glibc,
# gcc-libs, bash, coreutils, ...) is EXTENDED by this file.
#
# xz / zstd / lz4 are now proper tracked base packages (they ship their own CLI +
# liblzma/libzstd/liblz4), so they are NOT listed here anymore — bpm can upgrade
# them. ca-certificates left for the same reason: the image used to copy the host's
# bundle and claim the dep satisfied, but that only produced
# /etc/ssl/certs/ca-certificates.crt — not /etc/ssl/cert.pem (OpenSSL's default
# CAfile), so python/pip/bpmbuild trusted nothing. It is a real base package now.
# Only genuinely non-package bits remain:
#   libz.so.1  -> zlib  (zlib is also a tracked base package; kept for safety)
zlib
# The systemd base package ships libsystemd.so.0 + libudev.so.1 into the rootfs,
# so anything depending on systemd-libs (libgudev, libpulse, …) is satisfied.
systemd-libs

# glibc provides argp (argp.h / argp_parse); argp-standalone is a musl-only shim.
argp-standalone
