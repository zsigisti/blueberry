# Blueberry — console/serial login (util-linux `login`, incl. agetty --autologin).
# Everything routes through the shared system-auth stack.
auth      include    system-auth
account   include    system-auth
password  include    system-auth
session   include    system-auth
# NOTE: no pam_motd here — util-linux `login` already prints /etc/motd via
# login.defs MOTD_FILE, so adding pam_motd would show the banner twice.
