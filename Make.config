# Make.config — machine-local build configuration
# Copy this file to Make.local and edit it. Make.local is .gitignored.
# GNUmakefile includes Make.local if present, then falls back to these defaults.

# ── Architecture ──────────────────────────────────────────────────────────────
ARCH          ?= x86_64
# Supported: x86_64

# ── Toolchain ─────────────────────────────────────────────────────────────────
# Cross-compilation target triple. Set empty to use native host compiler.
# CROSS_COMPILE ?= x86_64-linux-musl-
CROSS_COMPILE ?=

CC            = $(CROSS_COMPILE)gcc
CXX           = $(CROSS_COMPILE)g++
AR            = $(CROSS_COMPILE)ar
STRIP         = $(CROSS_COMPILE)strip
OBJCOPY       = $(CROSS_COMPILE)objcopy

# The userland (busybox/runit/dropbear) is built dynamically against the host's
# glibc with $(CC); the glibc runtime is then bundled into the image. No libc is
# built from source.

# ── Parallel jobs ─────────────────────────────────────────────────────────────
JOBS          ?= $(shell nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)

# ── Source versions ───────────────────────────────────────────────────────────
LINUX_VERSION    ?= 6.18.38
BUSYBOX_VERSION  ?= 1.36.1
RUNIT_VERSION    ?= 2.1.2
DROPBEAR_VERSION ?= 2024.86

# ── Directories ───────────────────────────────────────────────────────────────
# All build artefacts live under OBJDIR — never in the source tree.
# Default: sibling directory ../blueberry-build, fully outside the source tree.
# Override in Make.local: OBJDIR ?= /path/to/your/build/dir
TOPDIR  := $(CURDIR)
OBJDIR  ?= $(abspath $(TOPDIR)/../blueberry-build)
DESTDIR ?= $(OBJDIR)/rootfs

# ── Compiler flags ────────────────────────────────────────────────────────────
CFLAGS   ?= -Os -pipe -fstack-protector-strong
CXXFLAGS ?= $(CFLAGS)
LDFLAGS  ?= -Wl,-z,relro,-z,now

# ── Kernel options ────────────────────────────────────────────────────────────
# The kernel is PINNED and PREBUILT, not rolling: `make` fetches a fixed binary
# artifact (vmlinuz + modules) from the repo instead of compiling it, so small
# machines never compile the kernel (nor gcc/glibc — those are host-provided).
# To change the kernel: bump LINUX_VERSION above and/or edit src/kernel/config,
# then run `make kernel-publish` on a build box to compile + release the new
# pinned artifact. `make kernel-rebuild` compiles locally without publishing.
KERNEL_LOCALVERSION ?= -blueberry
