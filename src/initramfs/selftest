#!/bin/sh
# /etc/selftest — in-guest smoke test for the Blueberry live CLI.
#
# Invoked by /init when the kernel is booted with `bbtest` on its cmdline.
# Prints a PASS/FAIL line per check and a final BLUEBERRY_TEST=PASS|FAIL
# marker that `make test` greps for from the serial log.

PASS=0
FAIL=0

ok()   { PASS=$((PASS + 1)); printf 'PASS: %s\n' "$1"; }
bad()  { FAIL=$((FAIL + 1)); printf 'FAIL: %s\n' "$1"; }

# check <name> <cmd...> — pass if the command exits 0
check() {
    name="$1"; shift
    if out=$("$@" 2>&1); then
        ok "$name"
    else
        bad "$name"
        printf '      %s\n' "$out"
    fi
}

# grep_check <name> <pattern> <cmd...> — pass if output matches the pattern
grep_check() {
    name="$1"; pat="$2"; shift 2
    if "$@" 2>&1 | grep -q "$pat"; then
        ok "$name"
    else
        bad "$name"
    fi
}

printf '\n=== Blueberry CLI self-test ===\n\n'

# Core shell + coreutils applets
check      "busybox present"     test -x /bin/busybox
check      "sh works"            sh -c 'exit 0'
grep_check "echo"        hello   echo hello
grep_check "ls /bin"     busybox ls /bin
grep_check "uname -s"    Linux   uname -s

# Pseudo-filesystems mounted by /init
check      "/proc mounted"       test -f /proc/cpuinfo
check      "/sys mounted"        test -d /sys/class
check      "/dev populated"      test -c /dev/null
grep_check "mount table"  proc   mount

# Process + system introspection
grep_check "ps lists init"  init  ps
check      "uptime readable"      cat /proc/uptime
check      "writable /tmp"        sh -c 'echo hi > /tmp/.t && rm -f /tmp/.t'

# Hostname was applied by /init
grep_check "hostname"  blueberry  hostname

# Networking: /init brings up lo + DHCP on every Ethernet NIC. Wait up to ~8s
# for a non-loopback interface to obtain an IPv4 address (QEMU user-net runs a
# DHCP server handing out 10.0.2.15).
net_ok=""
i=0
while [ $i -lt 16 ]; do
    for iface in $(ls /sys/class/net 2>/dev/null); do
        [ "$iface" = lo ] && continue
        if ip -4 addr show "$iface" 2>/dev/null | grep -q 'inet '; then
            net_ok="$iface"; break
        fi
    done
    [ -n "$net_ok" ] && break
    sleep 0.5; i=$((i + 1))
done
if [ -n "$net_ok" ]; then
    ok "DHCP lease on $net_ok ($(ip -4 addr show "$net_ok" | awk '/inet /{print $2}'))"
else
    bad "DHCP lease (no IPv4 on any NIC after 8s)"
fi

# Phantom interfaces: the built-in bonding/dummy drivers each auto-create a
# device unless suppressed on the kernel cmdline (bonding.max_bonds=0
# dummy.numdummies=0). Assert they are absent so only real NICs appear.
if [ ! -e /sys/class/net/bond0 ] && [ ! -e /sys/class/net/dummy0 ]; then
    ok "no phantom bond0/dummy0 interfaces"
else
    bad "phantom interface present: $(ls /sys/class/net | tr '\n' ' ')"
fi

# SSH: Dropbear should be listening on TCP 22. Port 22 = 0x0016, LISTEN = 0A
# in /proc/net/tcp{,6}. Wait a moment for the daemon (and its host-key gen).
ssh_ok=""
i=0
while [ $i -lt 10 ]; do
    if awk '$2 ~ /:0016$/ && $4 == "0A" {found=1} END{exit !found}' \
         /proc/net/tcp /proc/net/tcp6 2>/dev/null; then
        ssh_ok=1; break
    fi
    sleep 0.5; i=$((i + 1))
done
if [ -n "$ssh_ok" ]; then
    ok "dropbear SSH listening on :22"
else
    bad "dropbear SSH not listening on :22"
fi

# Time sync: ntpd should have been started by /init. We can't depend on real
# NTP reachability in CI, so just assert the daemon is running.
if ps 2>/dev/null | grep -v grep | grep -q '[n]tpd'; then
    ok "ntpd running"
else
    bad "ntpd not running"
fi

# Standalone shell: an applet with NO /bin symlink must still run by bare name.
# `seq` is deliberately not symlinked in the initramfs, so this only passes
# when CONFIG_FEATURE_SH_STANDALONE=y is built into busybox.
if [ ! -e /bin/seq ] && [ "$(seq 3 | tr -d '\n')" = "123" ]; then
    ok "standalone shell (unlinked applet runs by name)"
else
    bad "standalone shell (unlinked applet runs by name)"
fi

printf '\n=== %d passed, %d failed ===\n' "$PASS" "$FAIL"
if [ "$FAIL" -eq 0 ]; then
    printf 'BLUEBERRY_TEST=PASS\n'
else
    printf 'BLUEBERRY_TEST=FAIL\n'
fi
printf '\n'
