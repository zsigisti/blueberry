#!/bin/sh
# /init — Blueberry Linux initramfs entry point (PID 1)
#
# Blueberry boots as a self-contained live CLI: the kernel loads this
# initramfs and runs straight into an interactive busybox shell. No disk,
# no package manager, no network required.
#
# Kernel command-line parameters understood:
#   bbtest                run the in-guest self-test, print result, power off
#   root=<dev|LABEL|UUID> mount that device and switch_root into it instead
#   rootfstype=<type>     filesystem type for root= (default: auto)
#   rootflags=<flags>     mount flags for root= (default: ro)
#   init=<path>           init to exec after switch_root (default: /sbin/runit-init)
#   quiet                 suppress the banner and most output
#   debug                 verbose shell tracing

export PATH=/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root TERM="${TERM:-linux}"

# ── Mount the early filesystems ───────────────────────────────────────────────
mount -t proc     proc     /proc       2>/dev/null
mount -t sysfs    sysfs    /sys        2>/dev/null
mount -t devtmpfs devtmpfs /dev        2>/dev/null || \
    mount -t tmpfs devtmpfs /dev -o nosuid,mode=0755
mkdir -p /dev/pts /dev/shm /run /tmp /root
mount -t devpts devpts /dev/pts -o nosuid,noexec,gid=5,mode=620 2>/dev/null
mount -t tmpfs  shm    /dev/shm -o nosuid,nodev                 2>/dev/null
mount -t tmpfs  run    /run     -o nosuid,nodev,mode=755        2>/dev/null
chmod 1777 /tmp 2>/dev/null

# ── Populate /dev from sysfs ──────────────────────────────────────────────────
[ -x /bin/mdev ] && mdev -s 2>/dev/null

# ── Parse /proc/cmdline ───────────────────────────────────────────────────────
cmdline() {
    for tok in $(cat /proc/cmdline 2>/dev/null); do
        case "$tok" in
            "$1")   echo 1; return ;;
            "$1"=*) echo "${tok#*=}"; return ;;
        esac
    done
}

QUIET=$(cmdline quiet)
DEBUG=$(cmdline debug)
BBTEST=$(cmdline bbtest)
ROOT=$(cmdline root)

[ -n "$DEBUG" ] && set -x

hostname -F /etc/hostname 2>/dev/null || hostname blueberry 2>/dev/null

# ── Self-test mode (CI) ───────────────────────────────────────────────────────
# Boot with `bbtest` on the kernel cmdline to run the automated checks and
# power off. `make test` greps the serial log for BLUEBERRY_TEST=PASS.
if [ -n "$BBTEST" ]; then
    /etc/selftest
    echo o > /proc/sysrq-trigger 2>/dev/null
    poweroff -f 2>/dev/null
    exec sh
fi

# ── Disk boot mode (optional) ─────────────────────────────────────────────────
# If root= was given, mount it and hand off to the real init. Otherwise we
# run as a live system entirely from RAM.
if [ -n "$ROOT" ]; then
    ROOTFSTYPE=$(cmdline rootfstype); : "${ROOTFSTYPE:=auto}"
    ROOTFLAGS=$(cmdline rootflags);   : "${ROOTFLAGS:=ro}"
    INIT=$(cmdline init);             : "${INIT:=/sbin/runit-init}"
    mkdir -p /mnt/root
    if mount -t "$ROOTFSTYPE" -o "$ROOTFLAGS" "$ROOT" /mnt/root 2>/dev/null \
       && [ -x "/mnt/root$INIT" ]; then
        for d in proc sys dev run; do
            mkdir -p "/mnt/root/$d"
            mount --move "/$d" "/mnt/root/$d" 2>/dev/null
        done
        exec switch_root /mnt/root "$INIT"
    fi
    echo "init: could not boot root=$ROOT — falling back to live shell" >&2
fi

# ── Live CLI ──────────────────────────────────────────────────────────────────
if [ -z "$QUIET" ]; then
    VER=$(uname -r)
    clear 2>/dev/null
    cat <<EOF

   _     _                _
  | |__ | |_   _  ___| |__   ___ _ __ _ __ _   _
  | '_ \\| | | | |/ _ \\ '_ \\ / _ \\ '__| '__| | | |
  | |_) | | |_| |  __/ |_) |  __/ |  | |  | |_| |
  |_.__/|_|\\__,_|\\___|_.__/ \\___|_|  |_|   \\__, |
                                           |___/   Linux

  Blueberry Linux — live CLI   ·   kernel $VER
  Type 'help' for busybox applets.  Ctrl-A X quits QEMU.

EOF
fi

# Hush late/runtime kernel messages on the console so they don't interleave
# with the interactive prompt (e.g. the i8042 input devices that probe after
# init has started). Boot messages already printed, errors still show, and the
# full ring buffer is always available via `dmesg`. Skipped when `debug` is set.
[ -z "$DEBUG" ] && [ -w /proc/sys/kernel/printk ] && echo 4 > /proc/sys/kernel/printk

# Hand the controlling terminal to an interactive login shell. cttyhack gives
# us a controlling tty so job control (Ctrl-C, fg/bg) works on the console;
# setsid + the respawn loop means exiting the shell just starts a fresh one
# instead of panicking PID 1.
while : ; do
    setsid cttyhack /bin/sh -l 2>/dev/null || /bin/sh -l
done
