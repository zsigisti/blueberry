#!/bin/sh
# /init â€” Blueberry Linux initramfs entry point (PID 1)
#
# Blueberry boots as a self-contained live CLI: the kernel loads this
# initramfs and runs straight into an interactive busybox shell. No disk,
# no package manager, no network required.
#
# Kernel command-line parameters understood:
#   bbtest                run the in-guest self-test, print result, power off
#   blueberry.live=1      live desktop boot: mount the medium's squashfs as an
#                         overlayfs root and switch_root into systemd (graphical)
#   root=live:CDLABEL=ID  names the live medium for blueberry.live (else scanned)
#   root=<dev|LABEL|UUID> mount that device and switch_root into it instead
#   rootfstype=<type>     filesystem type for root= (default: auto)
#   rootflags=<flags>     mount flags for root= (default: ro)
#   init=<path>           init to exec after switch_root (default: /sbin/init,
#                         which points at runit-init or systemd per the image)
#   quiet                 suppress the banner and most output
#   debug                 verbose shell tracing

export PATH=/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root TERM="${TERM:-linux}"
# Interactive shells (the console getty spawns) source /etc/profile via $ENV,
# which sets the prompt and aliases.
export ENV=/etc/profile

# â”€â”€ Mount the early filesystems â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
mount -t proc     proc     /proc       2>/dev/null
mount -t sysfs    sysfs    /sys        2>/dev/null
mount -t devtmpfs devtmpfs /dev        2>/dev/null || \
    mount -t tmpfs devtmpfs /dev -o nosuid,mode=0755
mkdir -p /dev/pts /dev/shm /run /tmp /root
mount -t devpts devpts /dev/pts -o nosuid,noexec,gid=5,mode=620 2>/dev/null
mount -t tmpfs  shm    /dev/shm -o nosuid,nodev                 2>/dev/null
mount -t tmpfs  run    /run     -o nosuid,nodev,mode=755        2>/dev/null
chmod 1777 /tmp 2>/dev/null

# â”€â”€ Populate /dev from sysfs â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
[ -x /bin/mdev ] && mdev -s 2>/dev/null

# â”€â”€ Parse /proc/cmdline â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cmdline() {
    for tok in $(cat /proc/cmdline 2>/dev/null); do
        case "$tok" in
            "$1")   echo 1; return ;;
            "$1"=*) echo "${tok#*=}"; return ;;
        esac
    done
}

QUIET=$(cmdline quiet)
DEBUG=$(cmdline debug)
BBTEST=$(cmdline bbtest)
BBINSTALL=$(cmdline bbinstall)
LIVE=$(cmdline blueberry.live)
ROOT=$(cmdline root)

[ -n "$DEBUG" ] && set -x

hostname -F /etc/hostname 2>/dev/null || hostname blueberry 2>/dev/null

# â”€â”€ Networking â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Bring up loopback and DHCP every real Ethernet interface (ARPHRD_ETHER=1).
# udhcpc -b backgrounds itself and keeps renewing; the lease is applied by
# /etc/udhcpc.script. Not started on the disk-boot path â€” runit owns that.
setup_network() {
    ip link set lo up 2>/dev/null
    # NIC drivers (e1000 etc.) probe asynchronously and may not have created
    # their interface yet; wait briefly for at least one Ethernet device.
    _n=0
    while [ $_n -lt 10 ]; do
        for _p in /sys/class/net/*; do
            iface=${_p##*/}
            [ "$iface" = lo ] && continue
            [ "$(cat "$_p/type" 2>/dev/null)" = "1" ] && _n=99 && break
        done
        [ $_n -eq 99 ] && break
        sleep 0.3; _n=$((_n + 1))
    done
    for _p in /sys/class/net/*; do
        iface=${_p##*/}
        [ "$iface" = lo ] && continue
        [ "$(cat "$_p/type" 2>/dev/null)" = "1" ] || continue
        ip link set "$iface" up 2>/dev/null
        udhcpc -b -i "$iface" -s /etc/udhcpc.script -t 4 -T 1 2>/dev/null &
    done
    # QEMU SLIRP advertises a useless site-local IPv6 (fec0::) with no route to
    # the internet; dual-stack name lookups then prefer an unreachable AAAA and
    # downloads stall. If nothing got a global IPv6, turn IPv6 off so resolution
    # sticks to IPv4. A real network with SLAAC/DHCPv6 keeps IPv6 on.
    sleep 1
    if ! ip -6 addr show scope global 2>/dev/null | grep -q "inet6"; then
        echo 1 > /proc/sys/net/ipv6/conf/all/disable_ipv6 2>/dev/null || true
    fi
}

# â”€â”€ SSH â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Start the Dropbear SSH server. -R auto-generates host keys on first use (kept
# in /etc/dropbear, RAM). Log in as root with the default password "blueberry"
# (set in /etc/shadow) â€” change it in any real deployment.
start_sshd() {
    [ -x /usr/sbin/dropbear ] || return 0
    mkdir -p /etc/dropbear
    dropbear -R -p 22 2>/dev/null &
}

# â”€â”€ Time sync â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# busybox ntpd: step the clock on first sync, then discipline it. Backgrounded;
# needs working DNS + outbound UDP 123 (it just keeps retrying if unavailable).
start_ntpd() {
    ntpd -p 0.pool.ntp.org -p 1.pool.ntp.org 2>/dev/null &
}

# â”€â”€ Self-test mode (CI) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Boot with `bbtest` on the kernel cmdline to run the automated checks and
# power off. `make test` greps the serial log for BLUEBERRY_TEST=PASS.
if [ -n "$BBTEST" ]; then
    setup_network
    start_sshd
    start_ntpd
    /etc/selftest
    echo o > /proc/sysrq-trigger 2>/dev/null
    poweroff -f 2>/dev/null
    exec sh
fi

# â”€â”€ Unattended install mode â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Boot with `bbinstall` to run blueberry-install non-interactively, then power
# off. Target/password come from the cmdline (defaults: /dev/sda, "blueberry").
# Extra packages: blueberry.pkgs=vim,git (comma-separated; needs networking).
#   bbinstall blueberry.target=/dev/sda blueberry.rootpw=secret blueberry.pkgs=vim,git
if [ -n "$BBINSTALL" ]; then
    BLUEBERRY_TARGET=$(cmdline blueberry.target); : "${BLUEBERRY_TARGET:=/dev/sda}"
    BLUEBERRY_ROOTPW=$(cmdline blueberry.rootpw); : "${BLUEBERRY_ROOTPW:=blueberry}"
    # cmdline can't carry spaces, so packages are comma-separated -> spaces.
    BLUEBERRY_PKGS=$(cmdline blueberry.pkgs | tr ',' ' ')
    BLUEBERRY_HOSTNAME=$(cmdline blueberry.hostname)
    BLUEBERRY_SWAP=$(cmdline blueberry.swap)
    BLUEBERRY_USER=$(cmdline blueberry.user)
    BLUEBERRY_USERPW=$(cmdline blueberry.userpw)
    BLUEBERRY_LUKS=$(cmdline blueberry.luks)
    BLUEBERRY_LUKSPW=$(cmdline blueberry.lukspw)
    export BLUEBERRY_TARGET BLUEBERRY_ROOTPW BLUEBERRY_PKGS BLUEBERRY_YES=1
    export BLUEBERRY_HOSTNAME BLUEBERRY_SWAP BLUEBERRY_USER BLUEBERRY_USERPW
    export BLUEBERRY_LUKS BLUEBERRY_LUKSPW
    blueberry-install; rc=$?
    echo "BLUEBERRY_INSTALL_EXIT=$rc"
    [ "$rc" = 0 ] && echo "BLUEBERRY_INSTALL=OK" || echo "BLUEBERRY_INSTALL=FAIL"
    echo o > /proc/sysrq-trigger 2>/dev/null
    poweroff -f 2>/dev/null
    exec sh
fi

# â”€â”€ LUKS unlock (optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# `cryptdevice=<src>:<name>` on the cmdline unlocks an encrypted partition
# before the root mount, so root= can point at /dev/mapper/<name>. <src> is a
# device node or UUID=/PARTUUID=/LABEL=. cryptsetup prompts for the passphrase
# on the console; three tries then falls through to a rescue shell.
CRYPTDEV=$(cmdline cryptdevice)
if [ -n "$CRYPTDEV" ] && command -v cryptsetup >/dev/null 2>&1; then
    _csrc=${CRYPTDEV%%:*}; _cname=${CRYPTDEV#*:}; : "${_cname:=cryptroot}"
    case "$_csrc" in
        UUID=*|PARTUUID=*|LABEL=*) _r=$(findfs "$_csrc" 2>/dev/null) && [ -n "$_r" ] && _csrc=$_r ;;
    esac
    if [ -b "$_csrc" ]; then
        _n=0
        until cryptsetup open "$_csrc" "$_cname"; do
            _n=$((_n + 1))
            [ "$_n" -ge 3 ] && { echo "init: too many failed unlock attempts" >&2; break; }
            echo "Unlock failed â€” try again."
        done
    else
        echo "init: LUKS source not found: $_csrc" >&2
    fi
fi

# â”€â”€ Live desktop mode (squashfs + overlay) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# `blueberry.live=1` (set by the desktop ISO's GRUB menu) boots the live image:
# find the install medium, mount its read-only squashfs as the lower layer of an
# overlayfs with a tmpfs upper, and switch_root into it so systemd reaches the
# graphical target. The medium stays mounted at /run/live/medium so Calamares'
# unpackfs can copy the squashfs to disk. root=live:CDLABEL=<volid> names it.
if [ -n "$LIVE" ]; then
    # Pull the volume label out of root=live:CDLABEL=<volid> (fallback: scan).
    LABEL=""
    case "$ROOT" in live:CDLABEL=*) LABEL=${ROOT#live:CDLABEL=} ;; esac
    # Load the modules a live root needs if they aren't built in.
    for m in loop squashfs overlay isofs cdrom sr_mod usb_storage; do
        modprobe "$m" 2>/dev/null || true
    done
    # IMPORTANT: keep the overlay backing OUTSIDE /run. Mounting it under /run and
    # then `mount --move /run` into the new root nests the overlay's own
    # upperdir/lowerdir inside the overlay â†’ an inconsistent mount that makes
    # switch_root fail (kernel panic "Attempted to kill init"). /live is a
    # top-level initramfs dir that is never moved into the new root.
    mkdir -p /live/medium /live/rootfs.ro /live/overlay /mnt/root
    # Locate the medium: by label first, else probe every block device for the
    # live squashfs (handles USB sticks whose label differs from the ISO volid).
    MEDIUM=""
    if [ -n "$LABEL" ]; then
        _d=$(findfs "LABEL=$LABEL" 2>/dev/null) && [ -b "$_d" ] && MEDIUM=$_d
    fi
    _try=0
    while [ -z "$MEDIUM" ] && [ $_try -lt 20 ]; do
        [ -x /bin/mdev ] && mdev -s 2>/dev/null
        for _b in /dev/sr* /dev/sd* /dev/vd* /dev/nvme*n*; do
            [ -b "$_b" ] || continue
            if mount -t iso9660 -o ro "$_b" /live/medium 2>/dev/null \
               || mount -o ro "$_b" /live/medium 2>/dev/null; then
                [ -f /live/medium/live/filesystem.squashfs ] && { MEDIUM=$_b; break; }
                umount /live/medium 2>/dev/null
            fi
        done
        [ -n "$MEDIUM" ] && break
        sleep 0.5; _try=$((_try + 1))
    done
    if [ -n "$MEDIUM" ]; then
        mountpoint -q /live/medium 2>/dev/null \
            || mount -o ro "$MEDIUM" /live/medium 2>/dev/null
        if mount -t squashfs -o ro /live/medium/live/filesystem.squashfs \
                 /live/rootfs.ro 2>/dev/null; then
            mount -t tmpfs -o mode=0755 live-overlay /live/overlay
            mkdir -p /live/overlay/upper /live/overlay/work
            if mount -t overlay overlay \
                 -o lowerdir=/live/rootfs.ro,upperdir=/live/overlay/upper,workdir=/live/overlay/work \
                 /mnt/root 2>/dev/null; then
                # Move only the API filesystems; leave /run so systemd mounts a
                # fresh one. The overlay backing lives in /live (the initramfs
                # root), which the kernel keeps referenced after switch_root.
                for d in proc sys dev; do
                    mkdir -p "/mnt/root/$d"
                    mount --move "/$d" "/mnt/root/$d" 2>/dev/null
                done
                # Preserve the install medium for Calamares' unpackfs. systemd
                # mounts /run as tmpfs at boot, so stage the bind under /lib/live
                # (persisted in the overlay upper) instead of /run.
                mkdir -p /mnt/root/lib/live/medium
                mount --bind /live/medium /mnt/root/lib/live/medium 2>/dev/null
                echo "BLUEBERRY_LIVE_BOOT=OK medium=$MEDIUM"
                exec switch_root /mnt/root /sbin/init
            fi
        fi
    fi
    echo "init: live medium not found/usable â€” falling back to live CLI shell" >&2
fi

# â”€â”€ Disk boot mode (optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# If root= was given, mount it and hand off to the real init. Otherwise we
# run as a live system entirely from RAM.
if [ -n "$ROOT" ] && [ -z "$LIVE" ]; then
    ROOTFSTYPE=$(cmdline rootfstype); : "${ROOTFSTYPE:=auto}"
    ROOTFLAGS=$(cmdline rootflags);   : "${ROOTFLAGS:=ro}"
    # /sbin/init is the init-agnostic entry point: runit images symlink it to
    # runit-init, systemd images to /usr/lib/systemd/systemd. Either boots here.
    INIT=$(cmdline init);             : "${INIT:=/sbin/init}"
    # Resolve UUID=/LABEL= to a device node (what the installer writes). Fall
    # back to the raw value if findfs can't (older mount handles some itself).
    case "$ROOT" in
        UUID=*|LABEL=*|PARTUUID=*|PARTLABEL=*)
            _dev=$(findfs "$ROOT" 2>/dev/null) && [ -n "$_dev" ] && ROOT="$_dev" ;;
    esac
    mkdir -p /mnt/root
    # Accept the init if it's executable OR a symlink: an absolute symlink (e.g.
    # systemd's /sbin/init -> /usr/lib/systemd/systemd) can't be -x tested from
    # here because its target resolves against the initramfs root, not the
    # mounted rootfs; switch_root resolves it correctly inside the new root.
    if mount -t "$ROOTFSTYPE" -o "$ROOTFLAGS" "$ROOT" /mnt/root 2>/dev/null \
       && { [ -x "/mnt/root$INIT" ] || [ -L "/mnt/root$INIT" ]; }; then
        for d in proc sys dev run; do
            mkdir -p "/mnt/root/$d"
            mount --move "/$d" "/mnt/root/$d" 2>/dev/null
        done
        echo "BLUEBERRY_DISK_BOOT=OK root=$ROOT"
        exec switch_root /mnt/root "$INIT"
    fi
    echo "init: could not boot root=$ROOT â€” falling back to live shell" >&2
fi

# â”€â”€ Live CLI â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
setup_network
start_sshd
start_ntpd

# Hush late/runtime kernel messages on the console so they don't interleave with
# the interactive prompt (e.g. the i8042 input devices that probe after init has
# started). Boot messages already printed, errors still show, and the full ring
# buffer is always available via `dmesg`. Skipped when `debug` is set.
[ -z "$DEBUG" ] && [ -w /proc/sys/kernel/printk ] && echo 4 > /proc/sys/kernel/printk

banner() {
    [ -n "$QUIET" ] && return 0
    cat <<EOF

   _     _                _
  | |__ | |_   _  ___| |__   ___ _ __ _ __ _   _
  | '_ \\| | | | |/ _ \\ '_ \\ / _ \\ '__| '__| | | |
  | |_) | | |_| |  __/ |_) |  __/ |  | |  | |_| |
  |_.__/|_|\\__,_|\\___|_.__/ \\___|_|  |_|   \\__, |
                                           |___/   Linux

  Blueberry Linux â€” live CLI   Â·   kernel $(uname -r)
  Run 'bb-install' to install to disk   Â·   'help' for busybox applets.

EOF
}

# Put an interactive root shell on every console the kernel is using, so you get
# a prompt whether you are on a physical monitor (tty0 -> tty1) or a serial/IPMI
# console (ttyS0). getty opens the tty, makes it controlling (job control works),
# and -n -l <shell> skips the login prompt to drop straight into a root shell.
# Prefer bash (bundled in the live image) and fall back to busybox sh.
# Each shell respawns when it exits so PID 1 never dies.
LOGIN_SHELL=/bin/sh
# bblogin execs `bash --login` so /etc/profile is read (sets the
# root@blueberry:~# prompt); plain bash here would be non-login.
[ -x /usr/bin/bblogin ] && LOGIN_SHELL=/usr/bin/bblogin
run_shell() {
    tty="$1"; baud="$2"
    while : ; do
        banner > "/dev/$tty" 2>/dev/null
        getty -i -n -L -l "$LOGIN_SHELL" "$baud" "$tty" 2>/dev/null
        sleep 0.2
    done
}

CONSOLES=""
if [ -r /sys/class/tty/console/active ]; then
    for c in $(cat /sys/class/tty/console/active); do
        case "$c" in
            tty0) CONSOLES="$CONSOLES tty1" ;;   # VGA: run the shell on tty1
            *)    CONSOLES="$CONSOLES $c"   ;;
        esac
    done
fi
[ -n "$CONSOLES" ] || CONSOLES="tty1"

for c in $CONSOLES; do
    case "$c" in
        ttyS*) run_shell "$c" 115200 & ;;
        *)     run_shell "$c" 0      & ;;
    esac
done

# Act like a minimal init for shutdown: busybox halt/poweroff/reboot signal
# PID 1 (SIGUSR1/SIGUSR2/SIGTERM respectively). Catch them and perform the
# actual reboot(2) syscall, after syncing disks. This makes a bare `poweroff`,
# `reboot`, or `halt` from any shell or script work, not just `... -f`.
trap 'sync; halt -f'     USR1
trap 'sync; poweroff -f' USR2
trap 'sync; reboot -f'   TERM INT

# PID 1 must never exit.
while : ; do wait; sleep 1; done
