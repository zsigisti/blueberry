#!/bin/sh
# test-init — QEMU smoke test runner
#
# Run instead of the normal /init to verify the OS components work:
#   kernel boots, shell commands work, network comes up, bpm installs packages.
#
# Boot with:
#   -append "console=ttyS0 rdinit=/test-init BPMREPO=http://10.0.2.2:8080"
# (rdinit= runs from initramfs; init= runs after switch_root to real disk)
#
# The script prints SMOKE_TEST_RESULT=PASS or SMOKE_TEST_RESULT=FAIL just
# before powering off. The CI job greps for that string.

export PATH=/usr/sbin:/usr/bin:/sbin:/bin

# ── Mount early filesystems ───────────────────────────────────────────────────
mount -t proc    proc    /proc
mount -t sysfs   sysfs   /sys
mount -t devtmpfs dev    /dev   2>/dev/null || \
    mount -t tmpfs devtmpfs /dev -o nosuid,mode=0755
mkdir -p /dev/pts /tmp /run /var/lib/bpm /var/lib/bpm/cache /var/lib/bpm/db
mount -t devpts devpts /dev/pts -o nosuid,noexec 2>/dev/null || true
mount -t tmpfs  tmpfs  /run     -o nosuid,nodev   2>/dev/null || true

# ── Counters ─────────────────────────────────────────────────────────────────
PASS=0; FAIL=0

ok()   { PASS=$((PASS+1)); printf 'PASS: %s\n' "$*"; }
fail() { FAIL=$((FAIL+1)); printf 'FAIL: %s\n' "$*"; }

check() {
    local name="$1"; shift
    local out
    out=$("$@" 2>&1) && ok "$name" || { fail "$name"; printf '     %s\n' "$out"; }
}

# ── Read kernel command line ──────────────────────────────────────────────────
BPMREPO=""
for p in $(cat /proc/cmdline); do
    case "$p" in BPMREPO=*) BPMREPO="${p#BPMREPO=}" ;; esac
done

printf '\n=== Blueberry Smoke Tests ===\n\n'

# ─────────────────────────────────────────────────────────────────────────────
# 1. Basic shell commands
# ─────────────────────────────────────────────────────────────────────────────
printf '--- Shell ---\n'
check "ls /bin"          ls /bin
check "busybox ps"       busybox ps
check "mount list"       mount
check "uname -a"         busybox uname -a
check "cat /proc/uptime" cat /proc/uptime

# ─────────────────────────────────────────────────────────────────────────────
# 2. Network
# ─────────────────────────────────────────────────────────────────────────────
printf '\n--- Network ---\n'
# Detect first real Ethernet interface (type=1 = ARPHRD_ETHER, skips sit0/lo)
ETH=""
for _iface in $(ls /sys/class/net/ 2>/dev/null); do
    [ "$(cat /sys/class/net/$_iface/type 2>/dev/null)" = "1" ] && ETH="$_iface" && break
done
if [ -z "$ETH" ]; then
    fail "no network interface found"
else
    ok "interface: $ETH"
    ip link set "$ETH" up 2>/dev/null || true
    # QEMU SLIRP always assigns 10.0.2.15/24 — use static config, no DHCP needed
    ip addr add 10.0.2.15/24 dev "$ETH" 2>/dev/null || true
    ip route add default via 10.0.2.2 dev "$ETH" 2>/dev/null || true
    check "ping gateway (10.0.2.2)" ping -c 2 -W 3 10.0.2.2
    check "wget 1.1.1.1"           wget -q -T 10 -O /dev/null http://1.1.1.1/
fi

# ─────────────────────────────────────────────────────────────────────────────
# 3. bpm
# ─────────────────────────────────────────────────────────────────────────────
printf '\n--- bpm ---\n'
BPM=""
for p in /usr/bin/bpm /bin/bpm; do [ -x "$p" ] && BPM="$p" && break; done

if [ -z "$BPM" ]; then
    fail "bpm: not found in initramfs"
elif [ -z "$BPMREPO" ]; then
    ok "bpm: binary present (no BPMREPO set, skipping install test)"
else
    check "bpm --help" "$BPM" --help

    # Point bpm at the CI-local package repo
    mkdir -p /etc/bpm/repos.d
    printf 'name    = "ci"\nurl     = "%s"\nenabled = true\n' \
        "$BPMREPO" > /etc/bpm/repos.d/ci.conf

    check "bpm update"       "$BPM" update
    check "bpm install zlib" "$BPM" install zlib
fi

# ─────────────────────────────────────────────────────────────────────────────
printf '\n=== Results: %d passed, %d failed ===\n' "$PASS" "$FAIL"
if [ "$FAIL" -eq 0 ]; then
    printf 'SMOKE_TEST_RESULT=PASS\n'
else
    printf 'SMOKE_TEST_RESULT=FAIL\n'
fi
printf '\n'

# Power off — QEMU exits because of -no-reboot
halt -f -p 2>/dev/null || poweroff -f 2>/dev/null || \
    { echo 1 > /proc/sys/kernel/sysrq; echo o > /proc/sysrq-trigger; }
