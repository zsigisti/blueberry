#!/bin/sh
# bpm — Blueberry Package Manager
#
# A small package manager for Arch-format binary packages (.pkg.tar.zst): the
# output of the PKGBUILDs in packages/ (built locally with makepkg or on OBS).
# Pure POSIX sh; runs on the busybox/glibc live system with no extra runtime.
#
# Database:   $BPM_ROOT/var/lib/bpm/db/<name>/{desc,files}
# Repo index: $BPM_ROOT/var/lib/bpm/index   (fetched by `bpm update`)
# Cache:      $BPM_ROOT/var/lib/bpm/cache/
# Repos:      $BPM_ROOT/etc/bpm/repos.conf  (one "name url" per line)
#
# Set BPM_ROOT to install into a staging root instead of / (used by tests).

set -eu

BPM_ROOT="${BPM_ROOT:-/}"
BPM_ROOT="${BPM_ROOT%/}"
DB="$BPM_ROOT/var/lib/bpm/db"
CACHE="$BPM_ROOT/var/lib/bpm/cache"
INDEX="$BPM_ROOT/var/lib/bpm/index"
CONF="$BPM_ROOT/etc/bpm/repos.conf"

die() { printf 'bpm: %s\n' "$*" >&2; exit 1; }
log() { printf ':: %s\n' "$*"; }
warn() { printf 'bpm: warning: %s\n' "$*" >&2; }

for t in zstd tar sha256sum; do
    command -v "$t" >/dev/null 2>&1 || die "required tool not found: $t"
done

# ── helpers ───────────────────────────────────────────────────────────────────

# Read a single .PKGINFO field from stdin (e.g. pkgname). Repeated keys (depend)
# print one per line.
field() { awk -v k="$1" -F ' = ' '$1==k{print $2}'; }

# Stream a member of a .pkg.tar.zst to stdout. Handles both `name` and `./name`.
pkg_member() {
    zstd -dcq "$1" | tar -xO -f - "$2" 2>/dev/null && return 0
    zstd -dcq "$1" | tar -xO -f - "./$2" 2>/dev/null
}

is_meta() {  # metadata members to exclude from the payload
    case "$1" in
        .PKGINFO|./.PKGINFO|.MTREE|./.MTREE|.BUILDINFO|./.BUILDINFO|\
        .INSTALL|./.INSTALL|.CHANGELOG|./.CHANGELOG) return 0 ;;
    esac
    return 1
}

installed_version() {  # echo version if installed, else nothing
    [ -f "$DB/$1/desc" ] && field pkgver < "$DB/$1/desc"
}

# Strip a dependency atom of any version constraint / provider syntax:
#   "glibc>=2.38" -> "glibc",  "libfoo.so=1-64" -> "libfoo.so"
dep_name() { printf '%s\n' "$1" | sed 's/[<>=].*//'; }

# ── install a local .pkg.tar.zst ──────────────────────────────────────────────
install_file() {
    local pkg info name ver old d
    pkg="$1"
    [ -f "$pkg" ] || die "no such package file: $pkg"
    info=$(pkg_member "$pkg" .PKGINFO) || die "not a package (no .PKGINFO): $pkg"
    name=$(printf '%s\n' "$info" | field pkgname)
    ver=$(printf '%s\n' "$info" | field pkgver)
    [ -n "$name" ] || die "package has no pkgname: $pkg"

    old=$(installed_version "$name" || true)
    if [ -n "$old" ]; then
        log "reinstall/upgrade $name $old -> $ver"
        remove_files "$name"
    else
        log "installing $name $ver"
    fi

    # Extract the payload (everything but the metadata members) into the root.
    mkdir -p "$BPM_ROOT"
    zstd -dcq "$pkg" | tar -x -C "$BPM_ROOT" \
        --exclude .PKGINFO --exclude .MTREE --exclude .BUILDINFO \
        --exclude .INSTALL --exclude .CHANGELOG 2>/dev/null

    # Record the database entry.
    d="$DB/$name"
    mkdir -p "$d"
    printf '%s\n' "$info" > "$d/desc"
    pkg_member "$pkg" .PKGINFO >/dev/null  # warm (no-op, keeps shells happy)
    zstd -dcq "$pkg" | tar -tf - 2>/dev/null \
        | while IFS= read -r f; do is_meta "$f" || printf '%s\n' "${f#./}"; done \
        | grep -v '/$' > "$d/files" || true
    log "installed $name $ver"
}

# ── remove ────────────────────────────────────────────────────────────────────
remove_files() {  # remove a package's files but keep no db change here
    local name p f
    name="$1"
    [ -f "$DB/$name/files" ] || return 0
    # files first (reverse sort puts deepest paths first), then prune empty dirs
    sort -r "$DB/$name/files" | while IFS= read -r f; do
        [ -n "$f" ] || continue
        p="$BPM_ROOT/$f"
        if [ -d "$p" ]; then rmdir "$p" 2>/dev/null || true
        else rm -f "$p"; fi
    done
}

cmd_remove() {
    [ $# -ge 1 ] || die "usage: bpm remove <name>..."
    for name in "$@"; do
        [ -d "$DB/$name" ] || die "$name is not installed"
        log "removing $name"
        remove_files "$name"
        rm -rf "$DB/$name"
        log "removed $name"
    done
}

# ── repo index ────────────────────────────────────────────────────────────────
# repos.conf line:  <name> <url1> [url2 ...]   (extra urls are mirrors)
# Index line:       name|version|filename|sha256|dep1,dep2,...|repo_name
#
# Mirrors give redundancy: `bpm update` and package downloads try each mirror in
# turn and move on when one is unreachable.

# echo the mirror URLs configured for repo <name>
repo_mirrors() {
    [ -f "$CONF" ] && awk -v r="$1" '$1==r{$1="";sub(/^[ \t]+/,"");print;exit}' "$CONF"
}

cmd_update() {
    [ -f "$CONF" ] || die "no repo config: $CONF"
    command -v wget >/dev/null 2>&1 || die "wget required for 'update'"
    mkdir -p "$(dirname "$INDEX")"
    : > "$INDEX.tmp"
    while read -r rname urls; do
        case "$rname" in ''|\#*) continue ;; esac
        [ -n "$urls" ] || continue
        got=
        for url in $urls; do
            log "syncing '$rname' from $url"
            if wget -q -O "$INDEX.repo" "$url/bpm.index"; then
                sed "s#\$#|$rname#" "$INDEX.repo" >> "$INDEX.tmp"
                got=1; break
            fi
            warn "mirror unreachable: $url"
        done
        [ -n "$got" ] || warn "all mirrors failed for repo '$rname'"
    done < "$CONF"
    rm -f "$INDEX.repo"
    mv "$INDEX.tmp" "$INDEX"
    log "$(wc -l < "$INDEX" 2>/dev/null || echo 0) packages in index"
}

index_line() { [ -f "$INDEX" ] && awk -F'|' -v n="$1" '$1==n{print; exit}' "$INDEX"; }

# download <file> <sha256> <repo_name> -> $CACHE/<file>, trying each mirror
fetch_pkg() {
    local file="$1" sha="$2" repo="$3" out="$CACHE/$1" m got=
    mkdir -p "$CACHE"
    if [ -f "$out" ] && [ -n "$sha" ] && \
       [ "$(sha256sum "$out" | cut -d' ' -f1)" = "$sha" ]; then
        printf '%s\n' "$out"; return 0
    fi
    for m in $(repo_mirrors "$repo"); do
        if wget -q -O "$out" "$m/$file"; then got=1; break; fi
        warn "mirror unreachable: $m"
    done
    [ -n "$got" ] || die "all mirrors failed for $file (repo '$repo')"
    if [ -n "$sha" ] && [ "$(sha256sum "$out" | cut -d' ' -f1)" != "$sha" ]; then
        die "checksum mismatch for $file"
    fi
    printf '%s\n' "$out"
}

# ── install by name (resolve deps, download, install) ─────────────────────────
# Tracks names already handled this transaction in $SEEN (newline list).
SEEN=""
seen() { case "$SEEN" in *"|$1|"*) return 0 ;; esac; return 1; }
mark() { SEEN="$SEEN|$1|"; }

install_name() {
    # locals — without these, recursing for a dependency clobbers our state
    local name line ver file sha deps repo dep out
    name="$1"
    seen "$name" && return 0
    mark "$name"
    [ -n "$(installed_version "$name" || true)" ] && { log "$name already installed"; return 0; }

    line=$(index_line "$name")
    if [ -z "$line" ]; then
        # Not in any repo: assume the base system provides it (glibc, bash, ...).
        warn "$name not in repo index — assuming provided by the base system"
        return 0
    fi
    ver=$(printf '%s' "$line" | cut -d'|' -f2)
    file=$(printf '%s' "$line" | cut -d'|' -f3)
    sha=$(printf '%s' "$line" | cut -d'|' -f4)
    deps=$(printf '%s' "$line" | cut -d'|' -f5)
    repo=$(printf '%s' "$line" | cut -d'|' -f6)

    # dependencies first. Split on commas without touching global IFS (doing so
    # would corrupt word-splitting inside the recursive calls below).
    for dep in $(printf '%s' "$deps" | tr ',' ' '); do
        [ -n "$dep" ] || continue
        install_name "$(dep_name "$dep")"
    done

    log "downloading $name $ver"
    out=$(fetch_pkg "$file" "$sha" "$repo")
    install_file "$out"
}

cmd_install() {
    [ $# -ge 1 ] || die "usage: bpm install <name|file.pkg.tar.zst>..."
    for a in "$@"; do
        case "$a" in
            *.pkg.tar.*) install_file "$a" ;;
            *)           install_name "$a" ;;
        esac
    done
}

# ── queries ───────────────────────────────────────────────────────────────────
cmd_list() {
    [ -d "$DB" ] || return 0
    for d in "$DB"/*/; do
        [ -d "$d" ] || continue
        n=$(basename "$d")
        printf '%s %s\n' "$n" "$(field pkgver < "$d/desc" 2>/dev/null)"
    done
}

cmd_info() {
    [ $# -ge 1 ] || die "usage: bpm info <name>"
    [ -f "$DB/$1/desc" ] || die "$1 is not installed"
    cat "$DB/$1/desc"
}

cmd_files() {
    [ $# -ge 1 ] || die "usage: bpm files <name>"
    [ -f "$DB/$1/files" ] || die "$1 is not installed"
    cat "$DB/$1/files"
}

cmd_owns() {
    [ $# -ge 1 ] || die "usage: bpm owns <path>"
    q="${1#/}"; found=""
    for f in "$DB"/*/files; do
        [ -f "$f" ] || continue
        if grep -qxF "$q" "$f"; then
            printf '%s\n' "$(basename "$(dirname "$f")")"; found=1
        fi
    done
    [ -n "$found" ] || die "no package owns /$q"
}

cmd_search() {
    [ $# -ge 1 ] || die "usage: bpm search <term>"
    [ -f "$INDEX" ] || die "no index; run 'bpm update' first"
    awk -F'|' -v t="$1" 'index($1,t){printf "%s %s\n",$1,$2}' "$INDEX"
}

cmd_upgrade() {
    [ -f "$INDEX" ] || die "no index; run 'bpm update' first"
    cmd_list | while read -r n v; do
        line=$(index_line "$n"); [ -n "$line" ] || continue
        nv=$(printf '%s' "$line" | cut -d'|' -f2)
        [ "$nv" != "$v" ] && printf '%s\n' "$n"
    done | while read -r n; do SEEN=""; install_name "$n"; done
}

usage() {
    cat <<'EOF'
bpm — Blueberry Package Manager

  bpm install <name|file.pkg.tar.zst>...   install (resolve deps from repos)
  bpm remove  <name>...                    remove installed package(s)
  bpm update                               sync repo indices
  bpm upgrade                              upgrade all installed packages
  bpm search  <term>                       search the repo index
  bpm list                                 list installed packages
  bpm info    <name>                       show package metadata
  bpm files   <name>                       list files a package owns
  bpm owns    <path>                       which package owns a path

Env: BPM_ROOT=<dir> installs into a staging root instead of /.
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────
[ $# -ge 1 ] || { usage; exit 1; }
cmd="$1"; shift
case "$cmd" in
    install|in)        cmd_install "$@" ;;
    remove|rm)         cmd_remove "$@" ;;
    update|up)         cmd_update "$@" ;;
    upgrade)           cmd_upgrade "$@" ;;
    search|se)         cmd_search "$@" ;;
    list|ls)           cmd_list "$@" ;;
    info)              cmd_info "$@" ;;
    files)             cmd_files "$@" ;;
    owns)              cmd_owns "$@" ;;
    -h|--help|help)    usage ;;
    *)                 die "unknown command '$cmd' (try: bpm help)" ;;
esac
