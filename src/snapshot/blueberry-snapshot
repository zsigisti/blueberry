#!/bin/sh
# blueberry-snapshot — btrfs snapshot + boot-level rollback for Blueberry Linux.
#
# Snapshots the root subvolume (@) into @snapshots/<ts>-<label>, generates
# grub-btrfs-style per-snapshot boot entries, prunes old ones, and can roll @
# back to a snapshot. Each snapshot is a *writable* copy carrying its own
# /boot kernel + modules, and its GRUB entry pins rootflags=subvol=@snapshots/…,
# so booting a snapshot is a complete, self-consistent system (no kernel/root
# mismatch) — which is what makes "the last upgrade won't boot" recoverable.
#
# A no-op on non-btrfs roots. Commands:
#   create [label]     snapshot @ (default label: manual), prune, refresh grub
#   list               list snapshots (newest first)
#   grub               (re)generate the GRUB snapshot menu from current snapshots
#   prune              keep only the newest $KEEP snapshots
#   delete <name>      delete one snapshot
#   rollback <name>    replace @ with <name> (must be booted into a snapshot)
set -eu

SNAPDIR=/.snapshots
GRUBFRAG=/boot/grub/snapshots.cfg
GRUBCFG=/boot/grub/grub.cfg
KEEP=${BLUEBERRY_SNAPSHOT_KEEP:-5}

say() { echo "blueberry-snapshot: $*"; }
die() { echo "blueberry-snapshot: $*" >&2; exit 1; }

require_btrfs_root() {
    [ "$(findmnt -no FSTYPE / 2>/dev/null)" = btrfs ] \
        || die "root is not btrfs — snapshots not applicable"
    [ -d "$SNAPDIR" ] \
        || die "$SNAPDIR is missing (the installer creates the @snapshots subvol)"
}

ts_now() { date +%Y%m%d-%H%M%S; }

# Newest-first list of snapshot directory paths.
snap_dirs() { ls -1dr "$SNAPDIR"/*/ 2>/dev/null || true; }

# Make sure the main grub.cfg sources our fragment (idempotent; needed on
# systems installed before this tool existed).
ensure_grub_source() {
    [ -f "$GRUBCFG" ] || return 0
    grep -q 'snapshots.cfg' "$GRUBCFG" && return 0
    printf '\nif [ -f /@/boot/grub/snapshots.cfg ]; then source /@/boot/grub/snapshots.cfg; fi\n' \
        >> "$GRUBCFG"
    say "linked snapshots menu into $GRUBCFG"
}

cmd_create() {
    require_btrfs_root
    label=$(printf '%s' "${1:-manual}" | tr -c 'A-Za-z0-9._-' '-')
    name="$(ts_now)-${label}"
    dest="$SNAPDIR/$name"
    [ -e "$dest" ] && die "snapshot $name already exists"
    btrfs subvolume snapshot / "$dest" >/dev/null || die "btrfs snapshot failed"
    say "created snapshot $name"
    cmd_prune
    cmd_grub
}

cmd_list() {
    require_btrfs_root
    for d in $(snap_dirs); do basename "$d"; done
}

cmd_prune() {
    require_btrfs_root
    n=0
    for d in $(snap_dirs); do
        n=$((n + 1))
        [ "$n" -le "$KEEP" ] && continue
        btrfs subvolume delete "$d" >/dev/null 2>&1 && say "pruned $(basename "$d")"
    done
}

cmd_delete() {
    require_btrfs_root
    name=${1:-}; [ -n "$name" ] || die "usage: blueberry-snapshot delete <name>"
    [ -d "$SNAPDIR/$name" ] || die "no such snapshot: $name"
    btrfs subvolume delete "$SNAPDIR/$name" >/dev/null || die "delete failed"
    say "deleted $name"
    cmd_grub
}

# Clone the main menuentry once per snapshot, rewriting the boot path and the
# rootflags subvol so each entry boots that snapshot as a full system.
cmd_grub() {
    require_btrfs_root
    ensure_grub_source
    [ -f "$GRUBCFG" ] || die "no $GRUBCFG to derive boot entries from"
    search=$(grep -m1 'search .*--fs-uuid' "$GRUBCFG" | sed 's/^[[:space:]]*//' || true)
    linux=$(grep -m1 '^[[:space:]]*linux ' "$GRUBCFG" | sed 's/^[[:space:]]*//' || true)
    initrd=$(grep -m1 '^[[:space:]]*initrd ' "$GRUBCFG" | sed 's/^[[:space:]]*//' || true)
    [ -n "$linux" ] && [ -n "$initrd" ] || die "cannot parse the main menuentry in $GRUBCFG"
    tmp="$GRUBFRAG.tmp.$$"
    {
        echo "# Generated by blueberry-snapshot — do not edit by hand."
        echo "submenu 'Blueberry snapshots (rollback)' {"
        for d in $(snap_dirs); do
            name=$(basename "$d")
            l=$(printf '%s' "$linux" | sed "s#/@/boot#/@snapshots/$name/boot#; s#subvol=@ #subvol=@snapshots/$name #")
            i=$(printf '%s' "$initrd" | sed "s#/@/boot#/@snapshots/$name/boot#")
            echo "  menuentry 'Blueberry snapshot $name' {"
            [ -n "$search" ] && echo "    $search"
            echo "    insmod btrfs"
            echo "    $l"
            echo "    $i"
            echo "  }"
        done
        echo "}"
    } > "$tmp"
    mv "$tmp" "$GRUBFRAG"
    say "wrote $GRUBFRAG ($(snap_dirs | grep -c . || true) snapshot(s))"
}

cmd_rollback() {
    require_btrfs_root
    target=${1:-}; [ -n "$target" ] || die "usage: blueberry-snapshot rollback <name>"
    [ -d "$SNAPDIR/$target" ] || die "no such snapshot: $target"
    # @ cannot be replaced while it is the live root; the caller must have booted
    # a snapshot entry (GRUB > Blueberry snapshots) or a rescue first.
    cur=$(findmnt -no OPTIONS / | tr ',' '\n' | sed -n 's/^subvol=//p' | sed 's#^/##')
    case "$cur" in
        @) die "refusing to roll back while running from @ — reboot, pick GRUB > \
'Blueberry snapshots' > $target, then run 'blueberry-snapshot rollback $target'";;
    esac
    dev=$(findmnt -no SOURCE /)
    top=$(mktemp -d)
    mount -o subvolid=5 "$dev" "$top" || { rmdir "$top"; die "cannot mount btrfs top-level"; }
    old="@rollback-$(ts_now)"
    if ! mv "$top/@" "$top/$old"; then
        umount "$top"; rmdir "$top"; die "cannot move current @ aside"
    fi
    if btrfs subvolume snapshot "$top/@snapshots/$target" "$top/@" >/dev/null; then
        say "@ replaced with $target; previous @ kept as $old"
        umount "$top"; rmdir "$top"
        say "reboot into the default entry to run the restored system"
    else
        mv "$top/$old" "$top/@"          # best-effort restore
        umount "$top"; rmdir "$top"
        die "snapshot->@ failed; restored the original @"
    fi
}

cmd=${1:-}; shift 2>/dev/null || true
case "$cmd" in
    create)   cmd_create "$@";;
    list)     cmd_list;;
    grub)     cmd_grub;;
    prune)    cmd_prune;;
    delete)   cmd_delete "$@";;
    rollback) cmd_rollback "$@";;
    -h|--help|help|"") cat <<'USAGE';;
blueberry-snapshot — btrfs snapshot + boot-level rollback

  blueberry-snapshot create [label]   snapshot @ now (prunes + refreshes GRUB)
  blueberry-snapshot list             list snapshots (newest first)
  blueberry-snapshot grub             regenerate the GRUB snapshot menu
  blueberry-snapshot prune            keep only the newest $KEEP
  blueberry-snapshot delete <name>    delete one snapshot
  blueberry-snapshot rollback <name>  replace @ with <name> (boot a snapshot first)

Env: BLUEBERRY_SNAPSHOT_KEEP (default 5).
USAGE
    *) die "unknown command '$cmd' (try: blueberry-snapshot help)";;
esac
