# Blueberry Linux — Linux 7.0 minimal server kernel configuration
# Target: x86_64 bare-metal and VM (KVM/Xen/VMware)
# Philosophy: nothing you don't need, everything you do

#
# General setup
#
CONFIG_LOCALVERSION="-blueberry"
# Kernel image is self-decompressing; we build it zstd-compressed. Only one
# KERNEL_* compressor is ever used, so don't drag in the gzip path too.
CONFIG_KERNEL_ZSTD=y
# CONFIG_KERNEL_GZIP is not set
CONFIG_DEFAULT_HOSTNAME="blueberry"
CONFIG_SWAP=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT_NONE=y
CONFIG_HZ_250=y

#
# CPU
#
CONFIG_SMP=y
CONFIG_NR_CPUS=256
CONFIG_X86_64=y
CONFIG_X86_X2APIC=y
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y
CONFIG_XEN=y

#
# Memory
#
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_NUMA=y
CONFIG_BALLOON_COMPACTION=y
CONFIG_COMPACTION=y
CONFIG_MIGRATION=y
CONFIG_KSM=y

#
# Security
#
CONFIG_SECURITY=y
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_INTEGRITY=y
CONFIG_IMA=y
CONFIG_EVM=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_CC_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_PAGE_TABLE_ISOLATION=y
CONFIG_RETPOLINE=y

#
# Filesystem
#
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_BTRFS_FS=y
CONFIG_XFS_FS=y
CONFIG_VFAT_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_QUOTA=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_ISO9660_FS=y

#
# PCI bus (required for NICs, NVMe, GPU, and most real hardware)
#
CONFIG_PCI=y
CONFIG_PCI_QUIRKS=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIEAER=y
CONFIG_PCIE_ECRC=y
CONFIG_HOTPLUG_PCI=y
CONFIG_HOTPLUG_PCI_PCIE=y
CONFIG_HOTPLUG_PCI_ACPI=y

#
# SCSI + ATA/SATA (real disks, SATA CD-ROMs, USB storage all need this)
#
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y
CONFIG_SCSI_VIRTIO=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_PIIX=y
CONFIG_SATA_SIL=y
CONFIG_ATA_GENERIC=y

#
# Block devices
#
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_CRYPT=y
CONFIG_DM_THIN_PROVISIONING=y
CONFIG_MD=y
CONFIG_MD_RAID0=y
CONFIG_MD_RAID1=y
CONFIG_MD_RAID10=y
CONFIG_MD_RAID456=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_VIRTIO_BLK=y

#
# Networking
#
CONFIG_NET=y
# PACKET: raw packet sockets — required by DHCP clients (udhcpc), tcpdump, etc.
# UNIX: Unix-domain sockets — required by syslog, SSH, and most local IPC.
CONFIG_PACKET=y
CONFIG_PACKET_DIAG=y
CONFIG_UNIX=y
CONFIG_UNIX_DIAG=y
CONFIG_NETLINK_DIAG=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_IP_MULTICAST=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="cubic"
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NF_TABLES=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REJECT=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_IP_VS=y
CONFIG_VLAN_8021Q=y
CONFIG_BRIDGE=y
CONFIG_TUN=y
CONFIG_VETH=y
CONFIG_DUMMY=y
CONFIG_BONDING=y
CONFIG_WIREGUARD=y
CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y

#
# Network drivers
#
# NETDEVICES is the master gate: without it every NIC driver below — and the
# WireGuard/TUN/VETH/bonding devices above — is silently dropped by olddefconfig.
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_NET_VENDOR_MELLANOX=y
CONFIG_NET_VENDOR_VMWARE=y
CONFIG_VIRTIO_NET=y
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_IGB=y
CONFIG_IXGBE=y
CONFIG_MLX4_EN=y
CONFIG_MLX5_CORE=y
CONFIG_VMXNET3=y

#
# Virtualization
#
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y
CONFIG_VHOST_NET=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y

#
# Init and process
#
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_RT_GROUP_SCHED=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_PIDS=y

#
# systemd requirements (PID 1). systemd needs name_to_handle_at (FHANDLE),
# the unified cgroup v2 hierarchy (CGROUPS above), autofs for .automount units,
# tmpfs xattrs/ACLs for /run + transient units, seccomp filtering for unit
# sandboxing, kcmp, and DMI access. CRYPTO_HMAC backs systemd-cryptsetup/keys.
#
CONFIG_FHANDLE=y
CONFIG_AUTOFS_FS=y
CONFIG_TMPFS_XATTR=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_KCMP=y
CONFIG_DMIID=y
CONFIG_CRYPTO_HMAC=y

#
# BPF / eBPF
#
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_EVENTS=y
CONFIG_PERF_EVENTS=y

#
# Cryptography
#
CONFIG_CRYPTO=y
CONFIG_CRYPTO_MANAGER=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_NI_INTEL=y
# LUKS dm-crypt default cipher is aes-xts-plain64 — needs the XTS template
# (plus ECB/CBC for other LUKS profiles). Without XTS, dm-crypt fails with
# "Error allocating crypto tfm (-ENOENT)".
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_ECB=y
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_GHASH_CLMUL_NI_INTEL=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_CHACHA20POLY1305=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_ECDH=y
CONFIG_CRYPTO_USER_API_HASH=y
CONFIG_CRYPTO_USER_API_SKCIPHER=y

#
# Initramfs support (required to boot from initrd/initramfs)
#
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
# Blueberry's initramfs is always zstd (initramfs.cpio.zst). Keep gzip too as a
# universal fallback for hand-built initrds; drop the bzip2/lzma/xz/lzo/lz4
# decompressors — nothing we ship uses them.
CONFIG_RD_GZIP=y
CONFIG_RD_ZSTD=y
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set

#
# Serial console (required for QEMU -nographic and headless VMs)
#
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4
# CONFIG_SERIAL_8250_EXTENDED is not set

#
# USB (real-hardware keyboards, USB install media, USB NICs)
#
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_PCI=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PCI=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y
CONFIG_USB_HID=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y

#
# Firmware loading (real NICs/devices that need blobs in /lib/firmware)
#
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_EXTRA_FIRMWARE=""

#
# Squashfs (read-only live/install media root)
#
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_FILE_DIRECT=y

#
# UEFI boot + GPT (modern bare-metal servers)
#
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=y
CONFIG_EFIVAR_FS=y
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y
CONFIG_FAT_FS=y
CONFIG_NLS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y

#
# Framebuffer console — real UEFI machines (laptops/desktops) have no legacy
# VGA text console, only the EFI GOP framebuffer. Without this the kernel boots
# invisibly and the screen stays on the firmware logo. efifb drives the UEFI
# framebuffer; vesafb covers BIOS graphics; vgacon still handles BIOS text.
#
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FB_VESA=y
CONFIG_FB_SIMPLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_SYSFB_SIMPLEFB=y

#
# Debugging: strip to minimum for production
#
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_FTRACE is not set
CONFIG_MAGIC_SYSRQ=y
CONFIG_PRINTK=y
CONFIG_BUG=y

#
# Wireless (Realtek + Intel WiFi for laptops/desktops)
#
# Built-in (the kernel has no modules), so the cfg80211/mac80211 stack and the
# NIC drivers are all =y. The drivers still load their firmware blobs from
# /lib/firmware at runtime — install the matching firmware there for the device
# to associate (the driver itself is present either way).
#
CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_WLAN=y
# Intel
CONFIG_WLAN_VENDOR_INTEL=y
CONFIG_IWLWIFI=y
CONFIG_IWLMVM=y
CONFIG_IWLDVM=y
# Realtek — PCIe (rtlwifi legacy, rtw88, rtw89) + common USB dongles (rtl8xxxu)
CONFIG_WLAN_VENDOR_REALTEK=y
CONFIG_RTLWIFI=y
CONFIG_RTL8192CE=y
CONFIG_RTL8192SE=y
CONFIG_RTL8192DE=y
CONFIG_RTL8723AE=y
CONFIG_RTL8723BE=y
CONFIG_RTL8188EE=y
CONFIG_RTL8821AE=y
CONFIG_RTL8192EE=y
CONFIG_RTW88=y
CONFIG_RTW88_8822BE=y
CONFIG_RTW88_8822CE=y
CONFIG_RTW88_8821CE=y
CONFIG_RTW88_8723DE=y
CONFIG_RTW89=y
CONFIG_RTW89_8852AE=y
CONFIG_RTW89_8852BE=y
CONFIG_RTW89_8852CE=y
CONFIG_RTW89_8851BE=y
CONFIG_RTL8XXXU=y

#
# Not on a server
#
# CONFIG_SOUND is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_VIDEO_V4L2 is not set
# ── DRM / KMS (graphical desktop: provides /dev/dri for KWin/Wayland) ──────────
# Without DRM there is no /dev/dri device, so kwin_wayland (and any GPU compositor)
# cannot start a session and the display stays on the VGA/fbcon text console.
# VM GPUs are built in so the live ISO renders out of the box under QEMU/KVM;
# real-hardware drivers are modules (load when the matching GPU is present).
CONFIG_DRM=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_GEM_SHMEM_HELPER=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_BOCHS=y
CONFIG_DRM_QXL=y
CONFIG_DRM_VBOXVIDEO=m
# Real-hardware GPU drivers (modules; need linux-firmware for full KMS).
CONFIG_DRM_I915=m
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_AMDGPU_SI=y
CONFIG_DRM_AMDGPU_CIK=y
CONFIG_DRM_RADEON=m
CONFIG_DRM_NOUVEAU=m
CONFIG_DRM_AST=m
# (CONFIG_FB is enabled above for the EFI/VESA framebuffer console)
