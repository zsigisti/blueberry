# Build artefacts — generated by make, never committed
# Output goes to ../blueberry-build (outside the source tree) by default.
# If you override OBJDIR to a path inside the source tree, add it here.

# Machine-local build config (see Make.config for defaults)
Make.local

# Editor cruft
*.swp
*.swo
.DS_Store
*~

# QEMU run artefacts
*.qcow2
serial.log
*.iso
