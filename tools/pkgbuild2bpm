#!/usr/bin/env python3
"""pkgbuild2bpm — convert an Arch-style PKGBUILD into a native bpm.toml recipe.

EXPERIMENTAL (feature/bpm-pkg-format). Mechanical migration helper for the
~280 existing recipes. Sources the PKGBUILD in a sandboxed shell to capture its
variables and the bodies of build()/package()/prepare(), then emits bpm.toml.

  pkgbuild2bpm <packages/NAME/PKGBUILD> [> packages/NAME/bpm.toml]

Not every PKGBUILD converts perfectly (arrays built by loops, exotic bash) — the
output is a faithful starting point that a human reviews, exactly like any
automated port. Review before trusting in production.
"""
import json
import os
import subprocess
import sys

PROBE = r'''
set +e
# Source the PKGBUILD with placeholder helpers so it doesn't error on Arch-isms.
srcdir=/tmp/_s; pkgdir=/tmp/_p
. "$1" 2>/dev/null
emit() { printf '%s\0' "$1"; for v in "${@:2}"; do printf '%s\0' "$v"; done; printf '\036'; }
emit pkgname "${pkgname[@]}"
emit pkgver "$pkgver"
emit pkgrel "$pkgrel"
emit pkgdesc "$pkgdesc"
emit url "$url"
emit arch "${arch[@]}"
emit license "${license[@]}"
emit depends "${depends[@]}"
emit makedepends "${makedepends[@]}"
emit provides "${provides[@]}"
emit options "${options[@]}"
emit source "${source[@]}"
emit sha256sums "${sha256sums[@]}"
emit _prepare "$(declare -f prepare 2>/dev/null)"
emit _build "$(declare -f build 2>/dev/null)"
emit _package "$(declare -f package 2>/dev/null)"
'''


def toml_str(v):
    return '"' + str(v).replace("\\", "\\\\").replace('"', '\\"') + '"'


def toml_arr(items):
    return "[" + ", ".join(toml_str(x) for x in items) + "]"


def func_body(declared):
    """Extract the body between the first { and last } of `declare -f name`."""
    if not declared.strip():
        return ""
    i, j = declared.find("{"), declared.rfind("}")
    if i < 0 or j < 0:
        return ""
    lines = declared[i + 1 : j].splitlines()
    # strip one level of leading indentation, drop blank edges
    out = [ln[4:] if ln.startswith("    ") else ln for ln in lines]
    while out and not out[0].strip():
        out.pop(0)
    while out and not out[-1].strip():
        out.pop()
    return "\n".join(out)


def subst_vars(body):
    """Map PKGBUILD vars to bpmbuild's env names."""
    return (body.replace("$pkgver", "$version")
                .replace("${pkgver}", "$version")
                .replace("$pkgname", "$name")
                .replace("${pkgname}", "$name")
                .replace("$pkgrel", "$release")
                .replace("${pkgrel}", "$release"))


def main():
    if len(sys.argv) < 2:
        sys.exit("usage: pkgbuild2bpm <PKGBUILD>")
    pb = sys.argv[1]
    raw = subprocess.run(["bash", "-c", PROBE, "_", pb],
                         capture_output=True, text=True).stdout
    fields = {}
    for rec in raw.split("\036"):
        parts = [p for p in rec.split("\0") if p != ""]
        if not parts:
            continue
        fields[parts[0]] = parts[1:]

    def one(k):
        v = fields.get(k, [])
        return v[0] if v else ""

    def many(k):
        return [x for x in fields.get(k, []) if x]

    pkgver, pkgrel = one("pkgver"), one("pkgrel") or "1"
    sources = many("source")
    sums = many("sha256sums")

    out = []
    out.append("[package]")
    out.append(f"name     = {toml_str(one('pkgname'))}")
    out.append(f"version  = {toml_str(pkgver)}")
    out.append(f"release  = {pkgrel}")
    if one("pkgdesc"):
        out.append(f"summary  = {toml_str(one('pkgdesc'))}")
    if one("url"):
        out.append(f"homepage = {toml_str(one('url'))}")
    if many("license"):
        out.append(f"license  = {toml_arr(many('license'))}")
    out.append(f"arch     = {toml_arr(many('arch') or ['x86_64'])}")
    out.append("")
    if many("depends"):
        out.append(f"depends     = {toml_arr(many('depends'))}")
    if many("makedepends"):
        out.append(f"makedepends = {toml_arr(many('makedepends'))}")
    if many("provides"):
        out.append(f"provides    = {toml_arr(many('provides'))}")
    if many("options"):
        out.append(f"options     = {toml_arr(many('options'))}")
    out.append("")

    # Sources: pair each url with its checksum, resolving $pkgver in the URL.
    for i, s in enumerate(sources):
        url = subst_vars(s).replace("$version", pkgver).replace("$release", pkgrel)
        # PKGBUILD allows "rename::url" — keep the whole thing so bpmbuild can
        # name a download whose URL has no usable basename (e.g. a redirect).
        sha = sums[i] if i < len(sums) else "SKIP"
        out.append("[[source]]")
        out.append(f"url    = {toml_str(url)}")
        out.append(f"sha256 = {toml_str(sha)}")
        out.append("")

    out.append("[steps]")
    prep = func_body(one("_prepare"))
    build = func_body(one("_build"))
    pkg = func_body(one("_package"))
    # bpmbuild has build + package; fold prepare() into the front of build.
    if prep:
        build = prep + "\n" + build if build else prep
    if build:
        out.append("build = '''")
        out.append(subst_vars(build))
        out.append("'''")
    if pkg:
        out.append("package = '''")
        out.append(subst_vars(pkg))
        out.append("'''")

    sys.stdout.write("\n".join(out) + "\n")


if __name__ == "__main__":
    main()
