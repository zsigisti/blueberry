#!/usr/bin/env python3
"""arch-import — repackage official Arch Linux binary packages as native .bpm.

Blueberry and Arch share the x86_64 ABI (same glibc), and bpm reads a package's
payload identically whether the metadata arrives as Arch's `.PKGINFO` or a native
`.BPM` TOML. So importing a proven Arch binary package is a *metadata rewrite +
repack*, not a rebuild:

  1. resolve <name> -> exact filename/version from Arch's core/extra .db
  2. download the .pkg.tar.zst from a pinned mirror
  3. restage the payload, dropping Arch-only metadata (.PKGINFO/.BUILDINFO/.MTREE)
  4. rewrite the metadata into a .BPM manifest (deps/provides stripped of version
     constraints; epoch folded into the version)
  5. repack to <name>-<ver>-<rel>-<arch>.bpm using bpmbuild's exact payload
     normalisation, so `bpmbuild --check` binds the artifact to its manifest

The result drops into the same repo/index/install path as a Blueberry-built .bpm
(tools/release/repo-publish.sh). Post-install scriptlets (Arch `.INSTALL`) are NOT
translated yet — packages that need them are flagged, not silently shipped.

Usage:
  tools/pkg/arch-import <outdir> <pkgname> [pkgname...]

Env:
  ARCH_MIRROR   mirror base (default https://geo.mirror.pkgbuild.com)
  ARCH_REPOS    space-separated repos to search (default "core extra")
"""
import importlib.machinery
import importlib.util
import io
import os
import subprocess
import sys
import tarfile
import urllib.request

HERE = os.path.dirname(os.path.abspath(__file__))
MIRROR = os.environ.get("ARCH_MIRROR", "https://geo.mirror.pkgbuild.com").rstrip("/")
REPOS = os.environ.get("ARCH_REPOS", "core extra").split()

# Reuse bpmbuild's payload machinery so the digest matches `bpmbuild --check`.
# bpmbuild has no .py extension, so load it via an explicit source loader.
_loader = importlib.machinery.SourceFileLoader("bpmbuild", os.path.join(HERE, "bpmbuild"))
bb = importlib.util.module_from_spec(importlib.util.spec_from_loader("bpmbuild", _loader))
_loader.exec_module(bb)


def fetch(url):
    with urllib.request.urlopen(url, timeout=60) as r:
        return r.read()


def load_db(repo):
    """name -> (filename, version) from a repo's .db (a gzip tar of desc files)."""
    raw = fetch(f"{MIRROR}/{repo}/os/x86_64/{repo}.db")
    out = {}
    with tarfile.open(fileobj=io.BytesIO(raw), mode="r:gz") as t:
        for m in t:
            if not m.name.endswith("/desc"):
                continue
            desc = t.extractfile(m).read().decode()
            fields, key = {}, None
            for line in desc.splitlines():
                if line.startswith("%") and line.endswith("%"):
                    key = line.strip("%")
                    fields[key] = []
                elif line.strip() and key:
                    fields[key].append(line.strip())
            name = fields.get("NAME", [None])[0]
            if name:
                out[name] = (fields["FILENAME"][0], fields["VERSION"][0])
    return out


def bare(dep):
    """Arch dep/provide -> bare package name (drop version/soname constraints)."""
    for sep in ("<=", ">=", "=", "<", ">", ":"):
        i = dep.find(sep)
        if i != -1:
            dep = dep[:i]
    return dep.strip()


def parse_pkginfo(text):
    f = {}
    for line in text.splitlines():
        if line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        f.setdefault(k.strip(), []).append(v.strip())
    return f


def import_one(name, outdir, dbs):
    where = next((r for r in REPOS if name in dbs[r]), None)
    if not where:
        sys.exit(f"arch-import: {name} not found in {'/'.join(REPOS)}")
    filename, version = dbs[where][name]
    url = f"{MIRROR}/{where}/os/x86_64/{filename}"
    print(f"[arch-import] {name} {version} <- {where}/{filename}")
    blob = fetch(url)

    work = os.path.join(outdir, f".stage-{name}")
    subprocess.run(["rm", "-rf", work], check=True)
    os.makedirs(work, exist_ok=True)
    # extract payload; keep Arch metadata aside
    with tarfile.open(fileobj=io.BytesIO(blob), mode="r:zst") as t:
        t.extractall(work, filter="tar")

    pkginfo = parse_pkginfo(open(os.path.join(work, ".PKGINFO")).read())
    has_install = os.path.exists(os.path.join(work, ".INSTALL"))
    # drop Arch-only metadata members from the payload
    for meta in (".PKGINFO", ".BUILDINFO", ".MTREE", ".INSTALL", ".CHANGELOG"):
        p = os.path.join(work, meta)
        if os.path.exists(p):
            os.remove(p)

    # version/release/epoch: Arch pkgver is [epoch:]ver-rel
    pv = pkginfo["pkgver"][0]
    ver, rel = pv.rsplit("-", 1)  # rel is the pkgrel
    # Blueberry's index resolves deps by PACKAGE NAME (no provides column), so
    # keep Arch's real package deps and drop its auto-detected soname deps
    # (libX.so) — the library is already pulled in via its owning package, and a
    # bare soname would just be silently skipped by the resolver.
    def keep(d):
        b = bare(d)
        return b and not b.endswith(".so")
    depends = sorted({bare(d) for d in pkginfo.get("depend", []) if keep(d)})
    provides = sorted({bare(d) for d in pkginfo.get("provides", []) if bare(d)})
    backup = [b.lstrip("/") for b in pkginfo.get("backup", [])]
    arch_tag = pkginfo.get("arch", ["x86_64"])[0]

    payload_sha, installed_size = bb.payload_digest(work)
    manifest = "\n".join([
        "format = 1",
        f"name = {bb.toml_str(name)}",
        f"version = {bb.toml_str(ver)}",
        f"release = {int(rel) if rel.isdigit() else 1}",
        f"arch = {bb.toml_str(arch_tag)}",
        f"summary = {bb.toml_str(pkginfo.get('pkgdesc',[''])[0])}",
        f"depends = {bb.toml_str(depends)}",
        f"provides = {bb.toml_str(provides)}",
        f"backup = {bb.toml_str(backup)}",
        f"installed_size = {installed_size}",
        f"build_date = {bb.SDE}",
        f"payload_sha256 = {bb.toml_str(payload_sha)}",
    ]) + "\n"

    out = os.path.join(outdir, f"{name}-{ver}-{int(rel) if rel.isdigit() else 1}-{arch_tag}.bpm")
    raw = os.path.join(outdir, f".{name}.tar")
    with tarfile.open(raw, "w") as t:
        info = tarfile.TarInfo(".BPM")
        data = manifest.encode()
        info.size = len(data)
        bb._reset(info)
        t.addfile(info, io.BytesIO(data))
        for m in bb._payload_members(work):
            arc = "./" + os.path.relpath(m, work)
            t.add(m, arcname=arc, recursive=False, filter=bb._reset)
    with open(raw, "rb") as fi, open(out, "wb") as fo:
        subprocess.run(["zstd", "-19", "-q", "-c"], stdin=fi, stdout=fo, check=True)
    os.remove(raw)
    subprocess.run(["rm", "-rf", work], check=True)
    print(f"[arch-import] wrote {out} ({os.path.getsize(out)} bytes)")
    if has_install:
        print(f"[arch-import] WARNING {name} ships an Arch .INSTALL scriptlet that "
              f"was NOT translated — verify it needs no post-install action")
    return out


def main():
    if len(sys.argv) < 3:
        sys.exit(__doc__)
    outdir = sys.argv[1]
    names = sys.argv[2:]
    os.makedirs(outdir, exist_ok=True)
    dbs = {r: load_db(r) for r in REPOS}
    for n in names:
        import_one(n, outdir, dbs)


if __name__ == "__main__":
    main()
