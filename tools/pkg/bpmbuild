#!/usr/bin/env python3
"""bpmbuild — build a Blueberry `.bpm` package from a `bpm.toml` recipe.

EXPERIMENTAL (feature/bpm-pkg-format). Replaces makepkg+PKGBUILD for the native
package format. See doc/BPM-FORMAT.md.

  bpmbuild <recipe-dir> <out-dir>

A recipe is a directory containing `bpm.toml`. The builder fetches+verifies
sources, runs the `build` then `package` shell steps (package under fakeroot),
synthesises the `.BPM` TOML manifest, and emits `name-ver-rel-arch.bpm`
(zstd-compressed tar with `.BPM` as the first member).
"""
import hashlib
import io
import os
import shutil
import subprocess
import sys
import tarfile
import tempfile
import time
import urllib.request
# NOTE: `tomllib` (recipe parsing) is imported lazily inside main() so the
# `--check` path runs on Python 3.10 too (tomllib is 3.11+). The BUR web server
# is 3.10 and only ever needs `--check`.

ARCH = os.environ.get("BPM_ARCH", "x86_64")
SDE = int(os.environ.get("SOURCE_DATE_EPOCH", "1767225600"))


def die(msg):
    print(f"bpmbuild: FATAL: {msg}", file=sys.stderr)
    sys.exit(1)


def log(msg):
    print(f"\033[1;36m==> {msg}\033[0m")


def toml_str(v):
    """Minimal TOML value serialiser (strings, ints, list-of-strings)."""
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, int):
        return str(v)
    if isinstance(v, list):
        return "[" + ", ".join(toml_str(x) for x in v) + "]"
    return '"' + str(v).replace("\\", "\\\\").replace('"', '\\"') + '"'


def toml_multiline(v):
    """Serialise a (possibly multi-line) script as a TOML string. Install scripts
    are shell — full of backslashes and quotes — so a single-line basic string
    with \\n escapes is unreadable and error-prone. A '''literal''' block needs no
    escaping and round-trips through any conformant TOML parser (bpm's installer
    and the BUR publish validator both re-read this). The leading newline right
    after ''' is stripped by TOML, so it is added back on read; a literal ''' in
    the body can't appear in a literal block, so fall back to escaped basic."""
    s = str(v)
    if "'''" not in s:
        return "'''\n" + s + "'''"
    esc = s.replace("\\", "\\\\").replace('"""', '""\\"')
    return '"""\n' + esc + '"""'


# Blueberry ships its CA trust as a single bundle file and does NOT create the
# hashed CApath (or the /etc/ssl/cert.pem CAfile) that OpenSSL's default verify
# paths look for, so Python's stock SSL context trusts nothing and every https
# fetch dies with CERTIFICATE_VERIFY_FAILED. Point it at the bundle explicitly.
CA_BUNDLES = (
    "/etc/ssl/certs/ca-certificates.crt",   # Blueberry / Debian / Arch
    "/etc/pki/tls/certs/ca-bundle.crt",     # Fedora / RHEL
    "/etc/ssl/cert.pem",                    # OpenSSL default CAfile / BSD
)


def ssl_context():
    import ssl

    ctx = ssl.create_default_context()
    if ctx.cert_store_stats()["x509_ca"]:
        return ctx
    env = os.environ.get("SSL_CERT_FILE")
    for ca in ([env] if env else []) + list(CA_BUNDLES):
        if ca and os.path.isfile(ca):
            ctx.load_verify_locations(cafile=ca)
            return ctx
    die("no CA trust store found — install ca-certificates (`bpm install ca-certificates`)")


def fetch(url, dest):
    log(f"fetch {url}")
    # curl handles redirects/TLS uniformly; fall back to urllib if absent.
    # Retry transient failures (vendor CDNs / GitHub rate-limit large binary
    # downloads when many packages build in parallel). --retry-all-errors also
    # retries HTTP 4xx/5xx, not just connection errors.
    if shutil.which("curl"):
        subprocess.run(
            ["curl", "-fL", "--retry", "5", "--retry-delay", "3",
             "--retry-all-errors", "-o", dest, url],
            check=True,
        )
        return
    with urllib.request.urlopen(url, context=ssl_context()) as r, open(dest, "wb") as f:
        shutil.copyfileobj(r, f)


def sha256_file(path):
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1 << 20), b""):
            h.update(chunk)
    return h.hexdigest()


def run_step(script, cwd, env, fakeroot=False):
    if not script or not script.strip():
        return
    argv = ["/bin/sh", "-e", "-c", script]
    if fakeroot and shutil.which("fakeroot"):
        argv = ["fakeroot", "--"] + argv
    subprocess.run(argv, cwd=cwd, env=env, check=True)


def _manifest_field(text, key):
    """Read one scalar from a .BPM manifest (simple `key = value` lines) without
    a TOML parser — so `--check` runs on Python 3.10 (no tomllib)."""
    for line in text.splitlines():
        line = line.strip()
        if line.startswith("[") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        if k.strip() == key:
            v = v.strip()
            if len(v) >= 2 and v[0] == '"' and v[-1] == '"':
                v = v[1:-1]
            return v
    return None


def _safe_member(name):
    """A payload path that stays under the extraction root (no abs / .. escape)."""
    n = name.lstrip("./")
    return name not in (".BPM", "./.BPM") and not name.startswith("/") \
        and ".." not in n.split("/")


def check_bpm(bpm_path):
    """Verify a .bpm's payload against the manifest INSIDE it: recompute
    payload_sha256 + installed_size from the actual payload and compare. Proves
    the artifact is internally consistent (the manifest can't lie about what it
    ships), without any rebuild. Exit 0 on match, non-zero with a reason."""
    if not os.path.isfile(bpm_path):
        die(f"no such file: {bpm_path}")
    work = tempfile.mkdtemp(prefix="bpmcheck.")
    try:
        rawtar = os.path.join(work, "a.tar")
        with open(bpm_path, "rb") as fi, open(rawtar, "wb") as fo:
            if subprocess.run(["zstd", "-dcq"], stdin=fi, stdout=fo).returncode != 0:
                die("not a .bpm: could not zstd-decompress")
        pkgdir = os.path.join(work, "pkg")
        os.makedirs(pkgdir)
        manifest = None
        with tarfile.open(rawtar, "r") as t:
            # Python 3.12+ defaults extraction to the 'data' filter, which strips
            # setuid/setgid bits — that would recompute a different digest than the
            # payload actually stores (e.g. ssh-keysign 4711 -> 0711) and report a
            # false mismatch. Path traversal is already rejected by _safe_member
            # below, so extract fully-trusted to preserve modes exactly.
            if hasattr(tarfile, "fully_trusted_filter"):
                t.extraction_filter = tarfile.fully_trusted_filter
            for m in t.getmembers():
                if m.name in (".BPM", "./.BPM"):
                    manifest = t.extractfile(m).read().decode()
                    continue
                if not _safe_member(m.name):
                    die(f"unsafe payload path: {m.name}")
                t.extract(m, pkgdir)
        if manifest is None:
            die("not a .bpm: no .BPM manifest member")
        want_sha = _manifest_field(manifest, "payload_sha256")
        want_size = _manifest_field(manifest, "installed_size")
        sha, size = payload_digest(pkgdir)
        problems = []
        if want_sha and want_sha != sha:
            problems.append(f"payload_sha256: manifest {want_sha}, actual {sha}")
        if want_size and str(want_size) != str(size):
            problems.append(f"installed_size: manifest {want_size}, actual {size}")
        if problems:
            for p in problems:
                print(f"bpmbuild: {p}", file=sys.stderr)
            sys.exit(1)
        print(f"ok: payload matches manifest (sha256 {sha[:16]}…, {size} bytes)")
    finally:
        shutil.rmtree(work, ignore_errors=True)


def main():
    if len(sys.argv) == 3 and sys.argv[1] == "--check":
        check_bpm(os.path.abspath(sys.argv[2]))
        return
    if len(sys.argv) != 3:
        die("usage: bpmbuild <recipe-dir> <out-dir>\n"
            "       bpmbuild --check <file.bpm>")
    import tomllib  # lazy: 3.11+; the build path needs it, --check does not
    recipe_dir, out_dir = os.path.abspath(sys.argv[1]), os.path.abspath(sys.argv[2])
    recipe_path = os.path.join(recipe_dir, "bpm.toml")
    if not os.path.isfile(recipe_path):
        die(f"no bpm.toml in {recipe_dir}")
    with open(recipe_path, "rb") as f:
        recipe = tomllib.load(f)

    pkg = recipe.get("package") or die("recipe has no [package] table")
    name = pkg.get("name") or die("package.name missing")
    version = pkg.get("version") or die("package.version missing")
    release = int(pkg.get("release", 1))
    arches = pkg.get("arch", ["x86_64"])
    if ARCH not in arches and "any" not in arches:
        die(f"recipe does not target {ARCH} (arch = {arches})")
    arch_tag = "any" if arches == ["any"] else ARCH

    work = tempfile.mkdtemp(prefix=f"bpmbuild-{name}.")
    srcdir = os.path.join(work, "src")
    pkgdir = os.path.join(work, "pkg")
    os.makedirs(srcdir)
    os.makedirs(pkgdir)
    log(f"building {name} {version}-{release} ({arch_tag}) in {work}")

    # ── sources: fetch, verify, auto-extract tarballs ─────────────────────────
    sources = recipe.get("source", []) or recipe.get("sources", [])
    for s in sources:
        raw = s["url"]
        # `filename::url` (makepkg convention) lets a recipe name a download
        # whose URL has no usable basename (e.g. a ?query= redirect). An explicit
        # `name =` field overrides. Otherwise derive from the URL/path basename.
        if "::" in raw:
            fn, url = raw.split("::", 1)
        else:
            url, fn = raw, raw.split("/")[-1]
        fn = s.get("name", fn)
        dest = os.path.join(srcdir, fn)
        if "://" in url:
            fetch(url, dest)
        else:
            # Local source file shipped beside the recipe (.desktop, .patch,
            # .service, …) — copy it in instead of trying to curl a bare name.
            local = os.path.join(recipe_dir, url)
            if not os.path.isfile(local):
                die(f"local source '{url}' not found in {recipe_dir}")
            log(f"local source {fn}")
            shutil.copy2(local, dest)
        want = s.get("sha256", "SKIP")
        if want != "SKIP":
            got = sha256_file(dest)
            if got != want:
                die(f"sha256 mismatch for {fn}\n  want {want}\n  got  {got}")
            log(f"verified {fn} (sha256 ok)")
        else:
            log(f"{fn} (sha256 SKIP)")
        # Auto-extract archives so build() can cd into them, like makepkg. Use the
        # 'tar' filter, not 'data': sources are sha256-pinned (trusted), and 'data'
        # rejects harmless absolute-target symlinks that many GNU tarballs ship
        # (e.g. INSTALL -> /usr/share/automake/INSTALL), which would abort the whole
        # extraction. 'tar' still blocks path traversal outside srcdir.
        if fn.endswith((".tar.gz", ".tar.xz", ".tar.bz2", ".tar.zst", ".tgz")):
            try:
                with tarfile.open(dest) as t:
                    t.extractall(srcdir, filter="tar")
            except Exception as e:
                log(f"note: could not auto-extract {fn} ({e})")

    env = dict(os.environ)
    # Parallelise `make` builds. Without this, plain-make recipes (gcc, …) compile
    # single-threaded even on many-core hosts — ninja/cargo/x.py parallelise
    # themselves, but make does not. Recipes can still override via their steps.
    env.setdefault("MAKEFLAGS", f"-j{os.cpu_count() or 1}")
    env.update(
        srcdir=srcdir, pkgdir=pkgdir, name=name, version=str(version),
        release=str(release), arch=arch_tag, SOURCE_DATE_EPOCH=str(SDE),
        # startdir = the recipe directory (makepkg semantics). Recipes that pull
        # in-repo files reach them via "$startdir/../../<path>" (e.g. bpm copies
        # src/bpm-rs, linux copies src/kernel/config). Without it the path
        # resolves to /../../... and the step fails.
        startdir=recipe_dir,
    )

    log("build()")
    run_step(pkg_step(recipe, "build"), srcdir, env)
    log("package()")
    run_step(pkg_step(recipe, "package"), srcdir, env, fakeroot=True)

    # The Texinfo directory index (/usr/share/info/dir) is a generated, shared
    # index — no package may own it, or any two info-shipping packages collide
    # on install (e.g. readline vs gdbm). Strip it globally, like makepkg does.
    for junk in ("usr/share/info/dir", "usr/share/info/dir.gz"):
        p = os.path.join(pkgdir, junk)
        if os.path.exists(p):
            os.remove(p)
            log(f"pruned shared index: {junk}")

    # Declarative systemd enablement: `[package] enable = ["foo.service"]` drops
    # the markers bpm reads (usr/lib/bpm/enable/<unit>) to wire up + start the
    # unit on install. "if the app wants that" → list it in enable.
    enable = pkg.get("enable", []) or []
    if isinstance(enable, str):
        enable = [enable]
    if enable:
        endir = os.path.join(pkgdir, "usr/lib/bpm/enable")
        os.makedirs(endir, exist_ok=True)
        for unit in enable:
            open(os.path.join(endir, unit), "w").close()
            log(f"will enable systemd unit: {unit}")

    write_bpm(recipe, pkg, name, version, release, arch_tag, pkgdir, out_dir)
    shutil.rmtree(work, ignore_errors=True)


def pkg_step(recipe, key):
    # Build/package shell steps live in the [steps] table (an explicit table
    # avoids the TOML collision between a `package` key and the [package] table).
    return (recipe.get("steps", {}) or {}).get(key, "") or ""


def _reset(ti):
    """Normalise a tar entry so the payload is reproducible: fixed mtime, root
    owner. Mode is intentionally preserved (setuid bits matter)."""
    ti.mtime = SDE
    ti.uid = ti.gid = 0
    ti.uname = ti.gname = "root"
    return ti


def _payload_members(pkgdir):
    """Staged files in the deterministic order the payload tar uses."""
    members = []
    for root, dirs, files in os.walk(pkgdir):
        dirs.sort()
        for d in sorted(dirs):
            members.append(os.path.join(root, d))
        for fn in sorted(files):
            members.append(os.path.join(root, fn))
    return members


def payload_digest(pkgdir):
    """(payload_sha256, installed_size) for a staged package dir. This is the
    single source of truth for both keys, so a .bpm re-extracted and re-walked
    reproduces the same digest — which is what `--check` relies on to bind a
    published artifact to the manifest inside it, without a rebuild."""
    import io
    members = _payload_members(pkgdir)
    installed = sum(
        os.path.getsize(m) for m in members if os.path.isfile(m) and not os.path.islink(m)
    )
    buf = io.BytesIO()
    with tarfile.open(fileobj=buf, mode="w") as t:
        for m in members:
            arc = "./" + os.path.relpath(m, pkgdir)
            t.add(m, arcname=arc, recursive=False, filter=_reset)
    return hashlib.sha256(buf.getvalue()).hexdigest(), installed


def write_bpm(recipe, pkg, name, version, release, arch_tag, pkgdir, out_dir):
    os.makedirs(out_dir, exist_ok=True)
    out = os.path.join(out_dir, f"{name}-{version}-{release}-{arch_tag}.bpm")

    payload_sha, installed_size = payload_digest(pkgdir)
    reset = _reset  # the final .bpm tar reuses the same normalisation

    meta = bpm_manifest(recipe, pkg, name, version, release, arch_tag,
                        installed_size, payload_sha)
    log(f"writing {out}")
    raw = os.path.join(out_dir, f".{name}.tar")
    with tarfile.open(raw, "w") as t:
        info = tarfile.TarInfo(".BPM")
        data = meta.encode()
        info.size = len(data)
        reset(info)
        t.addfile(info, io.BytesIO(data))
        for m in _payload_members(pkgdir):
            arc = "./" + os.path.relpath(m, pkgdir)
            t.add(m, arcname=arc, recursive=False, filter=reset)
    # zstd-compress (level 19) to the final .bpm
    with open(raw, "rb") as fi, open(out, "wb") as fo:
        subprocess.run(["zstd", "-19", "-q", "-c"], stdin=fi, stdout=fo, check=True)
    os.remove(raw)
    log(f"built {out} ({os.path.getsize(out)} bytes, installed {installed_size})")


def bpm_manifest(recipe, pkg, name, version, release, arch_tag, size, payload_sha):
    lines = [
        "format = 1",
        f"name = {toml_str(name)}",
        f"version = {toml_str(str(version))}",
        f"release = {release}",
        f"arch = {toml_str(arch_tag)}",
        f"summary = {toml_str(pkg.get('summary',''))}",
        f"depends = {toml_str(pkg.get('depends',[]))}",
        f"provides = {toml_str(pkg.get('provides',[]))}",
        f"backup = {toml_str(pkg.get('backup',[]))}",
        f"installed_size = {size}",
        f"build_date = {SDE}",
        f"payload_sha256 = {toml_str(payload_sha)}",
    ]
    scripts = recipe.get("scripts", {})
    if scripts:
        lines.append("")
        lines.append("[scripts]")
        for k in ("post_install", "post_upgrade", "post_remove"):
            if scripts.get(k):
                lines.append(f"{k} = {toml_multiline(scripts[k])}")
    return "\n".join(lines) + "\n"


if __name__ == "__main__":
    main()
